/**app.wxss — garcia-fitness-new 深色主题风格**/

/* ========================
   CSS 变量（颜色系统）— 夜间主题（默认）
   ======================== */
page {
  --bg: #131313;
  --surface: #1c1c1c;
  --surface-low: #181818;
  --surface-high: #262626;
  --card-bg: rgba(255, 255, 255, 0.05);
  --card-border: rgba(255, 255, 255, 0.10);
  --primary: #ccf200;
  --primary-dim: #b3d400;
  /* 文字/边框场景用：day 主题下 lime 看不清，换深橄榄绿 */
  --primary-text: #ccf200;
  /* lime 软背景（如标签底色），day 主题下用深橄榄绿保持低饱和度可读 */
  --primary-bg-soft: rgba(204, 242, 0, 0.15);
  --text-primary: #ffffff;
  --text-secondary: #a1a1aa;
  --text-muted: #71717a;
  --divider: rgba(255, 255, 255, 0.10);
  --input-bg: rgba(255, 255, 255, 0.05);
  --red: #ef4444;

  background: var(--bg);
  color: var(--text-primary);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
}

/* ========================
   日间主题（light mode）
   ======================== */
page.theme-day {
  --bg: #f5f5f5;
  --surface: #ffffff;
  --surface-low: #f0f0f0;
  --surface-high: #e0e0e0;
  --card-bg: rgba(0, 0, 0, 0.05);
  --card-border: rgba(0, 0, 0, 0.10);
  --primary: #ccf200;
  --primary-dim: #b3d400;
  /* lime #ccf200 在白底上对比度差，文字/边框场景用深橄榄绿保可读 */
  --primary-text: #3a4a00;
  --primary-bg-soft: rgba(58, 74, 0, 0.15);
  --text-primary: #1a1a1a;
  --text-secondary: #52525b;
  --text-muted: #a1a1aa;
  --divider: rgba(0, 0, 0, 0.10);
  --input-bg: rgba(0, 0, 0, 0.05);
  --red: #ef4444;
  /* ————— 硬编码兜底（day）————— */
  background: #f5f5f5;
  color: #1a1a1a;
}
page.theme-day .card {
  background: rgba(0, 0, 0, 0.05);
  border-color: rgba(0, 0, 0, 0.10);
}
page.theme-day .btn-primary {
  background: #ccf200;
  color: #000;
}
page.theme-day .btn-ghost {
  background: rgba(0, 0, 0, 0.05);
  color: #1a1a1a;
  border-color: rgba(0, 0, 0, 0.10);
}
page.theme-day .tag {
  background: var(--primary-bg-soft);
  color: var(--primary-text);
}
page.theme-day .tag-neutral {
  background: rgba(0, 0, 0, 0.08);
  color: #a1a1aa;
}
page.theme-day .tag-blue {
  background: rgba(59, 130, 246, 0.15);
  color: #60a5fa;
}
page.theme-day .input {
  background: rgba(0, 0, 0, 0.05);
  border-color: rgba(0, 0, 0, 0.10);
  color: #1a1a1a;
}
page.theme-day .input:focus {
  border-color: var(--primary-text);
}
page.theme-day .input-placeholder {
  color: #a1a1aa;
}
page.theme-day .text-primary { color: var(--primary-text); }
page.theme-day .text-secondary { color: #52525b; }
page.theme-day .text-muted { color: #a1a1aa; }


/* ========================
   夜间主题 explicit class
   ======================== */
page.theme-night {
  --bg: #131313;
  --surface: #1c1c1c;
  --surface-low: #181818;
  --surface-high: #262626;
  --card-bg: rgba(255, 255, 255, 0.05);
  --card-border: rgba(255, 255, 255, 0.10);
  --primary: #ccf200;
  --primary-dim: #b3d400;
  --primary-text: #ccf200;
  --primary-bg-soft: rgba(204, 242, 0, 0.15);
  --text-primary: #ffffff;
  --text-secondary: #a1a1aa;
  --text-muted: #71717a;
  --divider: rgba(255, 255, 255, 0.10);
  --input-bg: rgba(255, 255, 255, 0.05);
  --red: #ef4444;
  /* ————— 硬编码兜底（night）————— */
  background: #131313;
  color: #ffffff;
}
page.theme-night .card {
  background: rgba(255, 255, 255, 0.05);
  border-color: rgba(255, 255, 255, 0.10);
}
page.theme-night .btn-primary {
  background: #ccf200;
  color: #000;
}
page.theme-night .btn-ghost {
  background: rgba(255, 255, 255, 0.05);
  color: #ffffff;
  border-color: rgba(255, 255, 255, 0.10);
}
page.theme-night .tag {
  background: var(--primary-bg-soft);
  color: var(--primary);
}
page.theme-night .tag-neutral {
  background: rgba(255, 255, 255, 0.08);
  color: #71717a;
}
page.theme-night .tag-blue {
  background: rgba(59, 130, 246, 0.15);
  color: #60a5fa;
}
page.theme-night .input {
  background: rgba(255, 255, 255, 0.05);
  border-color: rgba(255, 255, 255, 0.10);
  color: #ffffff;
}
page.theme-night .input:focus {
  border-color: var(--primary);
}
page.theme-night .input-placeholder {
  color: #71717a;
}
page.theme-night .text-primary { color: var(--primary); }
page.theme-night .text-secondary { color: #a1a1aa; }
page.theme-night .text-muted { color: #71717a; }


/* ========================
   glass-card — 玻璃态卡片
   ======================== */
.card {
  background: var(--card-bg);
  border: 1px solid var(--card-border);
  border-radius: 24rpx;
  overflow: hidden;
}

/* ========================
   按钮
   ======================== */
.btn-primary {
  background: var(--primary);
  color: #000;
  border-radius: 100rpx;
  font-size: 28rpx;
  font-weight: 800;
  text-align: center;
  line-height: 2.4;
  letter-spacing: 0.08em;
  border: none;
  width: 100%;
}
.btn-primary::after { border: none; }

.btn-ghost {
  background: var(--card-bg);
  color: var(--text-primary);
  border: 1px solid var(--card-border);
  border-radius: 100rpx;
  font-size: 26rpx;
  font-weight: 700;
  text-align: center;
  line-height: 2.2;
  letter-spacing: 0.05em;
}
.btn-ghost::after { border: none; }

.btn-danger {
  background: rgba(239, 68, 68, 0.15);
  color: #ef4444;
  border: 1px solid rgba(239, 68, 68, 0.3);
  border-radius: 100rpx;
  font-size: 28rpx;
  font-weight: 800;
  text-align: center;
  line-height: 2.4;
  letter-spacing: 0.08em;
  width: 100%;
}
.btn-danger::after { border: none; }

/* ========================
   标签胶囊
   ======================== */
.tag {
  display: inline-block;
  padding: 4rpx 14rpx;
  background: rgba(204, 242, 0, 0.15);
  color: var(--primary);
  border-radius: 100rpx;
  font-size: 20rpx;
  font-weight: 800;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

.tag-neutral {
  background: rgba(255, 255, 255, 0.08);
  color: var(--text-muted);
}

.tag-blue {
  background: rgba(59, 130, 246, 0.15);
  color: #60a5fa;
}

/* ========================
   输入框
   ======================== */
.input {
  background: var(--input-bg);
  border: 1px solid var(--divider);
  border-radius: 20rpx;
  color: var(--text-primary);
  font-size: 28rpx;
  padding: 20rpx 28rpx;
  width: 100%;
  box-sizing: border-box;
}

.input:focus {
  border-color: var(--primary);
  outline: none;
}

.input-placeholder {
  color: var(--text-muted);
}

/* ========================
   工具类
   ======================== */
.text-primary { color: var(--primary); }
.text-secondary { color: var(--text-secondary); }
.text-muted { color: var(--text-muted); }
/* 强调色: 文字/边框场景用, day 主题下自动用深橄榄绿 */
.text-accent { color: var(--primary-text); }
.bg-accent { background: var(--primary); color: #000; }
.bg-accent-soft { background: var(--primary-bg-soft); color: var(--primary-text); }
.border-accent { border-color: var(--primary-text); }

.font-lexend { font-family: 'Lexend Deca', 'Lexend', sans-serif; }
.font-bold { font-weight: 700; }
.font-black { font-weight: 900; }

.uppercase { text-transform: uppercase; }
.tracking-widest { letter-spacing: 0.15em; }
.tracking-wide { letter-spacing: 0.08em; }

.ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 通用 glass-card (替代 .card 别名) */
.glass-card {
  background: var(--card-bg);
  border: 1px solid var(--card-border);
  border-radius: 24rpx;
  overflow: hidden;
}
