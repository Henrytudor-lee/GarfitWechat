/* pages/profile/index.wxss — garcia-fitness-new style */
.page {
  min-height: 100vh;
  background: #131313;
  padding: 100rpx 24rpx 200rpx;
}

/* Profile Hero */
.profile-hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0 32rpx;
}

.avatar-wrap {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 4rpx solid rgba(204, 242, 0, 0.3);
  margin-bottom: 20rpx;
  box-shadow: 0 0 30rpx rgba(204, 242, 0, 0.15);
}

.avatar {
  width: 100%;
  height: 100%;
}

.profile-name {
  font-family: 'Lexend Deca', sans-serif;
  font-size: 44rpx;
  font-weight: 900;
  color: #fff;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  margin-bottom: 6rpx;
}

.profile-sub {
  font-size: 20rpx;
  font-weight: 700;
  color: #71717a;
  letter-spacing: 0.12em;
  text-transform: uppercase;
}

/* Login / Register Button (guest state) */
.login-btn {
  margin-top: 8rpx;
  background: #ccf200;
  color: #000;
  border-radius: 100rpx;
  font-family: 'Lexend Deca', sans-serif;
  font-size: 28rpx;
  font-weight: 900;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  border: none;
  padding: 0 48rpx;
  line-height: 2.4;
}
.login-btn::after { border: none; }

/* Stats Row */
.stats-row {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 24rpx;
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-val {
  font-family: 'Lexend Deca', sans-serif;
  font-size: 48rpx;
  font-weight: 900;
  color: #fff;
  line-height: 1;
}

.stat-key {
  font-size: 18rpx;
  font-weight: 800;
  color: #71717a;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  margin-top: 6rpx;
}

.stat-sep {
  width: 1rpx;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.08);
}

/* Level Card */
.level-card {
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid rgba(255, 255, 255, 0.10);
  border-radius: 20rpx;
  padding: 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.level-label {
  font-size: 18rpx;
  font-weight: 800;
  color: #71717a;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  margin-bottom: 6rpx;
}

.level-name {
  font-family: 'Lexend Deca', sans-serif;
  font-size: 32rpx;
  font-weight: 900;
  color: #ccf200;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  margin-bottom: 6rpx;
}

.level-xp {
  font-size: 20rpx;
  font-weight: 600;
  color: #71717a;
  letter-spacing: 0.05em;
}

.level-badge {
  width: 80rpx;
  height: 80rpx;
  background: #ccf200;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.level-num {
  font-family: 'Lexend Deca', sans-serif;
  font-size: 40rpx;
  font-weight: 900;
  color: #000;
  line-height: 1;
}

/* XP Bar */
.xp-bar-wrap {
  margin-bottom: 32rpx;
}

.xp-track {
  height: 8rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 4rpx;
  overflow: hidden;
}

.xp-fill {
  height: 100%;
  background: linear-gradient(90deg, #ccf200, #a0c800);
  border-radius: 4rpx;
  transition: width 0.5s ease;
}

/* Menu List */
.menu-list {
  background: rgba(255, 255, 255, 0.04);
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  gap: 20rpx;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 28rpx;
  color: #ccf200;
  width: 36rpx;
  text-align: center;
}

.menu-text {
  flex: 1;
  font-size: 26rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 0.05em;
  text-transform: uppercase;
}

.menu-arrow {
  font-size: 28rpx;
  color: #52525b;
}

/* Sign Out Button */
.btn-danger {
  background: rgba(239, 68, 68, 0.15);
  color: #ef4444;
  border-radius: 100rpx;
  font-family: 'Lexend Deca', sans-serif;
  font-size: 28rpx;
  font-weight: 900;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  border: 1px solid rgba(239, 68, 68, 0.3);
  line-height: 2.4;
  width: 100%;
}
.btn-danger::after { border: none; }

/* Fire color tiers: 0=gray, 1-7=orange, 8-30=yellow, 31-60=lime, 61-120=green, 121-360=teal, 361+=blue */
.color-neutral-600 { color: #52525b; }
.color-orange { color: #f97316; }
.color-yellow { color: #facc15; }
.color-lime { color: #a3e635; }
.color-green { color: #4ade80; }
.color-teal { color: #2dd4bf; }
.color-blue { color: #60a5fa; }

/* Trophy color tiers by level: 1=gray, 2=orange, 3=yellow, 4=lime, 5=green, 6+=blue */
.color-trophy-rookie { color: #52525b; }
.color-trophy-beginner { color: #f97316; }
.color-trophy-intermediate { color: #facc15; }
.color-trophy-advanced { color: #a3e635; }
.color-trophy-expert { color: #4ade80; }
.color-trophy-elite { color: #60a5fa; }

