/* pages/profile/index.wxss — matching index.wxml classes */
.page {
  min-height: 100vh;
  background: #131313;
  padding: 100rpx 24rpx 200rpx;
}

/* Profile Hero with Avatar */
.profile-hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0 32rpx;
}

.avatar-container {
  position: relative;
  width: 180rpx;
  height: 180rpx;
  margin-bottom: 20rpx;
}

.avatar-glow {
  position: absolute;
  inset: -10rpx;
  background: rgba(204, 242, 0, 0.12);
  border-radius: 50%;
  filter: blur(20rpx);
}

.avatar-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(204, 242, 0, 0.4);
  position: relative;
  z-index: 1;
  background: #1a1a1a;
}

.camera-btn {
  position: absolute;
  bottom: 0rpx;
  right: 0rpx;
  width: 52rpx;
  height: 52rpx;
  background: #ccf200;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  padding: 0;
  z-index: 2;
}

.camera-btn::after { border: none; }
.camera-btn {
  width:30px !important;
}
.camera-icon {
  font-size: 24rpx;
  color: #000;
  font-weight: 900;
}

.profile-name {
  font-family: 'Lexend Deca', sans-serif;
  font-size: 44rpx;
  font-weight: 900;
  color: #fff;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  margin-top: 8rpx;
}

/* Not Logged In State */
.not-logged-in {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
  gap: 24rpx;
}

.not-logged-icon {
  font-size: 80rpx;
  color: #ccf200;
  margin-bottom: 16rpx;
}

.not-logged-title {
  font-family: 'Lexend Deca', sans-serif;
  font-size: 40rpx;
  font-weight: 900;
  color: #fff;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.not-logged-hint {
  font-size: 26rpx;
  color: #71717a;
  text-align: center;
  line-height: 1.5;
}

.login-btn {
  margin-top: 16rpx;
  background: #ccf200;
  color: #000;
  border-radius: 100rpx;
  font-family: 'Lexend Deca', sans-serif;
  font-size: 28rpx;
  font-weight: 900;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  border: none;
  padding: 0 48rpx;
  line-height: 2.4;
}
.login-btn::after { border: none; }

/* Stats Grid (2-column) */
.stats-grid {
  display: flex;
  gap: 20rpx;
  padding: 0 4rpx;
  margin-bottom: 32rpx;
}

.stat-card {
  flex: 1;
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: 24rpx;
  padding: 28rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  position: relative;
  overflow: hidden;
}

.stat-icon {
  font-size: 56rpx;
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  opacity: 0.6;
}

.stat-label {
  font-size: 18rpx;
  font-weight: 800;
  color: #71717a;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  margin-top: 8rpx;
  margin-bottom: 12rpx;
}

.stat-value {
  font-family: 'Lexend Deca', sans-serif;
  font-size: 52rpx;
  font-weight: 900;
  color: #fff;
  line-height: 1;
}

.stat-unit {
  font-size: 24rpx;
  font-weight: 700;
  color: #71717a;
  margin-left: 4rpx;
}

.stat-value-lg {
  font-family: 'Lexend Deca', sans-serif;
  font-size: 36rpx;
  font-weight: 900;
  color: #fff;
  text-transform: uppercase;
  letter-spacing: 0.03em;
  line-height: 1;
  margin-top: 8rpx;
}

.stat-sub {
  font-size: 20rpx;
  font-weight: 700;
  color: #71717a;
  margin-top: 4rpx;
  letter-spacing: 0.05em;
}

/* Settings List */
.settings-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 32rpx;
  padding: 0 4rpx;
}

.settings-item {
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.settings-item.locked {
  opacity: 0.45;
}

.settings-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
  flex: 1;
}

.settings-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.05);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.lang-icon {
  background: rgba(59, 130, 246, 0.15);
}

.theme-icon {
  background: rgba(255, 255, 255, 0.05);
}

.lock-icon {
  background: rgba(255, 255, 255, 0.05);
}

.settings-icon-text {
  font-size: 22rpx;
  font-weight: 900;
  color: #fff;
  letter-spacing: 0.02em;
}

.settings-texts {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.settings-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 0.04em;
  text-transform: uppercase;
}

.settings-title.locked-text {
  color: #71717a;
  text-decoration: line-through;
  text-decoration-style: dotted;
}

.settings-subtitle {
  font-size: 20rpx;
  font-weight: 600;
  color: #71717a;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

.settings-subtitle.locked-text {
  color: #52525b;
}

/* Toggle Pills */
.toggle-pills {
  display: flex;
  background: rgba(0, 0, 0, 0.4);
  border-radius: 100rpx;
  padding: 6rpx;
  border: 1px solid rgba(255, 255, 255, 0.06);
  flex-shrink: 0;
}

.pill {
  font-size: 20rpx;
  font-weight: 900;
  letter-spacing: 0.05em;
  padding: 10rpx 20rpx;
  border-radius: 100rpx;
  color: #52525b;
  transition: all 0.2s ease;
}

.pill.pill-active {
  background: #ccf200;
  color: #000;
}

.pill.pill-active.dark {
  background: #3f3f46;
  color: #fff;
}

.pill.pill-active.light {
  background: #facc15;
  color: #000;
}

.pill.zh {
  /* nothing extra */
}

/* Lock icon right */
.lock-icon-right {
  font-size: 32rpx;
  color: #3f3f46;
  flex-shrink: 0;
}

/* Chevron */
.chevron {
  font-size: 36rpx;
  color: #3f3f46;
  flex-shrink: 0;
}

/* Logout Button */
.logout-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  background: rgba(239, 68, 68, 0.12);
  border: 1px solid rgba(239, 68, 68, 0.2);
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  margin: 0 4rpx 32rpx;
  width: calc(100% - 8rpx);
}

.logout-btn::after { border: none; }

.logout-icon {
  font-size: 32rpx;
  color: #ef4444;
}

.logout-text {
  font-family: 'Lexend Deca', sans-serif;
  font-size: 28rpx;
  font-weight: 900;
  color: #ef4444;
  letter-spacing: 0.1em;
  text-transform: uppercase;
}

/* Version */
.version-text {
  text-align: center;
  font-size: 18rpx;
  font-weight: 900;
  color: #3f3f46;
  letter-spacing: 0.25em;
  text-transform: uppercase;
  padding-top: 16rpx;
}

/* Fire/Trophy color tiers */
.color-neutral-600 { color: #52525b; }
.color-orange { color: #f97316; }
.color-yellow { color: #facc15; }
.color-lime { color: #a3e635; }
.color-green { color: #4ade80; }
.color-teal { color: #2dd4bf; }
.color-blue { color: #60a5fa; }
