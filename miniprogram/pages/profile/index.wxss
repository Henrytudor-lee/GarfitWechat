/* pages/profile/index.wxss — garcia-fitness-new style
   主题方案：使用 .theme-night / .theme-day 显式选择器，完全避免 CSS var() 继承问题
   所有颜色均为硬编码值，不依赖任何 CSS 变量
*/

/* ========================
   页面基础
   ======================== */
.page {
  min-height: 100vh;
  background: #131313;
  padding: 100rpx 24rpx 200rpx;
}

/* ========================
   日间主题 — 显式选择器
   ======================== */
.page.theme-day {
  background: #f5f5f5;
}

/* ========================
   夜间主题 — 显式选择器
   ======================== */
.page.theme-night {
  background: #131313;
}

/* ========================
   通用样式（两个主题一致）
   ======================== */
.profile-hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0 32rpx;
}

.avatar-container {
  position: relative;
  width: 180rpx;
  height: 180rpx;
  margin-bottom: 20rpx;
}

.avatar-glow {
  position: absolute;
  inset: -10rpx;
  background: rgba(204, 242, 0, 0.12);
  border-radius: 50%;
  filter: blur(20rpx);
}

.avatar-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(204, 242, 0, 0.4);
  position: relative;
  z-index: 1;
}

/* 头像 — 日间 */
.page.theme-day .avatar-img {
  background: #ffffff;
}
/* 头像 — 夜间 */
.page.theme-night .avatar-img {
  background: #1c1c1c;
}

.camera-btn {
  position: absolute;
  bottom: 0rpx;
  right: 0rpx;
  width: 52rpx;
  height: 52rpx;
  background: #ccf200;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  padding: 0;
  z-index: 2;
}

.camera-btn::after { border: none; }
.camera-btn {
  width:30px !important;
}
.camera-icon {
  font-size: 24rpx;
  color: #000;
  font-weight: 900;
}

/* 用户名 */
.profile-name {
  font-family: 'Lexend Deca', sans-serif;
  font-size: 44rpx;
  font-weight: 900;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  margin-top: 8rpx;
}
.page.theme-day .profile-name { color: #1a1a1a; }
.page.theme-night .profile-name { color: #ffffff; }

/* 未登录状态 */
.not-logged-in {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
  gap: 24rpx;
}

.not-logged-icon {
  font-size: 80rpx;
  color: #ccf200;
  margin-bottom: 16rpx;
}

.not-logged-title {
  font-family: 'Lexend Deca', sans-serif;
  font-size: 40rpx;
  font-weight: 900;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}
.page.theme-day .not-logged-title { color: #1a1a1a; }
.page.theme-night .not-logged-title { color: #ffffff; }

.not-logged-hint {
  font-size: 26rpx;
  text-align: center;
  line-height: 1.5;
}
.page.theme-day .not-logged-hint { color: #a1a1aa; }
.page.theme-night .not-logged-hint { color: #71717a; }

.login-btn {
  margin-top: 16rpx;
  background: #ccf200;
  color: #000;
  border-radius: 100rpx;
  font-family: 'Lexend Deca', sans-serif;
  font-size: 28rpx;
  font-weight: 900;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  border: none;
  padding: 0 48rpx;
  line-height: 2.4;
}
.login-btn::after { border: none; }

/* Stats Grid (2-column) */
.stats-grid {
  display: flex;
  gap: 20rpx;
  padding: 0 4rpx;
  margin-bottom: 32rpx;
}

/* 统计卡片 */
.stat-card {
  flex: 1;
  border-radius: 24rpx;
  padding: 28rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  position: relative;
  overflow: hidden;
}
.page.theme-day .stat-card {
  background: rgba(0, 0, 0, 0.05);
  border: 1px solid rgba(0, 0, 0, 0.10);
}
.page.theme-night .stat-card {
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid rgba(255, 255, 255, 0.08);
}

.stat-icon {
  font-size: 56rpx;
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  opacity: 0.6;

  width: 32px;
  height: 32px;
}

.stat-label {
  font-size: 18rpx;
  font-weight: 800;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  margin-top: 8rpx;
  margin-bottom: 12rpx;
}
.page.theme-day .stat-label { color: #a1a1aa; }
.page.theme-night .stat-label { color: #71717a; }

.stat-value {
  font-family: 'Lexend Deca', sans-serif;
  font-size: 52rpx;
  font-weight: 900;
  line-height: 1;
}
.page.theme-day .stat-value { color: #1a1a1a; }
.page.theme-night .stat-value { color: #ffffff; }

.stat-unit {
  font-size: 24rpx;
  font-weight: 700;
  margin-left: 4rpx;
}
.page.theme-day .stat-unit { color: #a1a1aa; }
.page.theme-night .stat-unit { color: #71717a; }

.stat-value-lg {
  font-family: 'Lexend Deca', sans-serif;
  font-size: 36rpx;
  font-weight: 900;
  text-transform: uppercase;
  letter-spacing: 0.03em;
  line-height: 1;
  margin-top: 8rpx;
}
.page.theme-day .stat-value-lg { color: #1a1a1a; }
.page.theme-night .stat-value-lg { color: #ffffff; }

.stat-sub {
  font-size: 20rpx;
  font-weight: 700;
  margin-top: 4rpx;
  letter-spacing: 0.05em;
}
.page.theme-day .stat-sub { color: #a1a1aa; }
.page.theme-night .stat-sub { color: #71717a; }

/* Settings List */
.settings-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 32rpx;
  padding: 0 4rpx;
}

/* 设置项 */
.settings-item {
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}
.page.theme-day .settings-item {
  background: rgba(0, 0, 0, 0.05);
  border: 1px solid rgba(0, 0, 0, 0.10);
}
.page.theme-night .settings-item {
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid rgba(255, 255, 255, 0.08);
}

.settings-item.locked {
  opacity: 0.45;
}

.settings-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
  flex: 1;
}

/* 设置图标容器 */
.settings-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.settings-lang-icon {
  width: 32px;
  height: 32px;
}

.settings-edit-icon {
  width: 20px;
  height: 20px;
}
.page.theme-day .settings-icon-wrap { background: rgba(0, 0, 0, 0.05); }
.page.theme-night .settings-icon-wrap { background: rgba(255, 255, 255, 0.05); }

.lang-icon {
  background: rgba(59, 130, 246, 0.15);
}

.theme-icon {}
.lock-icon {}

/* 设置图标文字 */
.settings-icon-text {
  font-size: 26px;
  font-weight: 900;
  letter-spacing: 0.02em;
}
.page.theme-day .settings-icon-text { color: #1a1a1a; }
.page.theme-night .settings-icon-text { color: #ffffff; }

/* 设置文本区 */
.settings-texts {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

/* 设置标题 */
.settings-title {
  font-size: 28rpx;
  font-weight: 700;
  letter-spacing: 0.04em;
  text-transform: uppercase;
}
.page.theme-day .settings-title { color: #1a1a1a; }
.page.theme-night .settings-title { color: #ffffff; }

.settings-title.locked-text {
  text-decoration: line-through;
  text-decoration-style: dotted;
}
.page.theme-day .settings-title.locked-text { color: #a1a1aa; }
.page.theme-night .settings-title.locked-text { color: #71717a; }

/* 设置副标题 */
.settings-subtitle {
  font-size: 20rpx;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}
.page.theme-day .settings-subtitle { color: #a1a1aa; }
.page.theme-night .settings-subtitle { color: #71717a; }

.settings-subtitle.locked-text {}
.page.theme-day .settings-subtitle.locked-text { color: #a1a1aa; }
.page.theme-night .settings-subtitle.locked-text { color: #52525b; }

/* Toggle Pills — 胶囊切换器 */
.toggle-pills {
  display: flex;
  border-radius: 100rpx;
  padding: 6rpx;
  flex-shrink: 0;
}
.page.theme-day .toggle-pills {
  background: #e0e0e0;
  border: 1px solid rgba(0, 0, 0, 0.10);
}
.page.theme-night .toggle-pills {
  background: #262626;
  border: 1px solid rgba(255, 255, 255, 0.06);
}

/* 胶囊 — 默认未选中 */
.pill {
  font-size: 20rpx;
  font-weight: 900;
  letter-spacing: 0.05em;
  padding: 10rpx 20rpx;
  border-radius: 100rpx;
  transition: all 0.2s ease;
}
.page.theme-day .pill { color: #a1a1aa; }
.page.theme-night .pill { color: #52525b; }

/* 胶囊 — 选中默认（基础亮色=日间主色） */
.pill.pill-active {
  background: #ccf200;
  color: #000;
}

/* 胶囊 — Night/Dark 主题选中态：深灰背景+白色文字 */
.page.theme-night .pill.pill-active.night,
.page.theme-night .pill.pill-active.dark {
  background: #262626;
  color: #ffffff !important;
}

/* 胶囊 — Day/Light 主题选中态：品牌黄 */
.pill.pill-active.day,
.pill.pill-active.light {
  background: #ccf200;
  color: #000;
}

.pill.zh {
  /* nothing extra */
}

/* 锁图标右侧 */
.lock-icon-right {
  font-size: 32rpx;
  flex-shrink: 0;
}
.page.theme-day .lock-icon-right { color: #a1a1aa; }
.page.theme-night .lock-icon-right { color: #3f3f46; }

/* Chevron */
.chevron {
  font-size: 36rpx;
  flex-shrink: 0;
}
.page.theme-day .chevron { color: #a1a1aa; }
.page.theme-night .chevron { color: #3f3f46; }

/* 退出按钮 */
.logout-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  margin: 0 4rpx 32rpx;
  width: calc(100% - 8rpx);
}
.page.theme-day .logout-btn {
  background: rgba(239, 68, 68, 0.10);
  border: 1px solid rgba(239, 68, 68, 0.20);
}
.page.theme-night .logout-btn {
  background: rgba(239, 68, 68, 0.12);
  border: 1px solid rgba(239, 68, 68, 0.20);
}

.logout-btn::after { border: none; }

.logout-icon {
  font-size: 32rpx;
  color: #ef4444;
}

.logout-text {
  font-family: 'Lexend Deca', sans-serif;
  font-size: 28rpx;
  font-weight: 900;
  color: #ef4444;
  letter-spacing: 0.1em;
  text-transform: uppercase;
}

/* 版本号 */
.version-text {
  text-align: center;
  font-size: 18rpx;
  font-weight: 900;
  letter-spacing: 0.25em;
  text-transform: uppercase;
  padding-top: 16rpx;
}
.page.theme-day .version-text { color: #a1a1aa; }
.page.theme-night .version-text { color: #3f3f46; }

.settings-lock-icon { width: 24rpx; height: 24rpx;}

/* 火焰/奖杯颜色分层 — 独立于主题 */
.color-neutral-600 { color: #52525b; }
.color-orange { color: #f97316; }
.color-yellow { color: #facc15; }
.color-lime { color: #a3e635; }
.color-green { color: #4ade80; }
.color-teal { color: #2dd4bf; }
.color-blue { color: #60a5fa; }

/* ========================
   昵称编辑按钮
   ======================== */
.profile-name-wrap {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 8rpx;
}

.edit-name-btn {
  font-size: 36rpx;
  color: #ccf200;
  padding: 8rpx;
  line-height: 1;
}

/* ========================
   昵称编辑弹窗
   ======================== */
.edit-modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.edit-modal-box {
  width: 600rpx;
  border-radius: 24rpx;
  padding: 40rpx 32rpx 32rpx;
}
.page.theme-day .edit-modal-box {
  background: #ffffff;
}
.page.theme-night .edit-modal-box {
  background: #262626;
  border: 1px solid rgba(255, 255, 255, 0.1);
}

.edit-modal-title {
  font-family: 'Lexend Deca', sans-serif;
  font-size: 32rpx;
  font-weight: 900;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  text-align: center;
  margin-bottom: 32rpx;
}
.page.theme-day .edit-modal-title { color: #1a1a1a; }
.page.theme-night .edit-modal-title { color: #ffffff; }

.edit-modal-input {
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  margin-bottom: 32rpx;
}
.page.theme-day .edit-modal-input {
  background: rgba(0, 0, 0, 0.05);
  border: 1px solid rgba(0, 0, 0, 0.1);
  color: #1a1a1a;
}
.page.theme-night .edit-modal-input {
  background: rgba(255, 255, 255, 0.08);
  border: 1px solid rgba(255, 255, 255, 0.12);
  color: #ffffff;
}

.edit-modal-btns {
  display: flex;
  gap: 16rpx;
}

.edit-modal-cancel,
.edit-modal-confirm {
  flex: 1;
  border-radius: 16rpx;
  padding: 20rpx;
  font-family: 'Lexend Deca', sans-serif;
  font-size: 26rpx;
  font-weight: 900;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  border: none;
}
.edit-modal-cancel::after,
.edit-modal-confirm::after { border: none; }

.edit-modal-cancel {
  background: rgba(255, 255, 255, 0.08);
}
.page.theme-day .edit-modal-cancel { color: #71717a; background: rgba(0, 0, 0, 0.06); }
.page.theme-night .edit-modal-cancel { color: #a1a1aa; }

.edit-modal-confirm {
  background: #ccf200;
  color: #000;
}
