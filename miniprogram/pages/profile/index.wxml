<!--pages/profile/index.wxml—garcia-fitness-new style-->
<view class="page">

  <!-- Top App Bar -->
  <appbar />

  <!-- Profile Hero -->
  <view class="profile-hero">
    <view class="avatar-wrap">
      <image class="avatar" src="{{userInfo.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill"/>
    </view>
    <view class="profile-name">{{userInfo.nickname || 'ATHLETE'}}</view>
    <view class="profile-sub">MEMBER SINCE {{memberSince || '—'}}</view>
  </view>

  <!-- Quick Stats -->
  <view class="stats-row">
    <view class="stat-item">
      <view class="stat-val">{{stats.totalWorkouts || 0}}</view>
      <view class="stat-key">SESSIONS</view>
    </view>
    <view class="stat-sep"></view>
    <view class="stat-item">
      <view class="stat-val">{{stats.currentStreak || 0}}</view>
      <view class="stat-key">STREAK</view>
    </view>
    <view class="stat-sep"></view>
    <view class="stat-item">
      <view class="stat-val">{{stats.totalVolume || 0}}</view>
      <view class="stat-key">TOTAL KG</view>
    </view>
  </view>

  <!-- Level Card -->
  <view class="level-card">
    <view class="level-left">
      <view class="level-label">CURRENT LEVEL</view>
      <view class="level-name">{{levelInfo.name || 'BEGINNER'}}</view>
      <view class="level-xp">{{levelInfo.currentXp || 0}} / {{levelInfo.nextXp || 100}} XP</view>
    </view>
    <view class="level-badge">
      <text class="level-num">{{levelInfo.level || 1}}</text>
    </view>
  </view>

  <!-- XP Bar -->
  <view class="xp-bar-wrap">
    <view class="xp-track">
      <view class="xp-fill" style="width: {{xpPercent || 0}}%"></view>
    </view>
  </view>

  <!-- Menu List -->
  <view class="menu-list">
    <view class="menu-item" bindtap="goToFavorites">
      <text class="menu-icon">♥</text>
      <text class="menu-text">FAVORITES</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goToHistory">
      <text class="menu-icon">☰</text>
      <text class="menu-text">HISTORY</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="onShareTap">
      <text class="menu-icon">↗</text>
      <text class="menu-text">SHARE APP</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="onAboutTap">
      <text class="menu-icon">ⓘ</text>
      <text class="menu-text">ABOUT</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <!-- Sign Out -->
  <button class="btn-danger" bindtap="onSignOut">SIGN OUT</button>

  <!-- Custom Tab Bar -->
  <custom-tabbar active="profile" />

</view>
