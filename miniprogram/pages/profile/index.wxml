<!--pages/profile/index.wxml—garcia-fitness-new style-->
<view class="page {{theme === 'day' ? 'theme-day' : 'theme-night'}}">

  <!-- Profile Hero with Avatar -->
  <view class="profile-hero" wx:if="{{isLoggedIn}}">
    <!-- Avatar + Camera Button -->
    <view class="avatar-container">
      <view class="avatar-glow"></view>
      <image class="avatar-img" src="{{userInfo.avatarUrl || '/images/avatar.png'}}" mode="aspectFill"/>
      <button class="camera-btn" bindtap="changeAvatar">
        <text class="camera-icon">✦</text>
      </button>
    </view>
    <!-- Nickname -->
    <view class="profile-name-wrap">
      <view class="profile-name">{{userInfo.nickname || '微信用户'}}</view>
      <image class="settings-edit-icon" bindtap="onEditName" src="{{imgPrefix}}/icons/icon-edit.png" mode="aspectFit" />
    </view>
  </view>

  <!-- Edit Nickname Modal -->
  <view class="edit-modal-mask" wx:if="{{showEditNameModal}}" bindtap="cancelEditName">
    <view class="edit-modal-box" catchtap="noop">
      <view class="edit-modal-title">{{locale === 'en' ? 'EDIT NICKNAME' : '编辑昵称'}}</view>
      <input class="edit-modal-input" value="{{editNameValue}}" placeholder="{{locale === 'en' ? 'Nickname' : '昵称'}}" maxlength="16" bindinput="onEditNameInput" />
      <view class="edit-modal-btns">
        <button class="edit-modal-cancel" bindtap="cancelEditName">{{locale === 'en' ? 'CANCEL' : '取消'}}</button>
        <button class="edit-modal-confirm" bindtap="confirmEditName">{{locale === 'en' ? 'CONFIRM' : '确认'}}</button>
      </view>
    </view>
  </view>

  <!-- Not Logged In State -->
  <view class="not-logged-in" wx:if="{{!isLoggedIn}}">
    <view class="not-logged-icon">✦</view>
    <view class="not-logged-title">{{locale === 'en' ? 'NOT LOGGED IN' : '未登录'}}</view>
    <view class="not-logged-hint">{{locale === 'en' ? 'Sign in to track your fitness journey' : '登录以开始健身之旅'}}</view>
    <button class="login-btn" bindtap="goToLogin">{{locale === 'en' ? 'LOGIN / REGISTER' : '登录 / 注册'}}</button>
  </view>

  <!-- Logged In Content -->
  <block wx:if="{{isLoggedIn}}">
    <!-- Streak + Level Cards -->
    <view class="stats-grid">
      <!-- Streak Card -->
      <view class="stat-card">
        <image class="stat-icon" src="{{imgPrefix}}/icons/icon-sign.png" mode="aspectFit" />
        <view class="stat-label">{{locale === 'en' ? 'ACTIVE STREAK' : '连续训练'}}</view>
        <view class="stat-value">{{streak || 0}}<text class="stat-unit">{{locale === 'en' ? ' days' : ' 天'}}</text></view>
      </view>
      <!-- Level Card -->
      <view class="stat-card">
        <image class="stat-icon" src="{{imgPrefix}}/icons/icon-crawn.png" mode="aspectFit" />
        <view class="stat-label">{{locale === 'en' ? 'LEVEL' : '等级'}}{{levelInfo.lv || 1}}</view>
        <view class="stat-value-lg">{{locale === 'en' ? levelInfo.label : (levelInfo.label_zh || levelInfo.label)}}</view>
      </view>
    </view>

    <!-- Settings List -->
    <view class="settings-list">
      <!-- Language Toggle -->
      <view class="settings-item" bindtap="toggleLanguage">
        <view class="settings-left">
          <view class="settings-icon-wrap lang-icon">
            <image class="settings-lang-icon" src="{{imgPrefix}}/icons/icon-lang.png" mode="aspectFit" />
          </view>
          <view class="settings-texts">
            <text class="settings-title">{{locale === 'en' ? 'LANGUAGE' : '语言'}}</text>
            <text class="settings-subtitle">{{locale === 'en' ? 'English (US)' : '中文'}}</text>
          </view>
        </view>
        <view class="toggle-pills">
          <text class="pill {{locale === 'en' ? 'pill-active' : ''}}">EN</text>
          <text class="pill {{locale === 'zh' ? 'pill-active zh' : ''}}">CN</text>
        </view>
      </view>

      <!-- Theme Toggle -->
      <view class="settings-item" bindtap="toggleTheme">
        <view class="settings-left">
          <view class="settings-icon-wrap theme-icon">
            <text class="settings-icon-text">{{theme === 'day' ? '◐' : '◑'}}</text>
          </view>
          <view class="settings-texts">
            <text class="settings-title">{{locale === 'en' ? 'THEME' : '主题'}}</text>
            <text class="settings-subtitle">{{theme === 'day' ? (locale === 'en' ? 'Day' : '日间') : (locale === 'en' ? 'Night' : '夜间')}}</text>
          </view>
        </view>
        <view class="toggle-pills">
          <text class="pill {{theme === 'day' ? 'pill-active day' : ''}}">{{locale === 'en' ? 'Day' : '日间'}}</text>
          <text class="pill {{theme === 'night' ? 'pill-active' : ''}}">{{locale === 'en' ? 'Night' : '夜间'}}</text>
        </view>
      </view>

      <!-- AI Coach (locked) -->
      <view class="settings-item locked">
        <view class="settings-left">
          <view class="settings-icon-wrap lock-icon">
            <text class="settings-icon-text">⚙</text>
          </view>
          <view class="settings-texts">
            <text class="settings-title locked-text">{{locale === 'en' ? 'AI COACH' : 'AI 教练'}}</text>
            <text class="settings-subtitle locked-text">{{locale === 'en' ? 'COMING SOON' : '即将推出'}}</text>
          </view>
        </view>
        <image class="settings-lock-icon" src="{{imgPrefix}}/icons/icon-lock.png" mode="aspectFit" />
      </view>
    </view>


    <!-- Version -->
    <view class="version-text">{{locale === 'en' ? 'GARCIA FITNESS V1.0.6 - STABLE' : 'GARCIA FITNESS V1.0.6 - 稳定版'}}</view>
  </block>

  <!-- Custom Tab Bar -->
  <custom-tabbar active="profile" theme="{{theme}}" />

</view>
