<!--pages/index/index.wxml—garcia-fitness-new style with bento stats, date picker, rest timer-->
<view class="page {{theme === 'day' ? 'theme-day' : 'theme-night'}}">

  <!-- Top App Bar -->
  <appbar theme="{{theme}}" />

  <!-- Hero Timer Card -->
  <view class="timer-card">
    <view class="timer-label">{{t.DURATION}}</view>
    <view class="timer-display">{{elapsedTime}}</view>
    <view class="timer-stats-row">
      <view class="timer-stat">
        <view class="stat-val">{{totalVolume}}</view>
        <view class="stat-key">{{t.VOLUME_KG}}</view>
      </view>
      <view class="stat-divider"></view>
      <view class="timer-stat">
        <view class="stat-val">{{exerciseCount}}</view>
        <view class="stat-key">{{t.EXERCISES}}</view>
      </view>
      <view class="stat-divider"></view>
      <view class="timer-stat">
        <view class="stat-val text-primary">{{restTime}}</view>
        <view class="stat-key">{{t.REST}}</view>
      </view>
    </view>
  </view>

  <!-- Quick Start / End Training -->
  <button class="start-btn {{runningSession ? 'stop' : 'start'}}" bindtap="{{runningSession ? 'requestStopWorkout' : 'startWorkout'}}">
    {{runningSession ? t.END_TRAINING : t.QUICK_START}}
  </button>

  <!-- Floating FAB - Add Exercise -->
  <view class="fab" wx:if="{{runningSession}}" bindtap="openAddModal">
    <text class="fab-icon">+</text>
  </view>

  <!-- Current Workout -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">{{t.CURRENT_WORKOUT}}</text>
      <text class="section-badge {{runningSession ? 'active' : ''}}">{{runningSession ? t.IN_PROGRESS : t.READY}}</text>
    </view>

    <view wx:if="{{exerciseGroups.length > 0}}" class="exercise-list">
      <view class="exercise-card" wx:for="{{exerciseGroups}}" wx:key="exercise_id" data-item="{{item}}" bindtap="onExerciseTap">
        <!-- Header: image + name/sets + volume -->
        <view class="ec-header">
          <view class="ec-img-wrap">
            <image wx:if="{{item.image_name}}" class="ec-img" src="{{imgPrefix}}/{{item.image_name}}" mode="aspectFill" />
            <view wx:else class="ec-img-placeholder">🏋️</view>
          </view>
          <view class="ec-info">
            <view class="ec-name">{{locale === 'en' ? item.name_en : item.name_zh}}</view>
            <view class="ec-sets-count">{{item.sets.length}} {{item.sets.length === 1 ? 'set' : 'sets'}}</view>
          </view>
          <view class="ec-volume">
            <view class="ec-vol-num">{{item.totalVolume}} kg</view>
            <view class="ec-vol-label">TOTAL VOLUME</view>
          </view>
        </view>
        <!-- Sets grid: 2 columns -->
        <view class="ec-sets-grid">
          <view class="ec-set-item" wx:for="{{item.sets}}" wx:for-item="s" wx:key="idx">
            <view class="ec-set-num">{{index + 1}}</view>
            <view class="ec-set-val">{{s.weight}} <text class="ec-set-unit">{{s.weight_unit}}</text></view>
            <view class="ec-set-sep">×</view>
            <view class="ec-set-val reps">{{s.reps}} <text class="ec-set-unit">reps</text></view>
          </view>
        </view>
      </view>
    </view>

    <view wx:elif="{{runningSession}}" class="empty-card" bindtap="goToLibrary">
      <text class="empty-hint">{{t.TAP_PLUS_TO_ADD_EXERCISES}}</text>
    </view>

    <view wx:else class="empty-card">
      <text class="empty-hint">{{t.START_TRAINING_TO_ADD_EXERCISES}}</text>
    </view>
  </view>
  <view class="section">
    <view class="section-header">
      <text class="section-title">{{t.FITNESS_CALENDAR}}</text>
    </view>
    <!-- Calendar Mini -->
    <view class="calendar-card">
      <view class="cal-header">
        <text class="cal-nav" bindtap="_prevMonth">‹</text>
        <text class="cal-month-label">{{locale === 'en' ? calMonthLabelEN : calMonthLabelZH}}</text>
        <text class="cal-nav" bindtap="_nextMonth">›</text>
      </view>
      <view class="cal-weekdays">
        <text wx:for="{{weekdays}}" wx:key="*this">{{item}}</text>
      </view>
      <view class="cal-days">
        <text wx:for="{{calendarDays}}" wx:key="dateStr" class="{{item.worked ? 'day-worked' : ''}} {{item.today ? 'day-today' : ''}}" bindtap="onDayTap" data-day="{{item}}">{{item.day}}</text>
      </view>
    </view>
  </view>

  <!-- History Bento Section -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">{{t.HISTORY}}</text>
      <view class="date-picker-btn" bindtap="openDatePicker">{{displayDate}}</view>
    </view>

    <!-- Sessions for selected date -->
    <view wx:if="{{historySessions.length > 0}}" class="history-session-list">
      <view class="history-session-item" wx:for="{{historySessions}}" wx:key="id" data-session="{{item}}" bindtap="onHistorySessionTap">
        <view class="history-session-time">{{item.timeStr}}</view>
        <view class="history-session-info">
          <text class="history-session-stat">{{item.durationStr}}</text>
          <text class="history-session-stat">{{item.exerciseCount || 0}} {{t.EXERCISES}}</text>
        </view>
      </view>
    </view>

    <!-- Bento Grid (shown when no sessions for selected date) -->
    <view wx:else class="bento-grid">
      <view class="bento-card bento-today">
        <view class="bento-label">{{t.TODAY}}</view>
        <view class="bento-day">{{todayDay}}</view>
        <view class="bento-month text-primary">{{todayMonth}}</view>
        <view class="bento-progress-bar">
          <view class="bento-progress-fill" style="width: {{todayProgress}}%"></view>
        </view>
      </view>
      <view class="bento-card bento-yesterday">
        <view class="bento-label">{{t.YESTERDAY}}</view>
        <view class="bento-day">{{yesterdayDay}}</view>
        <view class="bento-month text-muted">{{yesterdayMonth}}</view>
        <view class="bento-progress-bar">
          <view class="bento-progress-fill muted" style="width: 0%"></view>
        </view>
      </view>
      <view class="bento-card bento-monthly">
        <view class="bento-label">{{t.MONTHLY_VOL}}</view>
        <view class="bento-big-num text-primary">0 KG</view>
        <view class="bento-hint text-primary">{{t.START_TRACKING}}</view>
        <view class="bento-bg-icon">📊</view>
      </view>
    </view>
  </view>

  <!-- Custom Date Picker Modal -->
  <view class="picker-overlay {{showDatePicker ? 'show' : ''}}" bindtap="closeDatePicker">
    <view class="picker-modal" catchtap="">
      <!-- Month navigation -->
      <view class="picker-header">
        <view class="picker-nav" bindtap="prevMonth">
          <text class="picker-nav-arrow">‹</text>
        </view>
        <view class="picker-month-label">{{pickerYearLabel}}</view>
        <view class="picker-nav" bindtap="nextMonth">
          <text class="picker-nav-arrow">›</text>
        </view>
      </view>
      <!-- Day headers -->
      <view class="picker-day-headers">
        <text class="picker-day-h" wx:for="{{dayNames}}" wx:key="index">{{item}}</text>
      </view>
      <!-- Days grid -->
      <view class="picker-days-grid">
        <view wx:for="{{calendarDays}}" wx:key="index" class="picker-day-cell {{item.empty ? 'empty' : ''}} {{item.isSelected ? 'selected' : ''}} {{item.isToday ? 'today' : ''}}" bindtap="selectDay" data-day="{{item.day}}">{{item.day}}</view>
      </view>
      <!-- Today shortcut -->
      <view class="picker-today-btn" bindtap="goToToday">{{t.TODAY}}</view>
    </view>
  </view>

  <!-- Add Exercise Modal -->
  <add-exercise-modal isOpen="{{showAddModal}}" sessionId="{{currentSessionId}}" bind:close="onAddModalClose" bind:exerciseadded="onAddModalExerciseAdded" />

  <!-- Edit Exercise Modal -->
  <edit-exercise-modal isOpen="{{showEditModal}}" group="{{editingGroup}}" sessionId="{{currentSessionId}}" locale="{{locale}}" bind:close="onEditModalClose" bind:saved="onEditModalSaved" />

  <!-- Session Detail Modal -->
  <session-detail-modal isOpen="{{showSessionDetailModal}}" session="{{viewingSession}}" sessionId="{{viewingSessionId}}" locale="{{locale}}" bind:close="onSessionDetailClose" />

  <!-- Workout Summary Modal -->
  <workout-summary-modal isOpen="{{showWorkoutSummary}}" session="{{workoutSummarySession}}" exerciseList="{{workoutSummaryExercises}}" locale="{{locale}}" bind:close="onWorkoutSummaryClose" />

  <!-- Custom End Confirm Modal -->
  <custom-end-confirm-modal isOpen="{{showEndConfirm}}" locale="{{locale}}" theme="{{theme}}" bind:confirm="stopWorkout" bind:cancel="onEndConfirmCancel" />

  <!-- Welcome Modal -->
  <welcome-modal isOpen="{{showWelcome}}" bind:close="onWelcomeClose" />

  <!-- Session Orb (悬浮圆球, 显示 running session 状态) -->
  <session-orb session="{{runningSession}}" theme="{{theme}}" bind:tap="onOrbTap" />

  <!-- Custom Tab Bar -->
  <custom-tabbar active="training" theme="{{theme}}" />

</view>