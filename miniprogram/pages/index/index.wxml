<!--pages/index/index.wxml—garcia-fitness-new style-->
<view class="page">

  <!-- Top App Bar -->
  <appbar />

  <!-- Hero Timer Card -->
  <view class="timer-card">
    <view class="timer-label">DURATION</view>
    <view class="timer-display">{{elapsedTime}}</view>
    <view class="timer-stats-row">
      <view class="timer-stat">
        <view class="stat-val">{{totalVolume}}</view>
        <view class="stat-key">VOLUME (KG)</view>
      </view>
      <view class="stat-divider"></view>
      <view class="timer-stat">
        <view class="stat-val">{{exerciseCount}}</view>
        <view class="stat-key">EXERCISES</view>
      </view>
      <view class="stat-divider"></view>
      <view class="timer-stat">
        <view class="stat-val text-primary">{{restTime}}</view>
        <view class="stat-key">REST</view>
      </view>
    </view>
  </view>

  <!-- Quick Start / End Training -->
  <button
    class="start-btn {{runningSession ? 'stop' : 'start'}}"
    bindtap="{{runningSession ? 'stopWorkout' : 'startWorkout'}}"
  >
    {{runningSession ? 'END TRAINING' : 'QUICK START'}}
  </button>

  <!-- Floating FAB - Add Exercise -->
  <view class="fab" wx:if="{{runningSession}}" bindtap="goToLibrary">
    <text class="fab-icon">+</text>
  </view>

  <!-- Current Workout -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">CURRENT WORKOUT</text>
      <text class="section-badge {{runningSession ? 'active' : ''}}">{{runningSession ? 'IN PROGRESS' : 'READY'}}</text>
    </view>

    <view wx:if="{{exerciseGroups.length > 0}}" class="exercise-list">
      <view
        class="exercise-card"
        wx:for="{{exerciseGroups}}"
        wx:key="exercise_id"
        data-item="{{item}}"
        bindtap="onExerciseTap"
      >
        <view class="exercise-img-wrap">
          <image
            wx:if="{{item.image_name}}"
            class="exercise-img"
            src="{{imgPrefix}}/{{item.image_name}}"
            mode="aspectFill"
          />
          <view wx:else class="exercise-img-placeholder">💪</view>
        </view>
        <view class="exercise-content">
          <view class="exercise-name">{{item.name_zh || item.name}}</view>
          <view class="exercise-en">{{item.name}}</view>
          <view class="sets-tags">
            <text wx:for="{{item.sets}}" wx:for-item="s" wx:key="idx" class="set-tag">{{s.weight}}kg × {{s.reps}}</text>
          </view>
        </view>
      </view>
    </view>

    <view wx:elif="{{runningSession}}" class="empty-card" bindtap="goToLibrary">
      <text class="empty-hint">TAP + TO ADD EXERCISES</text>
    </view>

    <view wx:else class="empty-card">
      <text class="empty-hint">START TRAINING TO ADD EXERCISES</text>
    </view>
  </view>

  <!-- Recent Sessions -->
  <view class="section" wx:if="{{recentSessions.length > 0}}">
    <view class="section-header">
      <text class="section-title">RECENT</text>
      <text class="section-link" bindtap="goToHistory">VIEW ALL</text>
    </view>
    <view class="recent-list">
      <view class="recent-item" wx:for="{{recentSessions}}" wx:key="_id">
        <view class="recent-date">{{item.dateStr}}</view>
        <view class="recent-info">
          <text class="recent-stat">{{item.durationStr}}</text>
          <text class="recent-stat">{{item.exerciseCount || 0}} EXERCISES</text>
        </view>
      </view>
    </view>
  </view>

  <!-- Custom Tab Bar -->
  <custom-tabbar active="training" />

</view>
