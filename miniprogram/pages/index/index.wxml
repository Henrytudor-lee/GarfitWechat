<!--pages/index/index.wxml—garcia-fitness-new style with bento stats, date picker, rest timer-->
<view class="page {{theme === 'day' ? 'theme-day' : 'theme-night'}}">

  <!-- Top App Bar -->
  <appbar theme="{{theme}}" />

  <!-- Today Title -->
  <text class="today-title">{{todayTitle}}</text>

  <!-- Hero Timer Card -->
  <view class="timer-card">
    <view class="timer-label">{{locale === 'en' ? 'DURATION' : '时长'}}</view>
    <view class="timer-display">{{elapsedTime}}</view>
    <view class="timer-stats-row">
      <view class="timer-stat">
        <view class="stat-val">{{totalVolume}}</view>
        <view class="stat-key">{{locale === 'en' ? 'VOLUME (KG)' : '总重量(KG)'}}</view>
      </view>
      <view class="stat-divider"></view>
      <view class="timer-stat">
        <view class="stat-val">{{exerciseCount}}</view>
        <view class="stat-key">{{locale === 'en' ? 'EXERCISES' : '动作数'}}</view>
      </view>
      <view class="stat-divider"></view>
      <view class="timer-stat">
        <view class="stat-val text-primary">{{restTime}}</view>
        <view class="stat-key">{{locale === 'en' ? 'REST' : '休息'}}</view>
      </view>
    </view>
  </view>

  <!-- Quick Start / End Training -->
  <button
    class="start-btn {{runningSession ? 'stop' : 'start'}}"
    bindtap="{{runningSession ? 'stopWorkout' : 'startWorkout'}}"
  >
    {{runningSession ? (locale === 'en' ? 'END TRAINING' : '结束训练') : (locale === 'en' ? 'QUICK START' : '快速开始')}}
  </button>

  <!-- Floating FAB - Add Exercise -->
  <view class="fab" wx:if="{{runningSession}}" bindtap="openAddModal">
    <text class="fab-icon">+</text>
  </view>

  <!-- Current Workout -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">{{locale === 'en' ? 'CURRENT WORKOUT' : '当前训练'}}</text>
      <text class="section-badge {{runningSession ? 'active' : ''}}">{{runningSession ? (locale === 'en' ? 'IN PROGRESS' : '进行中') : (locale === 'en' ? 'READY' : '待开始')}}</text>
    </view>

    <view wx:if="{{exerciseGroups.length > 0}}" class="exercise-list">
      <view
        class="exercise-card"
        wx:for="{{exerciseGroups}}"
        wx:key="exercise_id"
        data-item="{{item}}"
        bindtap="onExerciseTap"
      >
        <!-- Header: image + name/sets + volume -->
        <view class="ec-header">
          <view class="ec-img-wrap">
            <image wx:if="{{item.image_name}}" class="ec-img" src="{{imgPrefix}}/{{item.image_name}}" mode="aspectFill" />
            <view wx:else class="ec-img-placeholder">🏋️</view>
          </view>
          <view class="ec-info">
            <view class="ec-name">{{item.name_zh || item.name}}</view>
            <view class="ec-sets-count">{{item.sets.length}} {{item.sets.length === 1 ? 'set' : 'sets'}}</view>
          </view>
          <view class="ec-volume">
            <view class="ec-vol-num">{{item.totalVolume}} kg</view>
            <view class="ec-vol-label">TOTAL VOLUME</view>
          </view>
        </view>
        <!-- Sets grid: 2 columns -->
        <view class="ec-sets-grid">
          <view class="ec-set-item" wx:for="{{item.sets}}" wx:for-item="s" wx:key="idx">
            <view class="ec-set-num">{{index + 1}}</view>
            <view class="ec-set-val">{{s.weight}} <text class="ec-set-unit">{{s.weight_unit}}</text></view>
            <view class="ec-set-sep">×</view>
            <view class="ec-set-val reps">{{s.reps}} <text class="ec-set-unit">reps</text></view>
          </view>
        </view>
      </view>
    </view>

    <view wx:elif="{{runningSession}}" class="empty-card" bindtap="goToLibrary">
      <text class="empty-hint">{{locale === 'en' ? 'TAP + TO ADD EXERCISES' : '点击 + 添加动作'}}</text>
    </view>

    <view wx:else class="empty-card">
      <text class="empty-hint">{{locale === 'en' ? 'START TRAINING TO ADD EXERCISES' : '开始训练以添加动作'}}</text>
    </view>
  </view>

  <!-- History Bento Section -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">{{locale === 'en' ? 'HISTORY' : '历史记录'}}</text>
      <view
        class="date-picker-btn"
        bindtap="openDatePicker"
      >{{displayDate}}</view>
    </view>

    <!-- Sessions for selected date -->
    <view wx:if="{{historySessions.length > 0}}" class="history-session-list">
      <view
        class="history-session-item"
        wx:for="{{historySessions}}"
        wx:key="id"
        data-session="{{item}}"
        bindtap="onHistorySessionTap"
      >
        <view class="history-session-time">{{item.timeStr}}</view>
        <view class="history-session-info">
          <text class="history-session-stat">{{item.durationStr}}</text>
          <text class="history-session-stat">{{item.exerciseCount || 0}} {{locale === 'en' ? 'EXERCISES' : '动作'}}</text>
        </view>
      </view>
    </view>

      <!-- Bento Grid (shown when no sessions for selected date) -->
      <view wx:else class="bento-grid">
        <view class="bento-card bento-today">
          <view class="bento-label">{{locale === 'en' ? 'TODAY' : '今天'}}</view>
          <view class="bento-day">{{todayDay}}</view>
          <view class="bento-month text-primary">{{todayMonth}}</view>
          <view class="bento-progress-bar">
            <view class="bento-progress-fill" style="width: {{todayProgress}}%"></view>
          </view>
        </view>
        <view class="bento-card bento-yesterday">
          <view class="bento-label">{{locale === 'en' ? 'YESTERDAY' : '昨天'}}</view>
          <view class="bento-day">{{yesterdayDay}}</view>
          <view class="bento-month text-muted">{{yesterdayMonth}}</view>
          <view class="bento-progress-bar">
            <view class="bento-progress-fill muted" style="width: 0%"></view>
          </view>
        </view>
        <view class="bento-card bento-monthly">
          <view class="bento-label">{{locale === 'en' ? 'MONTHLY VOL' : '本月总量'}}</view>
          <view class="bento-big-num text-primary">0 KG</view>
          <view class="bento-hint text-primary">{{locale === 'en' ? 'START TRACKING' : '开始记录'}}</view>
          <view class="bento-bg-icon">📊</view>
        </view>
      </view>
  </view>

  <!-- Custom Date Picker Modal -->
  <view class="picker-overlay {{showDatePicker ? 'show' : ''}}" bindtap="closeDatePicker">
    <view class="picker-modal" catchtap="noop">
      <!-- Month navigation -->
      <view class="picker-header">
        <view class="picker-nav" bindtap="prevMonth">
          <text class="picker-nav-arrow">‹</text>
        </view>
        <view class="picker-month-label">{{pickerYearLabel}}</view>
        <view class="picker-nav" bindtap="nextMonth">
          <text class="picker-nav-arrow">›</text>
        </view>
      </view>
      <!-- Day headers -->
      <view class="picker-day-headers">
        <text class="picker-day-h" wx:for="{{dayNames}}" wx:key="index">{{item}}</text>
      </view>
      <!-- Days grid -->
      <view class="picker-days-grid">
        <view
          wx:for="{{calendarDays}}"
          wx:key="index"
          class="picker-day-cell {{item.empty ? 'empty' : ''}} {{item.isSelected ? 'selected' : ''}} {{item.isToday ? 'today' : ''}}"
          bindtap="selectDay"
          data-day="{{item.day}}"
        >{{item.day}}</view>
      </view>
      <!-- Today shortcut -->
      <view class="picker-today-btn" bindtap="goToToday">{{locale === 'en' ? 'TODAY' : '今天'}}</view>
    </view>
  </view>

  <!-- Add Exercise Modal -->
  <add-exercise-modal
    isOpen="{{showAddModal}}"
    sessionId="{{currentSessionId}}"
    bind:close="onAddModalClose"
    bind:exerciseadded="onAddModalExerciseAdded"
  />

  <!-- Edit Exercise Modal -->
  <edit-exercise-modal
    isOpen="{{showEditModal}}"
    group="{{editingGroup}}"
    sessionId="{{currentSessionId}}"
    bind:close="onEditModalClose"
    bind:saved="onEditModalSaved"
  />

  <!-- Session Detail Modal -->
  <session-detail-modal
    isOpen="{{showSessionDetailModal}}"
    session="{{viewingSession}}"
    sessionId="{{viewingSessionId}}"
    locale="{{locale}}"
    bind:close="onSessionDetailClose"
  />

  <!-- Workout Summary Modal -->
  <workout-summary-modal
    isOpen="{{showWorkoutSummary}}"
    session="{{workoutSummarySession}}"
    exerciseList="{{workoutSummaryExercises}}"
    bind:close="onWorkoutSummaryClose"
  />

  <!-- Custom Tab Bar -->
  <custom-tabbar active="training" theme="{{theme}}" />

</view>
