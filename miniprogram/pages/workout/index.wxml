<!--pages/workout/index.wxml-->
<view class="page">

  <!-- 训练头部 -->
  <view class="workout-header">
    <view class="workout-status">
      <view class="status-dot" wx:if="{{session && !isFinished}}"></view>
      <text class="status-text">{{isFinished ? '训练已结束' : session ? '训练中' : '暂无进行中的训练'}}</text>
    </view>
    <view class="elapsed-time" wx:if="{{session && !isFinished}}">{{elapsedTime}}</view>
  </view>

  <!-- 未开始状态 -->
  <view class="idle-state" wx:if="{{!session || isFinished}}">
    <view class="idle-icon">💪</view>
    <view class="idle-text">开始你的训练吧</view>
    <button class="btn-primary" bindtap="startWorkout">开始训练</button>
  </view>

  <!-- 训练中 -->
  <block wx:if="{{session && !isFinished}}">

    <!-- 已添加的动作列表 -->
    <scroll-view class="exercise-list" scroll-y>
      <view class="section-title">今日动作 ({{exerciseList.length}})</view>

      <view class="exercise-item" wx:for="{{exerciseList}}" wx:key="_id">
        <view class="item-info">
          <view class="item-name">{{item.name_zh || item.name}}</view>
          <view class="item-sets">
            <text class="set-tag" wx:for="{{item.sets}}" wx:for-item="s" wx:key="idx">
              {{s.weight}}{{s.unit}} × {{s.reps}}
            </text>
            <text class="set-empty" wx:if="{{!item.sets || item.sets.length === 0}}">未设置</text>
          </view>
        </view>
        <view class="item-actions">
          <view class="action-btn add-set" catchtap="openAddSet" data-index="{{index}}">+组</view>
          <view class="action-btn edit-btn" catchtap="editExercise" data-item="{{item}}" data-index="{{index}}">编辑</view>
        </view>
      </view>

      <!-- 空状态 -->
      <view class="empty-exercises" wx:if="{{exerciseList.length === 0}}">
        <text>点击下方添加动作开始训练</text>
      </view>
    </scroll-view>

    <!-- 底部操作栏 -->
    <view class="bottom-bar">
      <button class="btn-add-exercise" bindtap="goToLibrary">+ 添加动作</button>
      <button class="btn-finish" bindtap="finishWorkout">结束训练</button>
    </view>

  </block>

  <!-- 添加组数弹窗 -->
  <view class="modal-mask" wx:if="{{showAddSetModal}}" bindtap="closeAddSetModal">
    <view class="modal-card" catchtap="">
      <view class="modal-title">设置重量和次数</view>
      <view class="modal-exercise-name">{{selectedExercise.name_zh || selectedExercise.name}}</view>
      <view class="modal-row">
        <view class="modal-field">
          <input
            class="modal-input"
            type="digit"
            placeholder="重量"
            value="{{inputWeight}}"
            bindinput="onWeightInput"
          />
          <text class="unit-label">{{weightUnit}}</text>
        </view>
        <view class="modal-field">
          <input
            class="modal-input"
            type="number"
            placeholder="次数"
            value="{{inputReps}}"
            bindinput="onRepsInput"
          />
          <text class="unit-label">次</text>
        </view>
      </view>
      <view class="modal-actions">
        <button class="btn-modal-cancel" bindtap="closeAddSetModal">取消</button>
        <button class="btn-modal-confirm" bindtap="confirmAddSet">确认</button>
      </view>
    </view>
  </view>

</view>
