<!--pages/workout/index.wxml-->
<view class="page {{theme === 'day' ? 'theme-day' : 'theme-night'}}">

  <!-- 训练头部 -->
  <view class="workout-header">
    <view class="workout-status">
      <view class="status-dot" wx:if="{{session && !isFinished}}"></view>
      <text class="status-text">{{isFinished ? (locale === 'en' ? 'Workout ended' : '训练已结束') : session ? (locale === 'en' ? 'Training in progress' : '训练中') : (locale === 'en' ? 'No active workout' : '暂无进行中的训练')}}</text>
    </view>
    <view class="elapsed-time" wx:if="{{session && !isFinished}}">{{elapsedTime}}</view>
  </view>

  <!-- 未开始状态 -->
  <view class="idle-state" wx:if="{{!session || isFinished}}">
    <view class="idle-icon">💪</view>
    <view class="idle-text">{{locale === 'en' ? 'Start your workout' : '开始你的训练吧'}}</view>
    <button class="btn-primary" bindtap="startWorkout">{{locale === 'en' ? 'START WORKOUT' : '开始训练'}}</button>
  </view>

  <!-- 训练中 -->
  <block wx:if="{{session && !isFinished}}">

    <!-- 已添加的动作列表 -->
    <scroll-view class="exercise-list" scroll-y>
      <view class="section-title">{{locale === 'en' ? "Today's exercises" : '今日动作'}} ({{exerciseList.length}})</view>

      <view class="exercise-item" wx:for="{{exerciseList}}" wx:key="id">
        <view class="item-image-wrap">
          <image wx:if="{{item.image_name}}" class="item-image" src="{{imgPrefix}}{{item.image_name}}" mode="aspectFill" />
          <view wx:else class="item-image-placeholder">🏋️</view>
        </view>
        <view class="item-info">
          <view class="item-name">{{item.name_zh || item.name}}</view>
          <view class="item-sub" wx:if="{{item.muscle_name || item.equipment_name}}">{{item.muscle_name}}{{item.muscle_name && item.equipment_name ? ' · ' : ''}}{{item.equipment_name}}</view>
          <view class="item-sets">
            <text class="set-tag" wx:for="{{item.sets}}" wx:for-item="s" wx:key="id">
              {{s.weight}}{{s.weight_unit}} × {{s.reps}}
            </text>
            <text class="set-empty" wx:if="{{!item.sets || item.sets.length === 0}}">{{locale === 'en' ? 'Not set' : '未设置'}}</text>
          </view>
        </view>
        <view class="item-volume-badge" wx:if="{{item.totalVolume > 0}}">{{item.totalVolume}}</view>
        <view class="item-actions">
          <view class="action-btn add-set" catchtap="openAddSet" data-index="{{index}}">{{locale === 'en' ? '+ Set' : '+组'}}</view>
          <view class="action-btn edit-btn" catchtap="editExercise" data-item="{{item}}" data-index="{{index}}">{{locale === 'en' ? 'Edit' : '编辑'}}</view>
        </view>
      </view>

      <!-- 空状态 -->
      <view class="empty-exercises" wx:if="{{exerciseList.length === 0}}">
        <text>{{locale === 'en' ? 'Tap below to add exercises and start training' : '点击下方添加动作开始训练'}}</text>
      </view>
    </scroll-view>

    <!-- 底部操作栏 -->
    <view class="bottom-bar">
      <button class="btn-add-exercise" bindtap="goToLibrary">{{locale === 'en' ? '+ ADD EXERCISE' : '+ 添加动作'}}</button>
      <button class="btn-finish" bindtap="finishWorkout">{{locale === 'en' ? 'END WORKOUT' : '结束训练'}}</button>
    </view>

  </block>

  <!-- 添加组数弹窗 -->
  <view class="modal-mask" wx:if="{{showAddSetModal}}" bindtap="closeAddSetModal">
    <view class="modal-card" catchtap="">
      <view class="modal-title">{{locale === 'en' ? 'Set weight and reps' : '设置重量和次数'}}</view>
      <view class="modal-exercise-name">{{selectedExercise.name_zh || selectedExercise.name}}</view>
      <view class="modal-row">
        <view class="modal-field">
          <input
            class="modal-input"
            type="digit"
            placeholder="{{locale === 'en' ? 'Weight' : '重量'}}"
            value="{{inputWeight}}"
            bindinput="onWeightInput"
          />
          <text class="unit-label">{{locale === 'en' ? 'kg' : '公斤'}}</text>
        </view>
        <view class="modal-field">
          <input
            class="modal-input"
            type="number"
            placeholder="{{locale === 'en' ? 'Reps' : '次数'}}"
            value="{{inputReps}}"
            bindinput="onRepsInput"
          />
          <text class="unit-label">{{locale === 'en' ? 'reps' : '次'}}</text>
        </view>
      </view>
      <view class="modal-actions">
        <button class="btn-modal-cancel" bindtap="closeAddSetModal">{{locale === 'en' ? 'Cancel' : '取消'}}</button>
        <button class="btn-modal-confirm" bindtap="confirmAddSet">{{locale === 'en' ? 'Confirm' : '确认'}}</button>
      </view>
    </view>
  </view>

</view>
