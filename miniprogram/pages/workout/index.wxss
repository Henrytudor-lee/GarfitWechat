/* pages/workout/index.wxss — garcia-fitness-new explicit dual-theme selectors */
/* ========================
   Page Base — Night
   ======================== */
.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #131313;
}

/* ========================
   Day Theme
   ======================== */
.page.theme-day {
  background: #f5f5f5;
}

/* ========================
   Night Theme
   ======================== */
.page.theme-night {}

/* ========================
   Workout Header — Day
   ======================== */
.page.theme-day .workout-header {
  background: linear-gradient(135deg, #e8e8e8, #f0f0f0);
}

.page.theme-day .status-text {
  color: #1a1a1a;
}

.page.theme-day .elapsed-time {
  color: #1a1a1a;
}

/* ========================
   Workout Header — Night
   ======================== */
.page.theme-night .workout-header {
  background: linear-gradient(135deg, #1A1A2E, #16213E);
}

.page.theme-night .status-text {
  color: #fff;
}

.page.theme-night .elapsed-time {
  color: #fff;
}

/* ========================
   Workout Header (shared)
   ======================== */
.workout-header {
  padding: 40rpx 32rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.workout-status {
  display: flex;
  align-items: center;
}

.status-dot {
  width: 10rpx;
  height: 10rpx;
  background: #E94560;
  border-radius: 50%;
  margin-right: 12rpx;
  animation: pulse 1.5s infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.3; }
}

.status-text {
  font-size: 28rpx;
  font-weight: 600;
}

.elapsed-time {
  font-size: 40rpx;
  font-weight: 700;
  font-variant-numeric: tabular-nums;
}

/* ========================
   Idle State — Day
   ======================== */
.page.theme-day .idle-text {
  color: #71717a;
}

/* ========================
   Idle State — Night
   ======================== */
.page.theme-night .idle-text {
  color: #999;
}

/* ========================
   Idle State (shared)
   ======================== */
.idle-state {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx;
}

.idle-icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
}

.idle-text {
  font-size: 32rpx;
  margin-bottom: 60rpx;
}

/* ========================
   Exercise List — Day
   ======================== */
.page.theme-day .section-title {
  color: #1a1a1a;
}

.page.theme-day .exercise-item {
  background: #ffffff;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.page.theme-day .item-image-wrap {
  background: #f0f0f0;
}

.page.theme-day .item-image-placeholder {
  background: #f0f0f0;
  color: #71717a;
}

.page.theme-day .item-name {
  color: #1a1a1a;
}

.page.theme-day .item-sub {
  color: #888;
}

.page.theme-day .set-tag {
  background: #FFF0F3;
  color: #E94560;
}

.page.theme-day .set-empty {
  color: #BBB;
}

/* ========================
   Exercise List — Night
   ======================== */
.page.theme-night .section-title {
  color: #fff;
}

.page.theme-night .exercise-item {
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
}

.page.theme-night .item-image-wrap {
  background: rgba(255, 255, 255, 0.05);
}

.page.theme-night .item-image-placeholder {
  background: rgba(255, 255, 255, 0.05);
  color: #71717a;
}

.page.theme-night .item-name {
  color: #fff;
}

.page.theme-night .item-sub {
  color: #71717a;
}

.page.theme-night .set-tag {
  background: rgba(233, 69, 96, 0.15);
  color: #ef4444;
}

.page.theme-night .set-empty {
  color: #52525b;
}

/* ========================
   Exercise List (shared)
   ======================== */
.exercise-list {
  flex: 1;
  padding: 24rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 700;
  margin-bottom: 20rpx;
}

.item-image-wrap {
  width: 120rpx;
  height: 120rpx;
  border-radius: 16rpx;
  overflow: hidden;
  flex-shrink: 0;
  margin-right: 20rpx;
}

.item-image {
  width: 100%;
  height: 100%;
}

.item-image-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
}

.exercise-item {
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
}

.item-info {
  flex: 1;
  min-width: 0;
}

.item-name {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 4rpx;
}

.item-sub {
  font-size: 22rpx;
  margin-bottom: 6rpx;
}

.item-sets {
  display: flex;
  gap: 8rpx;
  flex-wrap: wrap;
}

.set-tag {
  display: inline-block;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
}

.set-empty {
  font-size: 22rpx;
}

.action-btn {
  padding: 10rpx 20rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  border: none;
}

.add-set {
  background: #E94560;
  color: #fff;
}

.edit-btn {
  background: rgba(255, 255, 255, 0.08);
  color: #71717a;
}

.empty-exercises {
  text-align: center;
  color: #BBB;
  font-size: 26rpx;
  padding: 80rpx 0;
}

/* ========================
   Item Volume Badge (shared)
   ======================== */
.item-volume-badge {
  font-size: 22rpx;
  font-weight: 700;
  background: #ccf200;
  color: #1A1A2E;
  border-radius: 20rpx;
  padding: 4rpx 14rpx;
  flex-shrink: 0;
  margin-left: auto;
}

.item-actions {
  display: flex;
  gap: 12rpx;
  flex-shrink: 0;
}

/* ========================
   Bottom Bar — Day
   ======================== */
.page.theme-day .bottom-bar {
  background: #ffffff;
  border-top: 1rpx solid rgba(0, 0, 0, 0.10);
}

.page.theme-day .btn-add-exercise {
  background: #f0f0f0;
  color: #1A1A2E;
}

.page.theme-day .btn-finish {
  background: linear-gradient(135deg, #E94560, #FF6B6B);
  color: #fff;
}

/* ========================
   Bottom Bar — Night
   ======================== */
.page.theme-night .bottom-bar {
  background: #1c1c1c;
  border-top: 1rpx solid rgba(255, 255, 255, 0.08);
}

.page.theme-night .btn-add-exercise {
  background: rgba(255, 255, 255, 0.08);
  color: #fff;
}

.page.theme-night .btn-finish {
  background: linear-gradient(135deg, #E94560, #FF6B6B);
  color: #fff;
}

/* ========================
   Bottom Bar (shared)
   ======================== */
.bottom-bar {
  display: flex;
  gap: 20rpx;
  padding: 24rpx;
}

.btn-add-exercise {
  flex: 1;
  border-radius: 50rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
  line-height: 2.4;
}

.btn-finish {
  flex: 1;
  border-radius: 50rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
  line-height: 2.4;
}

.btn-finish::after, .btn-add-exercise::after { border: none; }

/* ========================
   Modal — Day
   ======================== */
.page.theme-day .modal-mask {
  background: rgba(0, 0, 0, 0.5);
}

.page.theme-day .modal-card {
  background: #ffffff;
}

.page.theme-day .modal-title {
  color: #1A1A2E;
}

.page.theme-day .modal-exercise-name {
  color: #71717a;
}

.page.theme-day .modal-field {
  border: 2rpx solid #EEEEEE;
}

.page.theme-day .modal-input {
  color: #1A1A2E;
}

.page.theme-day .unit-label {
  color: #888;
}

.page.theme-day .btn-modal-cancel {
  background: #f0f0f0;
  color: #666;
}

.page.theme-day .btn-modal-confirm {
  background: #E94560;
  color: #fff;
}

/* ========================
   Modal — Night
   ======================== */
.page.theme-night .modal-mask {
  background: rgba(0, 0, 0, 0.5);
}

.page.theme-night .modal-card {
  background: #1c1c1c;
}

.page.theme-night .modal-title {
  color: #fff;
}

.page.theme-night .modal-exercise-name {
  color: #71717a;
}

.page.theme-night .modal-field {
  border: 2rpx solid rgba(255, 255, 255, 0.10);
}

.page.theme-night .modal-input {
  color: #fff;
}

.page.theme-night .unit-label {
  color: #71717a;
}

.page.theme-night .btn-modal-cancel {
  background: rgba(255, 255, 255, 0.08);
  color: #a1a1aa;
}

.page.theme-night .btn-modal-confirm {
  background: #E94560;
  color: #fff;
}

/* ========================
   Modal (shared)
   ======================== */
.modal-mask {
  position: fixed;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-card {
  border-radius: 24rpx;
  padding: 40rpx;
  width: 600rpx;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 700;
  text-align: center;
  margin-bottom: 8rpx;
}

.modal-exercise-name {
  font-size: 26rpx;
  text-align: center;
  margin-bottom: 32rpx;
}

.modal-row {
  display: flex;
  gap: 24rpx;
  margin-bottom: 32rpx;
}

.modal-field {
  flex: 1;
  display: flex;
  align-items: center;
  border-radius: 16rpx;
  padding: 0 20rpx;
  height: 88rpx;
}

.modal-input {
  flex: 1;
  font-size: 32rpx;
  height: 100%;
}

.unit-label {
  font-size: 26rpx;
  margin-left: 8rpx;
}

.modal-actions {
  display: flex;
  gap: 20rpx;
}

.btn-modal-cancel, .btn-modal-confirm {
  flex: 1;
  border-radius: 50rpx;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 2.4;
  border: none;
}

.btn-modal-cancel::after, .btn-modal-confirm::after { border: none; }
