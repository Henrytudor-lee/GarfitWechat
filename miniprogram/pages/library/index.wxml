<!--pages/library/index.wxml—garcia-fitness-new style-->
<view class="page {{theme === 'day' ? 'theme-day' : 'theme-night'}}">

  <!-- Top App Bar -->
  <appbar theme="{{theme}}" />

  <!-- Fixed Filters Section -->
  <view class="filters-fixed">

  <!-- Page Header -->
  <view class="page-header">
    <view class="page-title">{{locale === 'en' ? 'EXERCISE LIBRARY' : '动作库'}}</view>
    <view class="page-subtitle">{{locale === 'en' ? 'Access 7000+ professional movements' : '访问 7000+ 专业动作'}}</view>
  </view>

  <!-- Search -->
  <view class="search-bar">
    <text class="search-icon">🔍</text>
    <input
      class="search-input"
      placeholder="{{locale === 'en' ? 'SEARCH EXERCISES...' : '搜索动作...'}}"
      placeholder-class="search-placeholder"
      value="{{keyword}}"
      bindinput="onSearchInput"
      bindconfirm="onSearch"
    />
    <view class="filter-icons-wrap">
      <text
        class="filter-icon-btn {{filterFavor ? 'active' : ''}}"
        bindtap="onFavorFilterTap"
        hover-class="tap-active"
      >♥</text>
      <text
        class="filter-icon-btn filter-icon-btn-text {{filterPracticed ? 'active' : ''}}"
        bindtap="onPracticedFilterTap"
        hover-class="tap-active"
      >☑</text>
    </view>
  </view>

  <!-- Equipment Filters -->
  <view class="filter-section">
    <scroll-view class="filter-scroll" scroll-x>
      <view class="filter-row">
        <view
          class="filter-chip {{selectedEquipment === null ? 'active' : ''}}"
          bindtap="onEquipmentTap"
          data-id="{{null}}"
        >{{locale === 'en' ? 'ALL' : '全部'}} <text wx:if="{{selectedEquipment === null}}" class="equip-name">{{locale === 'en' ? 'Equips' : '器材'}}</text></view>
        <view
          wx:for="{{equipmentList}}"
          wx:key="id"
          class="filter-chip {{selectedEquipment === item.id ? 'active' : ''}}"
          bindtap="onEquipmentTap"
          data-id="{{item.id}}"
        >
          <image wx:if="{{item.icon}}" class="equip-icon" src="{{imgPrefix}}/equipment_icons/{{item.icon}}" mode="aspectFit" />
          <text wx:if="{{selectedEquipment === item.id}}" class="equip-name">{{locale === 'en' ? item.name : item.name_zh}}</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- Muscle Filters -->
  <view class="filter-section">
    <scroll-view class="filter-scroll" scroll-x>
      <view class="filter-row">
        <view
          class="filter-chip {{selectedMuscle === null ? 'active' : ''}}"
          bindtap="onMuscleTap"
          data-id="{{null}}"
        >{{locale === 'en' ? 'ALL' : '全部'}} <text wx:if="{{selectedMuscle === null}}" class="equip-name">{{locale === 'en' ? 'Muscles' : '肌群'}}</text></view>
        <view
          wx:for="{{muscleList}}"
          wx:key="id"
          class="filter-chip {{selectedMuscle === item.id ? 'active' : ''}}"
          bindtap="onMuscleTap"
          data-id="{{item.id}}"
        >
          <image wx:if="{{item.icon}}" class="equip-icon" src="{{imgPrefix}}/body-icons/{{item.icon}}" mode="aspectFit" />
          <text wx:if="{{selectedMuscle === item.id}}" class="equip-name">{{locale === 'en' ? item.name : item.name_zh}}</text>
        </view>
      </view>
    </scroll-view>
  </view>

  </view>
  <!-- /filters-fixed -->

  <!-- Scrollable Content -->
  <scroll-view class="content-scroll" scroll-y bindscrolltolower="loadMore" lower-threshold="100">
  <view wx:if="{{loading && list.length === 0}}" class="loading-state">{{locale === 'en' ? 'LOADING...' : '加载中...'}}</view>
  <view wx:elif="{{list.length === 0 && !loading}}" class="empty-state">{{locale === 'en' ? 'NO EXERCISES FOUND' : '没有找到动作'}}</view>

  <view wx:else class="exercise-grid">
    <view
      class="exercise-card"
      wx:for="{{list}}"
      wx:key="id"
      data-item="{{item}}"
      bindtap="onExerciseTap"
    >
      <!-- Image -->
      <view class="card-img-wrap">
        <image
          wx:if="{{item.image_name}}"
          class="card-img"
          src="{{imgPrefix}}/{{item.image_name}}"
          mode="aspectFill"
        />
        <view wx:else class="card-img-placeholder">🏋️</view>
        <view class="card-gradient"></view>
        <view wx:if="{{item.is_practiced}}" class="done-badge">{{locale === 'en' ? 'DONE' : '已完成'}}</view>
        <view class="fav-icon-wrap {{item.is_favorite ? 'active' : ''}}" catchtap="onFavoriteTap" data-id="{{item.id}}">
          <image wx:if="{{item.is_favorite}}" src="{{imgPrefix}}/icons/heart_filled.png" mode="aspectFit" />
          <image wx:else src="{{imgPrefix}}/icons/heart.png" mode="aspectFit" />
        </view>
        <view wx:if="{{item.video_file}}" class="play-overlay">▶</view>
      </view>
      <!-- Card Footer -->
      <view class="card-footer">
        <view class="card-top">
          <view class="card-name">{{locale === 'en' ? item.name : (item.name_zh || item.name)}}</view>
          <view class="card-info-btn" catchtap="openDetail" data-item="{{item}}">ⓘ</view>
        </view>
        <view class="card-tags">
          <image wx:if="{{item.equipment_icon}}" class="chip-icon" src="{{imgPrefix}}/equipment_icons/{{item.equipment_icon}}" mode="aspectFit" />
          <text class="chip chip-neutral">{{locale === 'en' ? item.equipment_name : (item.equipment_name_zh || item.equipment_name)}}</text>
          <text wx:if="{{item.muscle_name}}" class="chip">{{locale === 'en' ? item.muscle_name : (item.muscle_name_zh || item.muscle_name)}}</text>
        </view>
      </view>
    </view>
  </view>

  <view wx:if="{{hasMore}}" class="load-more" bindtap="loadMore">{{locale === 'en' ? 'LOAD MORE' : '加载更多'}}</view>
  <view wx:if="{{!hasMore && list.length > 0}}" class="no-more">— {{locale === 'en' ? 'ALL' : '全部'}} —</view>

  </scroll-view>
  <!-- /content-scroll -->

  <!-- Exercise Detail Bottom Sheet -->
  <view class="sheet-mask {{selectedExercise ? 'show' : ''}}" catchtouchmove="noop">
    <view class="sheet" catchtap="noop">

      <!-- Close Handle -->
      <view class="sheet-handle" bindtap="closeSheet"></view>

      <!-- Header with close -->
      <view class="sheet-header">
        <text class="sheet-title">{{selectedExercise.name_zh || selectedExercise.name}}</text>
        <view class="sheet-close" bindtap="closeSheet">✕</view>
      </view>

      <!-- Media -->
      <view class="sheet-media">
        <video
          wx:if="{{selectedExercise.video_file}}"
          class="sheet-video"
          src="{{vidPrefix}}/{{selectedExercise.video_file}}"
          controls
          show-center-play-btn
          enable-play-gesture
          bindtap="onVideoTap"
        />
        <image
          wx:else
          class="sheet-img"
          src="{{imgPrefix}}/{{selectedExercise.image_name}}"
          mode="aspectFill"
        />
      </view>

      <!-- Scrollable Content -->
      <scroll-view class="sheet-scroll" scroll-y>
        <view class="sheet-content">
          <view class="sheet-en">{{selectedExercise.name}}</view>
          <view class="sheet-tags">
            <text class="chip chip-neutral">{{locale === 'en' ? selectedExercise.equipment_name : (selectedExercise.equipment_name_zh || selectedExercise.equipment_name)}}</text>
            <text wx:if="{{selectedExercise.muscle_name}}" class="chip">{{locale === 'en' ? selectedExercise.muscle_name : (selectedExercise.muscle_name_zh || selectedExercise.muscle_name)}}</text>
            <text class="chip chip-neutral">{{selectedExercise.exercise_type || 'STRENGTH'}}</text>
          </view>
        </view>
      </scroll-view>

      <!-- Action Button -->
      <view class="sheet-action">
        <button
          class="sheet-btn"
          bindtap="{{isSelectMode ? 'doSelect' : 'addToWorkout'}}"
          data-item="{{selectedExercise}}"
        >{{isSelectMode ? (locale === 'en' ? 'SELECT EXERCISE' : '选择动作') : (locale === 'en' ? 'ADD TO WORKOUT' : '添加到训练')}}</button>
      </view>
    </view>
  </view>

  <!-- Custom Tab Bar -->
  <custom-tabbar active="library" theme="{{theme}}" />

</view>
