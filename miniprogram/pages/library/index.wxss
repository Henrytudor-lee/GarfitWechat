/* pages/library/index.wxss — garcia-fitness-new explicit dual-theme selectors */
/* ========================
   Page Base — Night
   ======================== */
.page {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: #131313;
  padding-top: 100rpx;
  padding-left: 24rpx;
  padding-right: 24rpx;
  padding-bottom: 200rpx;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  overflow: hidden;
}

/* ========================
   Day Theme
   ======================== */
.page.theme-day {
  background: #f5f5f5;
}

/* ========================
   Night Theme
   ======================== */
.page.theme-night {}

/* ========================
   Page Header — Day
   ======================== */
.page.theme-day .page-title {
  color: #1a1a1a;
}

.page.theme-day .page-subtitle {
  color: #71717a;
}

/* ========================
   Page Header — Night
   ======================== */
.page.theme-night .page-title {
  color: #fff;
}

.page.theme-night .page-subtitle {
  color: #71717a;
}

/* ========================
   Page Header (shared)
   ======================== */
.page-header {
  padding: 24rpx 0 20rpx;
}

.page-title {
  font-family: 'Lexend Deca', 'Lexend', sans-serif;
  font-size: 48rpx;
  font-weight: 900;
  text-transform: uppercase;
  letter-spacing: 0.03em;
  line-height: 1;
  margin-bottom: 8rpx;
}

.page-subtitle {
  font-size: 22rpx;
  font-weight: 600;
  letter-spacing: 0.08em;
}

/* ========================
   Search Bar — Day
   ======================== */
.page.theme-day .search-bar {
  background: rgba(0, 0, 0, 0.05);
}

.page.theme-day .search-input {
  color: #1a1a1a;
}

.page.theme-day .search-placeholder {
  color: #a1a1aa;
}

.page.theme-day .filter-icon-btn {
  background: rgba(0, 0, 0, 0.08);
}

.page.theme-day .filter-icon-btn-text {
  color: #1a1a1a;
}

/* ========================
   Search Bar — Night
   ======================== */
.page.theme-night .search-bar {
  background: rgba(255, 255, 255, 0.05);
}

.page.theme-night .search-input {
  color: #fff;
}

.page.theme-night .search-placeholder {
  color: #3f3f46;
}

.page.theme-night .filter-icon-btn {
  background: rgba(255, 255, 255, 0.08);
}

.page.theme-night .filter-icon-btn-text {
  color: #fff;
}

/* ========================
   Search Bar (shared)
   ======================== */
.search-bar {
  display: flex;
  align-items: center;
  border-radius: 16rpx;
  padding: 0 24rpx;
  height: 64rpx;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.search-icon {
  font-size: 28rpx;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  font-size: 22rpx;
  font-weight: 700;
  background: transparent;
  border: none;
  outline: none;
  letter-spacing: 0.05em;
}

.search-placeholder {
  font-weight: 800;
  letter-spacing: 0.1em;
  font-size: 22rpx;
}

.filter-icons-wrap {
  display: flex;
  gap: 8rpx;
  align-items: center;
  flex-shrink: 0;
}

.filter-icon-btn {
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 10rpx;
  transition: background 0.15s;
  font-size: 28rpx;
  line-height: 1;
}

.filter-icon-btn-text {}

.filter-icon-btn.active {
  background: rgba(204, 242, 0, 0.2);
  color: var(--primary-text);
}

.tap-active {
  opacity: 0.7;
}

/* ========================
   Filter Sections — Day
   ======================== */
.page.theme-day .filter-label {
  color: #a1a1aa;
}

.page.theme-day .filter-chip {
  background: rgba(0, 0, 0, 0.08);
  color: #71717a;
  border: 1rpx solid rgba(0, 0, 0, 0.08);
}

.page.theme-day .filter-chip .equip-name {
  color: #71717a;
}

.page.theme-day .muscle-item {
  background: rgba(0, 0, 0, 0.05);
  border: 1rpx solid rgba(0, 0, 0, 0.05);
}

.page.theme-day .muscle-name {
  color: #71717a;
}

/* ========================
   Filter Sections — Night
   ======================== */
.page.theme-night .filter-label {
  color: #52525b;
}

.page.theme-night .filter-chip {
  background: rgba(255, 255, 255, 0.2);
  color: #888;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
}

.page.theme-night .filter-chip .equip-name {
  color: #888;
}

.page.theme-night .muscle-item {
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.05);
}

.page.theme-night .muscle-name {
  color: #71717a;
}

/* ========================
   Filter Sections (shared)
   ======================== */
.filter-section {
  margin-bottom: 20rpx;
}

.filter-label {
  font-size: 18rpx;
  font-weight: 800;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  margin-bottom: 12rpx;
  padding-left: 4rpx;
}

.filter-scroll {
  white-space: nowrap;
}

.filter-row {
  display: flex;
  gap: 12rpx;
}

.filter-chip {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 4rpx 8rpx;
  border-radius: 30rpx;
  font-size: 22rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.filter-chip.active {
  background: var(--primary);
  color: #000;
  border-color: var(--primary);
}

.filter-chip .equip-name {
  font-size: 22rpx;
  font-weight: 700;
  white-space: nowrap;
}

.filter-chip.active .equip-name {
  color: #000;
}

.filter-chip .equip-icon {
  width: 60rpx;
  height: 60rpx;
  flex-shrink: 0;
  border-radius: 8rpx;
}

.muscle-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.muscle-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  padding: 14rpx 16rpx;
  border-radius: 16rpx;
  min-width: 100rpx;
  flex-shrink: 0;
}

.muscle-item.active {
  background: rgba(59, 130, 246, 0.15);
  border-color: rgba(59, 130, 246, 0.3);
}

.muscle-icon {
  width: 40rpx;
  height: 40rpx;
  flex-shrink: 0;
}

.muscle-item.active .muscle-icon {
  opacity: 1;
}

.muscle-item .muscle-icon {
  opacity: 0.6;
}

.muscle-item.active .muscle-name {
  color: #60a5fa;
}

/* ========================
   Exercise Grid — Day
   ======================== */
.page.theme-day .exercise-card {
  background: rgba(0, 0, 0, 0.05);
  border: 1rpx solid rgba(0, 0, 0, 0.10);
}

.page.theme-day .card-img-wrap {
  background: rgba(0, 0, 0, 0.03);
}

.page.theme-day .card-gradient {
  background: linear-gradient(to top, rgba(0,0,0,0.3) 0%, transparent 60%);
}

.page.theme-day .card-name {
  color: #1a1a1a;
}

.page.theme-day .card-info-btn {
  color: #a1a1aa;
}

.page.theme-day .chip-neutral {
  background: rgba(0, 0, 0, 0.08);
  color: #71717a;
}

/* ========================
   Exercise Grid — Night
   ======================== */
.page.theme-night .exercise-card {
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.05);
}

.page.theme-night .card-img-wrap {
  background: rgba(255, 255, 255, 0.03);
}

.page.theme-night .card-gradient {
  background: linear-gradient(to top, rgba(0,0,0,0.6) 0%, transparent 60%);
}

.page.theme-night .card-name {
  color: #fff;
}

.page.theme-night .card-info-btn {
  color: #52525b;
}

.page.theme-night .chip-neutral {
  background: rgba(255, 255, 255, 0.08);
  color: #71717a;
}

/* ========================
   Exercise Grid (shared)
   ======================== */
.exercise-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
  margin-top: 24rpx;
  width: 100%;
  box-sizing: border-box;
}

.exercise-card {
  border-radius: 24rpx;
  overflow: hidden;
  box-sizing: border-box;
}

.card-img-wrap {
  width: 100%;
  aspect-ratio: 16 / 10;
  position: relative;
  overflow: hidden;
}

.card-img {
  width: 100%;
  height: 100%;
  opacity: 0.8;
}

.card-img-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 64rpx;
}

.card-gradient {
  position: absolute;
  inset: 0;
}

.fav-badge {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  background: var(--primary);
  color: #000;
  font-size: 16rpx;
  font-weight: 900;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  letter-spacing: 0.05em;
}

.done-badge {
  position: absolute;
  top: 8rpx;
  left: 8rpx;
  background: var(--primary);
  color: #000;
  font-size: 16rpx;
  font-weight: 900;
  padding: 4rpx 10rpx;
  border-radius: 8rpx;
}

.fav-icon-wrap {
  position: absolute;
  bottom: 8rpx;
  left: 8rpx;
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.5);
  border-radius: 50%;
}

.fav-icon-wrap image {
  width: 26rpx;
  height: 26rpx;
}

.fav-icon-wrap.active {
  background: rgba(204, 242, 0, 0.3);
}

.play-overlay {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  color: rgba(204, 242, 0, 0.8);
  opacity: 0;
}

.card-footer {
  padding: 16rpx;
}

.card-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 10rpx;
}

.card-name {
  font-family: 'Lexend Deca', 'Lexend', sans-serif;
  font-size: 22rpx;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 0.02em;
  line-height: 1.2;
  flex: 1;
  margin-right: 8rpx;
}

.card-info-btn {
  font-size: 24rpx;
  flex-shrink: 0;
}

.card-tags {
  display: flex;
  gap: 6rpx;
  flex-wrap: wrap;
}

.chip {
  display: inline-block;
  padding: 3rpx 10rpx;
  background: rgba(204, 242, 0, 0.15);
  color: var(--primary-text);
  border-radius: 6rpx;
  font-size: 16rpx;
  font-weight: 800;
  letter-spacing: 0.06em;
  text-transform: uppercase;
}

.chip-icon {
  width: 22rpx;
  height: 22rpx;
  flex-shrink: 0;
}

/* ========================
   States — Day
   ======================== */
.page.theme-day .loading-state,
.page.theme-day .empty-state {
  color: #a1a1aa;
}

.page.theme-day .load-more,
.page.theme-day .no-more {
  color: #a1a1aa;
}

/* ========================
   States — Night
   ======================== */
.page.theme-night .loading-state,
.page.theme-night .empty-state {
  color: #3f3f46;
}

.page.theme-night .load-more,
.page.theme-night .no-more {
  color: #52525b;
}

/* ========================
   States (shared)
   ======================== */
.loading-state, .empty-state {
  text-align: center;
  padding: 80rpx 0;
  font-family: 'Lexend Deca', sans-serif;
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 0.15em;
  text-transform: uppercase;
}

.load-more, .no-more {
  text-align: center;
  padding: 30rpx 0;
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 0.1em;
}

/* ========================
   Bottom Sheet — Day
   ======================== */
.page.theme-day .sheet-mask {
  background: rgba(0, 0, 0, 0.6);
}

.page.theme-day .sheet {
  background: #ffffff;
}

.page.theme-day .sheet-handle {
  background: rgba(0, 0, 0, 0.15);
}

.page.theme-day .sheet-close {
  background: rgba(0, 0, 0, 0.08);
  color: #1a1a1a;
}

.page.theme-day .sheet-title {
  color: #1a1a1a;
}

.page.theme-day .sheet-media {
  background: #f0f0f0;
}

.page.theme-day .sheet-name {
  color: #1a1a1a;
}

.page.theme-day .sheet-en {
  color: #71717a;
}

.page.theme-day .sheet-id {
  color: #a1a1aa;
}

/* ========================
   Bottom Sheet — Night
   ======================== */
.page.theme-night .sheet-mask {
  background: rgba(0, 0, 0, 0.6);
}

.page.theme-night .sheet {
  background: #1a1a1a;
}

.page.theme-night .sheet-handle {
  background: rgba(255,255,255,0.15);
}

.page.theme-night .sheet-close {
  background: rgba(255,255,255,0.1);
  color: #fff;
}

.page.theme-night .sheet-title {
  color: #fff;
}

.page.theme-night .sheet-media {
  background: #000;
}

.page.theme-night .sheet-name {
  color: #fff;
}

.page.theme-night .sheet-en {
  color: #71717a;
}

.page.theme-night .sheet-id {
  color: #52525b;
}

/* ========================
   Bottom Sheet (shared)
   ======================== */
.sheet-mask {
  display: none;
  position: fixed;
  inset: 0;
  z-index: 200;
  flex-direction: column;
  justify-content: flex-end;
}

.sheet-mask.show {
  display: flex;
}

.sheet {
  border-radius: 32rpx 32rpx 0 0;
  max-height: 90vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.sheet-handle {
  width: 80rpx;
  height: 8rpx;
  border-radius: 4rpx;
  margin: 20rpx auto;
  flex-shrink: 0;
}

.sheet-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 32rpx 24rpx;
  flex-shrink: 0;
}

.sheet-close {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  flex-shrink: 0;
}

.sheet-title {
  font-family: 'Lexend Deca', sans-serif;
  font-size: 34rpx;
  font-weight: 900;
  text-transform: uppercase;
  letter-spacing: 0.02em;
  flex: 1;
  margin-right: 16rpx;
}

.sheet-media {
  width: 100%;
  aspect-ratio: 16 / 9;
  flex-shrink: 0;
  position: relative;
  background: var(--surface-low, #181818);
}

.sheet-video, .sheet-img {
  width: 100%;
  height: 100%;
}

.sheet-img-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--surface-low, #181818);
}

.placeholder-icon {
  font-size: 96rpx;
  opacity: 0.4;
}

/* 视频缺失时的提示遮罩: 覆盖在图片/占位符底部 */
.sheet-media-tip {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 16rpx 24rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  background: linear-gradient(180deg, rgba(0, 0, 0, 0) 0%, rgba(0, 0, 0, 0.85) 60%);
  pointer-events: none;
}

.tip-icon {
  font-size: 28rpx;
  margin-bottom: 2rpx;
}

.tip-text {
  font-size: 24rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 0.02em;
  text-align: center;
}

.tip-sub {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.65);
  letter-spacing: 0.02em;
  text-align: center;
}

.sheet-scroll {
  flex: 1;
  overflow-y: auto;
}

.sheet-content {
  padding: 24rpx;
}

.sheet-name {
  font-family: 'Lexend Deca', sans-serif;
  font-size: 36rpx;
  font-weight: 900;
  text-transform: uppercase;
  letter-spacing: 0.03em;
  margin-bottom: 6rpx;
}

.sheet-en {
  font-size: 22rpx;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  margin-bottom: 16rpx;
}

.sheet-tags {
  display: flex;
  gap: 10rpx;
  flex-wrap: wrap;
  margin-bottom: 16rpx;
}

.sheet-id {
  font-size: 20rpx;
  font-weight: 700;
}

.sheet-action {
  padding: 0 24rpx 40rpx;
  flex-shrink: 0;
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom, 0px));
}

.sheet-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  white-space: nowrap;
  background: var(--primary);
  color: #000;
  border-radius: 100rpx;
  font-family: 'Lexend Deca', sans-serif;
  font-size: 28rpx;
  font-weight: 900;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  border: none;
  line-height: 96rpx;
  white-space: nowrap;
}
.sheet-btn::after { border: none; }

/* ========================
   Appended — Library Fixes
   ======================== */

/* 1. filter-chip active state — green tint background + primary text */
.filter-chip.active {
  background: rgba(204, 242, 0, 0.15) !important;
  color: var(--primary-text) !important;
  border-color: var(--primary) !important;
}

.filter-chip.active .equip-name {
  color: var(--primary-text) !important;
}

/* 2. content-scroll — fill remaining viewport height */
.content-scroll {
  flex: 1;
  height: 0;          /* flex-grow fills remaining space; 0 min-width prevents blow-out */
  min-height: 300rpx;
}

/* 3. page layout — make page a proper flex column so content-scroll fills the gap */
.page {
  height: 100vh;
  overflow: hidden;
}

/* ensure filters-fixed does not shrink */
.filters-fixed {
  flex-shrink: 0;
}
