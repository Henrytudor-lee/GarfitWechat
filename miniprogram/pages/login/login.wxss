/* pages/login/login.wxss — dark theme */
.page {
  min-height: 100vh;
  background: #131313;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 48rpx;
}

/* Logo */
.logo-area {
  margin-top: 200rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.logo-icon {
  font-size: 120rpx;
  line-height: 1;
  margin-bottom: 24rpx;
}

.logo-title {
  font-size: 72rpx;
  font-weight: 900;
  color: #ccf200;
  letter-spacing: 0.2em;
  line-height: 1;
}

.logo-sub {
  font-size: 22rpx;
  font-weight: 700;
  color: rgba(255, 255, 255, 0.4);
  letter-spacing: 0.3em;
  margin-top: 12rpx;
}

/* Login Card */
.login-card {
  width: 100%;
  margin-top: 100rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.login-desc {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-bottom: 48rpx;
  text-align: center;
}

.login-btn {
  width: 100%;
  height: 100rpx;
  background: #ccf200;
  border-radius: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  padding: 0;
  margin: 0;
}

.login-btn::after {
  border: none;
}

.login-btn.loading {
  opacity: 0.7;
}

.btn-content {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.btn-icon {
  font-size: 40rpx;
}

.btn-text {
  font-size: 32rpx;
  font-weight: 700;
  color: #131313;
}

.login-note {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.35);
  text-align: center;
  margin-top: 32rpx;
  line-height: 1.6;
}

.link {
  color: #ccf200;
}

/* Skip */
.skip-area {
  margin-top: 48rpx;
}

.skip-btn {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.3);
  padding: 16rpx 32rpx;
}
