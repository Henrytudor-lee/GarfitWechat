/* pages/login/login.wxss — dark theme */
.page {
  min-height: 100vh;
  background: #131313;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 48rpx;
}

/* Logo */
.logo-area {
  margin-top: 160rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.logo-icon {
  font-size: 120rpx;
  line-height: 1;
  margin-bottom: 24rpx;
}

.logo-title {
  font-size: 72rpx;
  font-weight: 900;
  color: #ccf200;
  letter-spacing: 0.2em;
  line-height: 1;
}

.logo-sub {
  font-size: 22rpx;
  font-weight: 700;
  color: rgba(255, 255, 255, 0.4);
  letter-spacing: 0.3em;
  margin-top: 12rpx;
}

/* Login Card */
.login-card {
  width: 100%;
  margin-top: 80rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.login-desc {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-bottom: 48rpx;
  text-align: center;
}

/* Avatar */
.avatar-btn {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: transparent;
  border: none;
  padding: 0;
  margin: 0 0 32rpx;
}

.avatar-btn::after {
  border: none;
}

.avatar-wrapper {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  overflow: hidden;
  position: relative;
  border: 3rpx solid rgba(204, 242, 0, 0.4);
}

.avatar-img {
  width: 100%;
  height: 100%;
}

.avatar-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(0, 0, 0, 0.6);
  color: #fff;
  font-size: 20rpx;
  text-align: center;
  padding: 8rpx 0;
  opacity: 0;
  transition: opacity 0.2s;
}

.avatar-wrapper:hover .avatar-overlay {
  opacity: 1;
}

/* Nickname */
.nickname-wrap {
  width: 100%;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  margin-bottom: 32rpx;
  padding: 0 32rpx;
  box-sizing: border-box;
}

.nickname-input {
  height: 96rpx;
  font-size: 30rpx;
  color: #fff;
  width: 100%;
}

.nickname-placeholder {
  color: rgba(255, 255, 255, 0.35);
}

/* Login Button */
.login-btn {
  width: 100%;
  height: 100rpx;
  background: #ccf200;
  border-radius: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  padding: 0;
  margin: 0;
  font-size: 32rpx;
  font-weight: 700;
  color: #131313;
}

.login-btn.disabled {
  background: rgba(204, 242, 0, 0.35);
  color: rgba(19, 19, 19, 0.5);
}

.login-note {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.35);
  text-align: center;
  margin-top: 32rpx;
  line-height: 1.6;
}

.link {
  color: #ccf200;
}

/* Skip */
.skip-area {
  margin-top: 48rpx;
}

.skip-btn {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.3);
  padding: 16rpx 32rpx;
}
