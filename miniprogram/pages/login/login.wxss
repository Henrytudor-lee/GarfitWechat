/* pages/login/login.wxss — 极简微信登录 */
.page {
  min-height: 100vh;
  background: #131313;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 48rpx;
}

/* Logo */
.logo-area {
  margin-top: 160rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.logo-icon {
  font-size: 120rpx;
  line-height: 1;
  margin-bottom: 24rpx;
}

.logo-title {
  font-size: 72rpx;
  font-weight: 900;
  color: #ccf200;
  letter-spacing: 0.2em;
  line-height: 1;
}

.logo-sub {
  font-size: 22rpx;
  font-weight: 700;
  color: rgba(255, 255, 255, 0.4);
  letter-spacing: 0.3em;
  margin-top: 12rpx;
}

/* Login Card */
.login-card {
  width: 100%;
  margin-top: 80rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 微信登录按钮 */
.wx-login-btn {
  width: 100%;
  height: 100rpx;
  background: #ccf200;
  border-radius: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  padding: 0;
  margin: 0;
  font-size: 32rpx;
  font-weight: 700;
  color: #131313;
}
.wx-login-btn::after { border: none; }
