<!--pages/favorites/index.wxml—garcia-fitness-new style-->
<view class="page">

  <view class="page-header">
    <view class="page-title">FAVORITES</view>
    <view class="page-subtitle">{{list.length}} EXERCISES</view>
  </view>

  <view wx:if="{{list.length === 0}}" class="empty-state">
    <text class="empty-icon">♥</text>
    <text class="empty-hint">NO FAVORITES YET</text>
    <text class="empty-sub">ADD EXERCISES FROM THE LIBRARY</text>
  </view>

  <view class="exercise-list">
    <view
      class="exercise-card"
      wx:for="{{list}}"
      wx:key="_id"
      data-item="{{item}}"
      bindtap="onExerciseTap"
    >
      <view class="card-img-wrap">
        <image class="card-img" src="{{imgPrefix}}/{{item.image_name}}" mode="aspectFill"/>
        <view class="card-overlay"></view>
      </view>
      <view class="card-info">
        <view class="card-name">{{item.name_zh || item.name}}</view>
        <view class="card-en">{{item.name}}</view>
        <view class="card-tags">
          <text class="tag tag-neutral">{{item.equipment_name || 'OTHER'}}</text>
        </view>
      </view>
      <view class="remove-btn" catchtap="remove" data-id="{{item._id}}">✕</view>
    </view>
  </view>

</view>
