<!--pages/history/index.wxml—garcia-fitness-new style-->
<view class="page">

  <view class="page-header">
    <view class="page-title">HISTORY</view>
    <view class="page-subtitle">TRAINING RECORDS</view>
  </view>

  <!-- Filter by exercise -->
  <view class="select-wrap">
    <view class="select-label">FILTER BY EXERCISE</view>
    <picker mode="selector" range="{{exerciseList}}" range-key="name" bindchange="onExerciseChange">
      <view class="select-display">
        <text>{{selectedName || '— ALL EXERCISES —'}}</text>
        <text class="select-arrow">›</text>
      </view>
    </picker>
  </view>

  <view wx:if="{{loading}}" class="loading-state">LOADING...</view>

  <view wx:elif="{{list.length === 0}}" class="empty-state">
    <text class="empty-icon">☰</text>
    <text class="empty-hint">NO RECORDS FOUND</text>
  </view>

  <!-- Grouped by month -->
  <view wx:for="{{grouped}}" wx:key="month" class="month-group">
    <view class="month-label">{{item.month}}</view>
    <view class="record-list">
      <view
        class="record-card"
        wx:for="{{item.records}}"
        wx:key="id"
        data-item="{{item}}"
        bindtap="onRecordTap"
      >
        <view class="record-left">
          <view class="record-date">{{item.dateStr}}</view>
          <view class="record-name">{{item.name}}</view>
        </view>
        <view class="record-right">
          <view class="record-stat">{{item.weight}}kg × {{item.reps}}</view>
          <view class="record-arrow">›</view>
        </view>
      </view>
    </view>
  </view>

</view>
