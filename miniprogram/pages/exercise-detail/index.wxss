/* pages/exercise-detail/index.wxss — garcia-fitness-new style */
.page {
  min-height: 100vh;
  background: #131313;
  padding-bottom: 160rpx;
}

.media-wrap {
  width: 100%;
  height: 600rpx;
  position: relative;
  background: #000;
  overflow: hidden;
}

.media {
  width: 100%;
  height: 100%;
}

.media-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to bottom, transparent 50%, rgba(0,0,0,0.8) 100%);
}

.back-btn {
  position: absolute;
  top: 60rpx;
  left: 24rpx;
  width: 72rpx;
  height: 72rpx;
  background: rgba(0,0,0,0.5);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: #fff;
  backdrop-filter: blur(10rpx);
}

.content {
  padding: 32rpx 24rpx;
}

.exercise-name {
  font-family: 'Lexend Deca', sans-serif;
  font-size: 48rpx;
  font-weight: 900;
  color: #fff;
  text-transform: uppercase;
  letter-spacing: 0.03em;
  line-height: 1.1;
  margin-bottom: 8rpx;
}

.exercise-en {
  font-size: 24rpx;
  color: #71717a;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  margin-bottom: 20rpx;
}

.tags-row {
  display: flex;
  gap: 10rpx;
  flex-wrap: wrap;
  margin-bottom: 24rpx;
}

.tag {
  display: inline-block;
  padding: 6rpx 16rpx;
  background: rgba(204, 242, 0, 0.15);
  color: #ccf200;
  border-radius: 100rpx;
  font-size: 20rpx;
  font-weight: 800;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

.tag-neutral {
  background: rgba(255, 255, 255, 0.08);
  color: #71717a;
}

.desc {
  font-size: 26rpx;
  color: #a1a1aa;
  line-height: 1.7;
  margin-bottom: 24rpx;
  padding: 20rpx;
  background: rgba(255,255,255,0.04);
  border-radius: 16rpx;
}

.instructions {
  margin-bottom: 24rpx;
}

.section-title {
  font-family: 'Lexend Deca', sans-serif;
  font-size: 24rpx;
  font-weight: 900;
  color: #fff;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  margin-bottom: 12rpx;
}

.instruction-text {
  font-size: 24rpx;
  color: #a1a1aa;
  line-height: 1.7;
}

/* Action Bar */
.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #131313;
  border-top: 1px solid rgba(255,255,255,0.08);
  padding: 20rpx 24rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  display: flex;
  gap: 16rpx;
  align-items: center;
  z-index: 100;
}

.action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  padding: 12rpx 20rpx;
  font-size: 32rpx;
  color: #71717a;
}

.action-label {
  font-size: 16rpx;
  font-weight: 700;
  letter-spacing: 0.08em;
}

.action-btn.fav-active {
  color: #ef4444;
}

.btn-primary {
  flex: 1;
  background: #ccf200;
  color: #000;
  border-radius: 100rpx;
  font-family: 'Lexend Deca', sans-serif;
  font-size: 26rpx;
  font-weight: 900;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  border: none;
  line-height: 2.4;
}
.btn-primary::after { border: none; }
