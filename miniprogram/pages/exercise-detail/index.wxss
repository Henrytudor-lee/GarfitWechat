/* pages/exercise-detail/index.wxss — garcia-fitness-new explicit dual-theme selectors */
/* ========================
   Page Base — Night
   ======================== */
.page {
  min-height: 100vh;
  background: #131313;
  padding-bottom: 160rpx;
}

/* ========================
   Day Theme
   ======================== */
.page.theme-day {
  background: #f5f5f5;
}

/* ========================
   Night Theme
   ======================== */
.page.theme-night {}

/* ========================
   Media Wrap (shared)
   ======================== */
.media-wrap {
  width: 100%;
  height: 600rpx;
  position: relative;
  background: #000;
  overflow: hidden;
}

.media {
  width: 100%;
  height: 100%;
}

.media-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to bottom, transparent 50%, rgba(0,0,0,0.8) 100%);
}

.back-btn {
  position: absolute;
  top: 60rpx;
  left: 24rpx;
  width: 72rpx;
  height: 72rpx;
  background: rgba(0,0,0,0.5);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: #fff;
  backdrop-filter: blur(10rpx);
}

/* ========================
   Content — Day
   ======================== */
.page.theme-day .exercise-name {
  color: #1a1a1a;
}

.page.theme-day .exercise-en {
  color: #71717a;
}

.page.theme-day .tag-neutral {
  background: rgba(0, 0, 0, 0.08);
  color: #71717a;
}

.page.theme-day .desc {
  color: #71717a;
  background: rgba(0, 0, 0, 0.04);
}

.page.theme-day .instruction-text {
  color: #71717a;
}

/* ========================
   Content — Night
   ======================== */
.page.theme-night .exercise-name {
  color: #fff;
}

.page.theme-night .exercise-en {
  color: #71717a;
}

.page.theme-night .tag-neutral {
  background: rgba(255, 255, 255, 0.08);
  color: #71717a;
}

.page.theme-night .desc {
  color: #a1a1aa;
  background: rgba(255,255,255,0.04);
}

.page.theme-night .instruction-text {
  color: #a1a1aa;
}

/* ========================
   Content (shared)
   ======================== */
.content {
  padding: 32rpx 24rpx;
}

.exercise-name {
  font-family: 'Lexend Deca', sans-serif;
  font-size: 48rpx;
  font-weight: 900;
  color: #fff;
  text-transform: uppercase;
  letter-spacing: 0.03em;
  line-height: 1.1;
  margin-bottom: 8rpx;
}

.exercise-en {
  font-size: 24rpx;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  margin-bottom: 20rpx;
}

.tags-row {
  display: flex;
  gap: 10rpx;
  flex-wrap: wrap;
  margin-bottom: 24rpx;
}

.tag {
  display: inline-block;
  padding: 6rpx 16rpx;
  background: rgba(204, 242, 0, 0.15);
  color: #ccf200;
  border-radius: 100rpx;
  font-size: 20rpx;
  font-weight: 800;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

.tag-neutral {
  background: rgba(255, 255, 255, 0.08);
  color: #71717a;
}

.desc {
  font-size: 26rpx;
  line-height: 1.7;
  margin-bottom: 24rpx;
  padding: 20rpx;
  border-radius: 16rpx;
}

.instructions {
  margin-bottom: 24rpx;
}

.section-title {
  font-family: 'Lexend Deca', sans-serif;
  font-size: 24rpx;
  font-weight: 900;
  color: #fff;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  margin-bottom: 12rpx;
}

.instruction-text {
  font-size: 24rpx;
  line-height: 1.7;
}

/* ========================
   Action Bar — Day
   ======================== */
.page.theme-day .action-bar {
  background: #ffffff;
  border-top: 1rpx solid rgba(0, 0, 0, 0.10);
}

.page.theme-day .action-btn {
  color: #71717a;
}

/* ========================
   Action Bar — Night
   ======================== */
.page.theme-night .action-bar {
  background: #131313;
  border-top: 1rpx solid rgba(255,255,255,0.08);
}

.page.theme-night .action-btn {
  color: #71717a;
}

/* ========================
   Action Bar (shared)
   ======================== */
.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 24rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  display: flex;
  gap: 16rpx;
  align-items: center;
  z-index: 100;
}

.action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  padding: 12rpx 20rpx;
  font-size: 32rpx;
}

.action-label {
  font-size: 16rpx;
  font-weight: 700;
  letter-spacing: 0.08em;
}

.action-btn.fav-active {
  color: #ef4444;
}

.btn-primary {
  flex: 1;
  height: 96rpx;
  background: #ccf200;
  color: #000;
  border-radius: 100rpx;
  font-family: 'Lexend Deca', sans-serif;
  font-size: 26rpx;
  font-weight: 900;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  border: none;
  line-height: 96rpx;
  white-space: nowrap;
}
.btn-primary::after { border: none; }
