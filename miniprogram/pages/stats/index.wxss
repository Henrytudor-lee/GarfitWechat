/* ========================
   Exercise Selector (shared)
   ======================== */
.select-wrap {
  border-radius: 20rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 24rpx;
}

.select-header {
  margin-bottom: 8rpx;
}

.select-label {
  font-size: 20rpx;
