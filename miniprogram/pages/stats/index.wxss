.page.theme-night .empty-text {
  color: #52525b;
}

.page.theme-night .empty-subtext {
  color: #3f3f46;
}

/* ========================
   Empty State (shared)
   ======================== */
.empty-state {
  text-align: center;
  padding: 80rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.empty-icon {
  width: 80rpx;
