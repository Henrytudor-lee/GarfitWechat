/* pages/stats/index.wxss — garcia-fitness-new explicit dual-theme selectors */
/* ========================
   Page Base — Night
   ======================== */
.page {
  min-height: 100vh;
  background: #131313;
  padding: 100rpx 24rpx 200rpx;
}

/* ========================
   Day Theme
   ======================== */
.page.theme-day {
  background: #f5f5f5;
  /* 兜底: WeChat 自定义组件/页面 CSS 变量传递不可靠, 在 page 自己的作用域内再定义一次 */
  --primary-text: #3a4a00;
  --primary-bg-soft: rgba(58, 74, 0, 0.15);
}

/* ========================
   Night Theme
   ======================== */
.page.theme-night {
  background: #131313;
  --primary-text: #ccf200;
  --primary-bg-soft: rgba(204, 242, 0, 0.15);
}

/* ========================
   Page Header — Day
   ======================== */
.page.theme-day .page-title-text {
  color: var(--primary-text);
}

.page.theme-day .page-subtitle-text {
  color: #71717a;
}

/* ========================
   Page Header — Night
   ======================== */
.page.theme-night .page-title-text {
  color: var(--primary-text);
}

.page.theme-night .page-subtitle-text {
  color: #71717a;
}

/* ========================
   Page Header (shared)
   ======================== */
.page-header {
  margin-bottom: 32rpx;
}

.page-title-text {
  font-family: 'Lexend Deca', 'Lexend', sans-serif;
  font-size: 40rpx;
  font-weight: 900;
  color: var(--primary-text);
  text-transform: uppercase;
  letter-spacing: 0.1em;
}

.page-subtitle-text {
  font-size: 22rpx;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  margin-top: 4rpx;
}

/* ========================
   Summary Stats Grid — Day
   ======================== */
.page.theme-day .stat-card {
  background: rgba(0, 0, 0, 0.05);
  border: 1rpx solid rgba(0, 0, 0, 0.10);
}

.page.theme-day .stat-card-value {
  color: #1a1a1a;
}

.page.theme-day .stat-card-value-small {
  color: #1a1a1a;
}

.page.theme-day .stat-card-label {
  color: #71717a;
}

/* ========================
   Summary Stats Grid — Night
   ======================== */
.page.theme-night .stat-card {
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.10);
}

.page.theme-night .stat-card-value {
  color: #fff;
}

.page.theme-night .stat-card-value-small {
  color: #fff;
}

.page.theme-night .stat-card-label {
  color: #71717a;
}

/* ========================
   Summary Stats Grid (shared)
   ======================== */
.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.stat-card {
  border-radius: 20rpx;
  padding: 24rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.stat-card-icon {
  width: 36rpx;
  height: 36rpx;
  margin-bottom: 4rpx;
}

.stat-card-value {
  font-family: 'Lexend Deca', 'Lexend', sans-serif;
  font-size: 44rpx;
  font-weight: 900;
  line-height: 1;
}

/* 单位 (kg) 视觉降级: 与数字 K 区分 */
.unit {
  font-size: 60%;
  font-weight: 600;
  color: var(--text-muted);
  margin-left: 0.15em;
  letter-spacing: 0.05em;
}

/* 肌群图例数字小, 单位用绝对值避免过小 */
.muscle-legend-val .unit {
  font-size: 16rpx;
  margin-left: 0.2em;
}

.stat-card-value-small {
  font-family: 'Lexend Deca', sans-serif;
  font-size: 32rpx;
  font-weight: 900;
  line-height: 1;
}

.stat-card-label {
  font-size: 20rpx;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  margin-top: 4rpx;
}

/* ========================
   Glass Card — Day
   ======================== */
.page.theme-day .glass-card {
  background: rgba(0, 0, 0, 0.05);
  border: 1rpx solid rgba(0, 0, 0, 0.10);
}

/* ========================
   Glass Card — Night
   ======================== */
.page.theme-night .glass-card {
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.10);
}

/* ========================
   Glass Card (shared)
   ======================== */
.glass-card {
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

/* ========================
   Section — Day
   ======================== */
.page.theme-day .section-title {
  color: #1a1a1a;
}

.page.theme-day .section-subtitle {
  color: #71717a;
}

/* ========================
   Section — Night
   ======================== */
.page.theme-night .section-title {
  color: #fff;
}

.page.theme-night .section-subtitle {
  color: #71717a;
}

/* ========================
   Section (shared)
   ======================== */
.section-title {
  font-family: 'Lexend Deca', sans-serif;
  font-size: 26rpx;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  margin-bottom: 4rpx;
}

.section-subtitle {
  font-size: 20rpx;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  margin-bottom: 16rpx;
}

/* ========================
   Bar Chart — Day
   ======================== */
.page.theme-day .bar-chart {
  background: rgba(0, 0, 0, 0.05);
  border: 1rpx solid rgba(0, 0, 0, 0.10);
}

.page.theme-day .chart-card {
  background: rgba(0, 0, 0, 0.05);
  border: 1rpx solid rgba(0, 0, 0, 0.10);
}

.page.theme-day .bar-label {
  color: #71717a;
}

.page.theme-day .bar-track {
  background: rgba(0, 0, 0, 0.08);
}

.page.theme-day .bar-value {
  color: #71717a;
}

/* ========================
   Bar Chart — Night
   ======================== */
.page.theme-night .bar-chart {
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.10);
}

.page.theme-night .chart-card {
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.10);
}

.page.theme-night .bar-label {
  color: #a1a1aa;
}

.page.theme-night .bar-track {
  background: rgba(255, 255, 255, 0.08);
}

.page.theme-night .bar-value {
  color: #71717a;
}

/* ========================
   Bar Chart (shared)
   ======================== */
.bar-chart {
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.chart-card {
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.bar-rows {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-top: 8rpx;
}

/* Leaderboard */
.lb-card {
  position: relative;
  overflow: visible;
}

.lb-badge {
  position: absolute;
  top: 24rpx;
  left: -14rpx;
  background: var(--primary);
  color: #000;
  font-size: 22rpx;
  font-weight: 800;
  padding: 8rpx 24rpx;
  border-radius: 8rpx;
  letter-spacing: 0.06em;
  z-index: 2;
  white-space: nowrap;
}

.lb-title-row {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  margin-bottom: 20rpx;
}

.lb-toggles {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex-shrink: 0;
}

/* Type toggle — segmented pill */
.lb-type-toggle {
  display: flex;
  border-radius: 12rpx;
  overflow: hidden;
}
.page.theme-night .lb-type-toggle {
  background: rgba(255, 255, 255, 0.06);
}
.page.theme-day .lb-type-toggle {
  background: rgba(0, 0, 0, 0.05);
}

.lb-type-btn {
  height: 48rpx;
  padding: 0 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  font-weight: 700;
  color: #71717a;
}
.page.theme-day .lb-type-btn { color: #a1a1aa; }

.lb-type-btn.active {
  background: var(--primary);
  color: #000;
}

/* Period toggle — small separate pills */
.lb-period-toggle {
  display: flex;
  gap: 8rpx;
}

.lb-period-btn {
  height: 40rpx;
  padding: 0 16rpx;
  border-radius: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18rpx;
  font-weight: 600;
}
.page.theme-night .lb-period-btn {
  background: rgba(255, 255, 255, 0.06);
  color: #71717a;
  border: 1px solid rgba(255, 255, 255, 0.06);
}
.page.theme-night .lb-period-btn.active {
  background: rgba(204, 242, 0, 0.15);
  color: #ccf200;
  border-color: rgba(204, 242, 0, 0.3);
}
.page.theme-day .lb-period-btn {
  background: rgba(0, 0, 0, 0.04);
  color: #a1a1aa;
  border: 1px solid rgba(0, 0, 0, 0.06);
}
.page.theme-day .lb-period-btn.active {
  background: rgba(133, 160, 0, 0.12);
  color: #85a000;
  border-color: rgba(133, 160, 0, 0.3);
}

.lb-body { margin-top: 16rpx; }

.lb-empty {
  text-align: center;
  padding: 40rpx 0;
  font-size: 24rpx;
  opacity: 0.4;
}

.lb-header {
  display: flex;
  align-items: center;
  padding: 16rpx 0 12rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
  margin-bottom: 12rpx;
}
.page.theme-day .lb-header { border-color: rgba(0, 0, 0, 0.06); }

.lb-header-rank { width: 56rpx; font-size: 18rpx; font-weight: 800; opacity: 0.4; letter-spacing: 0.1em; }
.lb-header-name { flex: 1; }
.lb-header-cal { width: 80rpx; text-align: right; font-size: 18rpx; font-weight: 800; opacity: 0.4; letter-spacing: 0.1em; }

.lb-header-rank, .lb-header-cal { color: #71717a; }
.page.theme-day .lb-header-rank, .page.theme-day .lb-header-cal { color: #a1a1aa; }

.lb-rows { display: flex; flex-direction: column; gap: 16rpx; }

.lb-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.lb-rank {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 900;
  flex-shrink: 0;
  background: rgba(255, 255, 255, 0.06);
  color: #71717a;
}
.page.theme-day .lb-rank { background: rgba(0, 0, 0, 0.06); color: #a1a1aa; }

.lb-rank.gold { background: #facc15; color: #000; }
.lb-rank.silver { background: #9ca3af; color: #000; }
.lb-rank.bronze { background: #d97706; color: #fff; }

.lb-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  flex-shrink: 0;
  background: rgba(255, 255, 255, 0.08);
}
.lb-avatar-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.lb-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.lb-name {
  font-size: 24rpx;
  font-weight: 700;
  color: #e5e5e5;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.page.theme-day .lb-name { color: #1a1a1a; }

.lb-track {
  height: 8rpx;
  border-radius: 4rpx;
  background: rgba(255, 255, 255, 0.06);
  overflow: hidden;
}
.page.theme-day .lb-track { background: rgba(0, 0, 0, 0.06); }

.lb-fill {
  height: 100%;
  border-radius: 4rpx;
  background: var(--primary);
}

.lb-cal {
  width: 80rpx;
  text-align: right;
  font-size: 24rpx;
  font-weight: 800;
  color: #e5e5e5;
  flex-shrink: 0;
}
.page.theme-day .lb-cal { color: #1a1a1a; }

.bar-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 4rpx;
}
.bar-header-label {
  width: 100rpx;
  flex-shrink: 0;
}
.bar-header-track {
  flex: 1;
}
.bar-header-unit {
  width: 80rpx;
  font-size: 20rpx;
  font-weight: 700;
  color: var(--text-muted);
  text-align: right;
  flex-shrink: 0;
  letter-spacing: 0.1em;
  text-transform: uppercase;
}

.bar-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.bar-label {
  font-size: 22rpx;
  font-weight: 600;
  width: 100rpx;
  flex-shrink: 0;
}

.bar-track {
  flex: 1;
  height: 16rpx;
  border-radius: 8rpx;
  overflow: hidden;
}

.bar-fill {
  height: 100%;
  background: var(--primary);
  border-radius: 8rpx;
  transition: width 0.5s ease;
}

.bar-value {
  font-size: 22rpx;
  font-weight: 600;
  width: 80rpx;
  text-align: right;
  flex-shrink: 0;
}

/* ========================
   Muscle Distribution — Day
   ======================== */
.page.theme-day .muscle-legend-name {
  color: #71717a;
}

/* ========================
   Muscle Distribution — Night
   ======================== */
.page.theme-night .muscle-legend-name {
  color: #d4d4d8;
}

/* ========================
   Muscle Distribution (shared)
   ======================== */
.muscle-chart-wrap {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 8rpx;
  width: 100%;
}

.pie-chart-canvas {
  width: 120px;
  height: 120px;
}

.muscle-legend {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.muscle-legend-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.muscle-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.muscle-legend-name {
  font-size: 24rpx;
  font-weight: 600;
  flex: 1;
  text-transform: uppercase;
  letter-spacing: 0.04em;
}

.muscle-legend-val {
  font-size: 20rpx;
  font-weight: 600;
  color: #71717a;
}

/* ========================
   Most Trained — Day
   ======================== */
.page.theme-day .freq-item {
  background: rgba(0, 0, 0, 0.04);
}

.page.theme-day .freq-name {
  color: #1a1a1a;
}

.page.theme-day .freq-count {
  color: #71717a;
}

/* ========================
   Most Trained — Night
   ======================== */
.page.theme-night .freq-item {
  background: rgba(255, 255, 255, 0.04);
}

.page.theme-night .freq-name {
  color: #fff;
}

.page.theme-night .freq-count {
  color: #71717a;
}

/* ========================
   Most Trained (shared)
   ======================== */
.freq-list {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  margin-top: 8rpx;
}

.freq-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14rpx 16rpx;
  border-radius: 12rpx;
}

.freq-name {
  font-size: 26rpx;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.04em;
  flex: 1;
}

.freq-count {
  font-size: 22rpx;
  font-weight: 600;
}

/* ========================
   Exercise Selector — Day
   ======================== */
.page.theme-day .select-wrap {
  background: rgba(0, 0, 0, 0.05);
  border: 1rpx solid rgba(0, 0, 0, 0.10);
}

.page.theme-day .select-label {
