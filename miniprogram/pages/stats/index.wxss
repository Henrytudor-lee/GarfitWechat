  color: #71717a;
}

/* ========================
   Loading State — Night
   ======================== */
.page.theme-night .loading-text {
  color: #71717a;
}

/* ========================
   Loading State (shared)
   ======================== */
.loading-state {
  display: flex;
  justify-content: center;
  padding: 40rpx;
}

.loading-text {
  font-size: 24rpx;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.1em;
}
