<!--pages/stats/index.wxml—garcia-fitness-new style with charts-->
<view class="page {{theme === 'day' ? 'theme-day' : 'theme-night'}}">

  <!-- Top App Bar -->
  <appbar theme="{{theme}}" />

  <!-- Header -->
  <view class="page-header">
    <view class="page-title-text">{{t.STATS}}</view>
    <view class="page-subtitle-text">{{t.YOUR_PERFORMANCE_DATA}}</view>
  </view>

  <!-- Summary Stats Row -->
  <view wx:if="{{hasData}}" class="stats-grid">
    <view class="stat-card">
      <image class="stat-card-icon" src="{{imgPrefix}}/icons/icon-calendar.png" mode="aspectFit" />
      <view class="stat-card-value">{{totalSessions}}</view>
      <view class="stat-card-label">{{t.SESSIONS}}</view>
    </view>
    <view class="stat-card">
      <image class="stat-card-icon" src="{{imgPrefix}}/icons/icon-flame.png" mode="aspectFit" />
      <view class="stat-card-value">{{currentStreak}}</view>
      <view class="stat-card-label">{{t.STREAK}}</view>
    </view>
    <view class="stat-card">
      <image class="stat-card-icon" src="{{imgPrefix}}/icons/icon-activity.png" mode="aspectFit" />
      <view class="stat-card-value">{{weekWorkouts}}</view>
      <view class="stat-card-label">{{t.SESSIONS_THIS_WEEK}}</view>
    </view>
    <view class="stat-card">
      <image class="stat-card-icon" src="{{imgPrefix}}/icons/icon-dumbbell.png" mode="aspectFit" />
      <view class="stat-card-value stat-card-value-small">{{totalVolumeDisplay}} <text class="unit">{{t.CAL_UNIT_SHORT}}</text></view>
      <view class="stat-card-label">{{t.CAL_UNIT}}</view>
    </view>
  </view>

  <!-- Exercise Leaderboard -->
  <view class="glass-card chart-card lb-card">
    <view class="lb-badge">{{t.EXERCISE_LEADERBOARD}}</view>
    <view class="lb-title-row">
      <view class="lb-toggles">
        <!-- Type: segmented pill -->
        <view class="lb-type-toggle">
          <view class="lb-type-btn {{lbType === 'calories' ? 'active' : ''}}" bindtap="onLbTypeTap" data-type="calories">{{t.LB_CALORIES}}</view>
          <view class="lb-type-btn {{lbType === 'volume' ? 'active' : ''}}" bindtap="onLbTypeTap" data-type="volume">{{t.LB_VOLUME}}</view>
        </view>
        <!-- Period: small pills -->
        <view class="lb-period-toggle">
          <view class="lb-period-btn {{lbPeriod === 'year' ? 'active' : ''}}" bindtap="onLbPeriodTap" data-period="year">{{t.LB_YEAR}}</view>
          <view class="lb-period-btn {{lbPeriod === 'month' ? 'active' : ''}}" bindtap="onLbPeriodTap" data-period="month">{{t.LB_MONTH}}</view>
          <view class="lb-period-btn {{lbPeriod === 'day' ? 'active' : ''}}" bindtap="onLbPeriodTap" data-period="day">{{t.LB_DAY}}</view>
        </view>
      </view>
    </view>

    <view wx:if="{{leaderboard.length > 0}}" class="lb-body">
      <view class="lb-header">
        <text class="lb-header-rank">{{t.RANK}}</text>
        <text class="lb-header-name"></text>
        <text class="lb-header-cal">{{lbType === 'volume' ? 'KG' : t.CAL_UNIT_SHORT}}</text>
      </view>
      <view class="lb-rows">
        <view class="lb-row" wx:for="{{leaderboard}}" wx:key="rank">
          <view class="lb-rank {{item.rank === 1 ? 'gold' : item.rank === 2 ? 'silver' : item.rank === 3 ? 'bronze' : ''}}">{{item.rank}}</view>
          <image wx:if="{{item.avatar}}" class="lb-avatar" src="{{item.avatar}}" mode="aspectFill" />
          <view wx:else class="lb-avatar lb-avatar-placeholder">👤</view>
          <view class="lb-info">
            <text class="lb-name">{{item.name}}</text>
            <view class="lb-track">
              <view class="lb-fill" style="width: {{item.percent}}%"></view>
            </view>
          </view>
          <text class="lb-cal">{{item.valueDisplay}}</text>
        </view>
      </view>
    </view>
    <view wx:else class="lb-empty">{{t.NO_TRAINING_DATA_YET}}</view>
  </view>

  <!-- Weekly Volume Bar Chart — last 8 weeks -->
  <view wx:if="{{weeklyVolume.length > 0}}" class="glass-card chart-card">
    <view class="section-title">{{t.WEEKLY_TRAINING_VOLUME}}</view>
    <view class="section-subtitle">{{t.LAST_8_WEEKS}}</view>
    <view class="bar-header">
      <text class="bar-header-label"></text>
      <view class="bar-header-track"></view>
      <text class="bar-header-unit">{{t.CAL_UNIT_SHORT}}</text>
    </view>
    <view class="bar-rows">
      <view class="bar-row" wx:for="{{weeklyVolume}}" wx:key="yrweek">
        <text class="bar-label">{{item.label}}</text>
        <view class="bar-track">
          <view class="bar-fill" style="width: {{item.percent}}%"></view>
        </view>
        <text class="bar-value">{{item.volumeDisplay}}</text>
      </view>
    </view>
  </view>

  <!-- Muscle Distribution -->
  <view wx:if="{{muscleDistribution.length > 0}}" class="glass-card chart-card">
    <view class="section-title">{{t.MUSCLE_DISTRIBUTION}}</view>
    <view class="muscle-chart-wrap">
      <image wx:if="{{muscleChartImage}}" src="{{muscleChartImage}}" class="pie-chart-canvas" mode="aspectFit" />
      <canvas wx:else id="muscleChart" type="2d" class="pie-chart-canvas" />
      <view class="muscle-legend">
        <view class="muscle-legend-item" wx:for="{{muscleDistribution}}" wx:key="name">
          <view class="muscle-dot" style="background: {{item.color}}"></view>
          <text class="muscle-legend-name">{{item.name}}</text>
          <text class="muscle-legend-val">{{item.valueDisplay}} <text class="unit">{{t.CAL_UNIT_SHORT}}</text></text>
        </view>
      </view>
    </view>
  </view>

  <!-- Most Trained Exercises -->
  <view wx:if="{{mostTrained.length > 0}}" class="glass-card chart-card">
    <view class="section-title">{{t.MOST_TRAINED}}</view>
    <view class="freq-list">
      <view class="freq-item" wx:for="{{mostTrained}}" wx:key="name">
        <text class="freq-name">{{item.name}}</text>
        <text class="freq-count">{{item.count}} {{t.SETS}}</text>
      </view>
    </view>
  </view>

  <!-- Exercise Selector -->
  <view class="glass-card select-wrap">
    <view class="select-header">
      <text class="select-label">{{t.EXERCISE_MAX_RECORD}}</text>
    </view>
    <picker mode="selector" range="{{exerciseList}}" range-key="name" bindchange="onExerciseChange">
      <view class="select-display">
        <text class="{{selectedExerciseName ? 'select-text-active' : 'select-text-placeholder'}}">
          {{selectedExerciseName || t.CHOOSE_EXERCISE}}
        </text>
        <text class="select-arrow">›</text>
      </view>
    </picker>
  </view>

  <!-- No data state -->
  <view wx:if="{{!hasData && !loading}}" class="empty-state">
    <image class="empty-icon" src="{{imgPrefix}}/icons/icon-chart.png" mode="aspectFit" />
    <text class="empty-text">{{t.NO_TRAINING_DATA_YET}}</text>
    <text class="empty-subtext">{{t.START_A_WORKOUT_TO_SEE_YOUR_STATS}}</text>
  </view>

  <!-- Max Record Cards -->
  <view wx:if="{{maxRecord}}" class="max-record-grid">
    <view class="max-record-card">
      <image class="max-record-icon" src="{{imgPrefix}}/icons/icon-target.png" mode="aspectFit" />
      <view class="max-record-num">{{maxRecord.weight}}</view>
      <view class="max-record-unit">{{t.KG}}</view>
    </view>
    <view class="max-record-card">
      <image class="max-record-icon" src="{{imgPrefix}}/icons/icon-chart.png" mode="aspectFit" />
      <view class="max-record-num">{{maxRecord.reps}}</view>
      <view class="max-record-unit">{{t.REPS}}</view>
    </view>
    <view class="max-record-card">
      <image class="max-record-icon" src="{{imgPrefix}}/icons/icon-check.png" mode="aspectFit" />
      <view class="max-record-num">{{maxRecord.totalSets}}</view>
      <view class="max-record-unit">{{t.TOTAL_SETS}}</view>
    </view>
  </view>

  <!-- Weight Progress Chart -->
  <view wx:if="{{weightRecords.length > 0}}" class="glass-card chart-card">
    <view class="section-title">{{t.WEIGHT_PROGRESS}}</view>
    <view class="section-subtitle">{{weightRecords.length}} {{t.RECORDS}}</view>
    <image wx:if="{{weightChartImage}}" src="{{weightChartImage}}" class="weight-chart-canvas" mode="aspectFit" />
    <canvas wx:else id="weightChart" type="2d" class="weight-chart-canvas" />
  </view>

  <!-- Loading -->
  <view wx:if="{{loading}}" class="loading-state">
    <text class="loading-text">{{t.LOADING}}</text>
  </view>

  <!-- Custom Tab Bar -->
  <custom-tabbar active="stats" theme="{{theme}}" />

  <!-- Session Orb -->
  <session-orb session="{{orbSession}}" theme="{{theme}}" bind:orb-tap="onOrbTap" />

</view>