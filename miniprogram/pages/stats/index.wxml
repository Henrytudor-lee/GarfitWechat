<!--pages/stats/index.wxml—garcia-fitness-new style-->
<view class="page">

  <!-- Top App Bar -->
  <appbar />

  <!-- Header -->
  <view class="page-header">
    <view class="page-title-text">STATS</view>
    <view class="page-subtitle-text">YOUR PERFORMANCE DATA</view>
  </view>

  <!-- Summary Stats -->
  <view class="stats-grid">
    <view class="stat-card">
      <view class="stat-card-value">{{stats.totalWorkouts || 0}}</view>
      <view class="stat-card-label">SESSIONS</view>
    </view>
    <view class="stat-card">
      <view class="stat-card-value">{{stats.currentStreak || 0}}</view>
      <view class="stat-card-label">STREAK</view>
    </view>
    <view class="stat-card">
      <view class="stat-card-value">{{stats.weekWorkouts || 0}}</view>
      <view class="stat-card-label">THIS WEEK</view>
    </view>
    <view class="stat-card">
      <view class="stat-card-value stat-card-value-small">{{stats.totalVolume || 0}}</view>
      <view class="stat-card-label">TOTAL KG</view>
    </view>
  </view>

  <!-- Exercise Selector -->
  <view class="select-wrap">
    <view class="select-label">EXERCISE MAX RECORD</view>
    <picker mode="selector" range="{{exerciseList}}" range-key="name" bindchange="onExerciseChange">
      <view class="select-display">
        <text>{{selectedExerciseName || '— CHOOSE EXERCISE —'}}</text>
        <text class="select-arrow">›</text>
      </view>
    </picker>
  </view>

  <!-- No data -->
  <view wx:if="{{exerciseList.length === 0}}" class="empty-state">
    <text class="empty-icon">📊</text>
    <text>NO TRAINING DATA YET</text>
  </view>

  <!-- Max Record -->
  <view wx:if="{{maxRecord}}" class="max-card">
    <view class="section-title">MAX RECORD</view>
    <view class="max-card-grid">
      <view class="max-item">
        <view class="max-num">{{maxRecord.weight}}</view>
        <view class="max-label">KG</view>
      </view>
      <view class="max-item">
        <view class="max-num">{{maxRecord.reps}}</view>
        <view class="max-label">REPS</view>
      </view>
      <view class="max-item">
        <view class="max-num">{{maxRecord.totalSets}}</view>
        <view class="max-label">TOTAL SETS</view>
      </view>
    </view>
  </view>

  <!-- Weekly Volume Bar Chart — last 7 days -->
  <view wx:if="{{weeklyVolume.length > 0}}" class="bar-chart">
    <view class="section-title">WEEKLY VOLUME</view>
    <view class="bar-rows">
      <view class="bar-row" wx:for="{{weeklyVolume}}" wx:key="day">
        <text class="bar-label">{{item.label}}</text>
        <view class="bar-track">
          <view class="bar-fill" style="width: {{item.percent}}%"></view>
        </view>
        <text class="bar-value">{{item.volume}}kg</text>
      </view>
    </view>
  </view>

  <!-- Most Trained Muscle Groups -->
  <view wx:if="{{mostTrained.length > 0}}" class="muscle-list">
    <view class="section-title">MOST TRAINED</view>
    <view class="muscle-items">
      <view class="muscle-item" wx:for="{{mostTrained}}" wx:key="name">
        <text class="muscle-name">{{item.name}}</text>
        <text class="muscle-count">{{item.count}} sessions</text>
      </view>
    </view>
  </view>

  <!-- Custom Tab Bar -->
  <custom-tabbar active="stats" />

</view>
