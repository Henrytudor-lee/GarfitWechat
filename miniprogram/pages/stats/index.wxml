<!--pages/stats/index.wxml—garcia-fitness-new style with charts-->
<view class="page">

  <!-- Top App Bar -->
  <appbar />

  <!-- Header -->
  <view class="page-header">
    <view class="page-title-text">STATS</view>
    <view class="page-subtitle-text">YOUR PERFORMANCE DATA</view>
  </view>

  <!-- Summary Stats Row -->
  <view wx:if="{{hasData}}" class="stats-grid">
    <view class="stat-card">
      <image class="stat-card-icon" src="{{imgPrefix}}/images/icons/icon-calendar.svg" mode="aspectFit" />
      <view class="stat-card-value">{{totalSessions}}</view>
      <view class="stat-card-label">SESSIONS</view>
    </view>
    <view class="stat-card">
      <image class="stat-card-icon" src="{{imgPrefix}}/images/icons/icon-flame.svg" mode="aspectFit" />
      <view class="stat-card-value">{{currentStreak}}</view>
      <view class="stat-card-label">STREAK</view>
    </view>
    <view class="stat-card">
      <image class="stat-card-icon" src="{{imgPrefix}}/images/icons/icon-activity.svg" mode="aspectFit" />
      <view class="stat-card-value">{{weekWorkouts}}</view>
      <view class="stat-card-label">THIS WEEK</view>
    </view>
    <view class="stat-card">
      <image class="stat-card-icon" src="{{imgPrefix}}/images/icons/icon-dumbbell.svg" mode="aspectFit" />
      <view class="stat-card-value stat-card-value-small">{{totalVolume}}kg</view>
      <view class="stat-card-label">TOTAL VOLUME</view>
    </view>
  </view>

  <!-- Weekly Volume Bar Chart — last 8 weeks -->
  <view wx:if="{{weeklyVolume.length > 0}}" class="glass-card chart-card">
    <view class="section-title">WEEKLY VOLUME</view>
    <view class="section-subtitle">LAST 8 WEEKS</view>
    <view class="bar-rows">
      <view class="bar-row" wx:for="{{weeklyVolume}}" wx:key="iso">
        <text class="bar-label">{{item.label}}</text>
        <view class="bar-track">
          <view class="bar-fill" style="width: {{item.percent}}%"></view>
        </view>
        <text class="bar-value">{{item.volume}}kg</text>
      </view>
    </view>
  </view>

  <!-- Muscle Distribution -->
  <view wx:if="{{muscleDistribution.length > 0}}" class="glass-card chart-card">
    <view class="section-title">MUSCLE DISTRIBUTION</view>
    <view class="muscle-chart-wrap">
      <canvas canvas-id="muscleChart" class="pie-chart-canvas" />
      <view class="muscle-legend">
        <view class="muscle-legend-item" wx:for="{{muscleDistribution}}" wx:key="name">
          <view class="muscle-dot" style="background: {{item.color}}"></view>
          <text class="muscle-legend-name">{{item.name}}</text>
          <text class="muscle-legend-val">{{item.value}}kg</text>
        </view>
      </view>
    </view>
  </view>

  <!-- Most Trained Exercises -->
  <view wx:if="{{mostTrained.length > 0}}" class="glass-card chart-card">
    <view class="section-title">MOST TRAINED</view>
    <view class="freq-list">
      <view class="freq-item" wx:for="{{mostTrained}}" wx:key="name">
        <text class="freq-name">{{item.name}}</text>
        <text class="freq-count">{{item.count}} SETS</text>
      </view>
    </view>
  </view>

  <!-- Exercise Selector -->
  <view class="glass-card select-wrap">
    <view class="select-header">
      <text class="select-label">EXERCISE MAX RECORD</text>
    </view>
    <picker mode="selector" range="{{exerciseList}}" range-key="name" bindchange="onExerciseChange">
      <view class="select-display">
        <text class="{{selectedExerciseName ? 'select-text-active' : 'select-text-placeholder'}}">
          {{selectedExerciseName || '— CHOOSE EXERCISE —'}}
        </text>
        <text class="select-arrow">›</text>
      </view>
    </picker>
  </view>

  <!-- No data state -->
  <view wx:if="{{!hasData && !loading}}" class="empty-state">
    <image class="empty-icon" src="{{imgPrefix}}/images/icons/icon-chart.svg" mode="aspectFit" />
    <text class="empty-text">NO TRAINING DATA YET</text>
    <text class="empty-subtext">Start a workout to see your stats</text>
  </view>

  <!-- Max Record Cards -->
  <view wx:if="{{maxRecord}}" class="max-record-grid">
    <view class="max-record-card">
      <image class="max-record-icon" src="{{imgPrefix}}/images/icons/icon-target.svg" mode="aspectFit" />
      <view class="max-record-num">{{maxRecord.weight}}</view>
      <view class="max-record-unit">KG</view>
    </view>
    <view class="max-record-card">
      <image class="max-record-icon" src="{{imgPrefix}}/images/icons/icon-chart.svg" mode="aspectFit" />
      <view class="max-record-num">{{maxRecord.reps}}</view>
      <view class="max-record-unit">REPS</view>
    </view>
    <view class="max-record-card">
      <image class="max-record-icon" src="{{imgPrefix}}/images/icons/icon-check.svg" mode="aspectFit" />
      <view class="max-record-num">{{maxRecord.totalSets}}</view>
      <view class="max-record-unit">TOTAL SETS</view>
    </view>
  </view>

  <!-- Weight Progress Chart -->
  <view wx:if="{{weightRecords.length > 0}}" class="glass-card chart-card">
    <view class="section-title">WEIGHT PROGRESS</view>
    <view class="section-subtitle">{{weightRecords.length}} RECORDS</view>
    <canvas canvas-id="weightChart" class="weight-chart-canvas" />
  </view>

  <!-- Loading -->
  <view wx:if="{{loading}}" class="loading-state">
    <text class="loading-text">LOADING...</text>
  </view>

  <!-- Custom Tab Bar -->
  <custom-tabbar active="stats" />

</view>
