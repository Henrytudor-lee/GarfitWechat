<!--components/custom-end-confirm-modal/index.wxml-->
<view class="modal-mask {{_theme === 'day' ? 'theme-day' : 'theme-night'}}" wx:if="{{isOpen}}" bindtap="onMaskTap">
  <view class="modal-card" catchtap="">

    <!-- Background decoration -->
    <view class="card-bg"></view>
    <view class="bg-blob blob-1"></view>
    <view class="bg-blob blob-2"></view>

    <!-- Header -->
    <view class="card-header">
      <view class="brand-row">
        <image class="brand-logo" src="/images/logo.png" mode="aspectFit" />
        <view class="brand">GFIT</view>
      </view>
      <view class="confirm-label">{{t.CONFIRM_END_TRAINING}}</view>
    </view>

    <!-- Content -->
    <view class="content-body">
      <view class="content-text">{{t.ARE_YOU_SURE_END_TRAINING}}</view>
    </view>

    <!-- Action Buttons -->
    <view class="card-footer">
      <button class="btn-secondary" bindtap="cancelConfirm">{{t.CANCEL}}</button>
      <button class="btn-primary" bindtap="confirmEnd">{{t.CONFIRM}}</button>
    </view>

  </view>
</view>