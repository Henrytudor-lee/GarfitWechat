/* components/custom-end-confirm-modal/index.wxss */

/* Modal Mask */
.modal-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.75);
  backdrop-filter: blur(8rpx);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  padding: 40rpx;
}

/* Day theme overrides */
.modal-mask.theme-day {
  background: rgba(0, 0, 0, 0.5);
}

/* Card */
.modal-card {
  position: relative;
  width: 100%;
  max-width: 600rpx;
  background: #111111;
  border-radius: 32rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

/* Day theme card */
.theme-day .modal-card {
  background: #ffffff;
}

/* Background gradient */
.card-bg {
  position: absolute;
  inset: 0;
  background: linear-gradient(160deg, #1a1a2e 0%, #16213e 40%, #0f3460 70%, #1a1a2e 100%);
  pointer-events: none;
}

.theme-day .card-bg {
  background: linear-gradient(160deg, #f5f5f5 0%, #ffffff 50%, #f0f0f0 100%);
}

/* Decorative blobs */
.bg-blob {
  position: absolute;
  border-radius: 50%;
  pointer-events: none;
}

.blob-1 {
  top: -60rpx;
  right: -40rpx;
  width: 200rpx;
  height: 200rpx;
  background: radial-gradient(circle, rgba(204, 242, 0, 0.15) 0%, transparent 70%);
}

.theme-day .blob-1 {
  background: radial-gradient(circle, rgba(0, 100, 0, 0.1) 0%, transparent 70%);
}

.blob-2 {
  bottom: 40rpx;
  left: -30rpx;
  width: 160rpx;
  height: 160rpx;
  background: radial-gradient(circle, rgba(139, 195, 74, 0.1) 0%, transparent 70%);
}

.theme-day .blob-2 {
  background: radial-gradient(circle, rgba(0, 100, 0, 0.08) 0%, transparent 70%);
}

/* Header */
.card-header {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 32rpx 24rpx;
}

.brand {
  font-family: 'Lexend Deca', 'Lexend', sans-serif;
  font-size: 28rpx;
  font-weight: 900;
  color: #ccf200;
  letter-spacing: 0.2em;
  margin-bottom: 24rpx;
}

.theme-day .brand {
  color: #006400;
}

.confirm-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #ccf200, #8bc34a);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
  font-size: 48rpx;
  color: #000;
  font-weight: 900;
}

.theme-day .confirm-icon {
  background: linear-gradient(135deg, #006400, #228b22);
  color: #fff;
}

.confirm-label {
  font-family: 'Lexend Deca', 'Lexend', sans-serif;
  font-size: 24rpx;
  font-weight: 800;
  color: rgba(255, 255, 255, 0.7);
  letter-spacing: 0.15em;
  text-transform: uppercase;
}

.theme-day .confirm-label {
  color: rgba(0, 0, 0, 0.6);
}

/* Content body */
.content-body {
  position: relative;
  z-index: 1;
  padding: 0 32rpx 24rpx;
}

.content-text {
  font-family: 'Lexend Deca', 'Lexend', sans-serif;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.7);
  text-align: center;
  line-height: 1.5;
}

.theme-day .content-text {
  color: rgba(0, 0, 0, 0.6);
}

/* Footer Buttons */
.card-footer {
  position: relative;
  z-index: 1;
  display: flex;
  gap: 16rpx;
  padding: 0 32rpx 32rpx;
}

.btn-primary,
.btn-secondary {
  flex: 1;
  height: 96rpx;
  border-radius: 100rpx;
  font-family: 'Lexend Deca', 'Lexend', sans-serif;
  font-size: 26rpx;
  font-weight: 900;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-primary {
  background: linear-gradient(135deg, #ccf200, #8bc34a);
  color: #000;
}

.theme-day .btn-primary {
  background: linear-gradient(135deg, #006400, #228b22);
  color: #fff;
}

.btn-secondary {
  background: rgba(255, 255, 255, 0.1);
  color: #fff;
}

.theme-day .btn-secondary {
  background: rgba(0, 0, 0, 0.08);
  color: #000;
}

.btn-primary::after,
.btn-secondary::after {
  border: none;
}