/* components/session-orb/index.wxss — cover-view 版本 */
/* 注: cover-view 不支持 conic-gradient / mask, 所以原旋转光圈改为静态圆环 */

.session-orb {
  position: fixed;
  /* left/top 由 inline style 控制 */
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  z-index: 1500;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: 'Lexend Deca', 'Lexend', sans-serif;
  -webkit-tap-highlight-color: transparent;
  overflow: visible;
  transform-origin: center center;
  will-change: transform, left, top;
  /* 松手后吸附动画 (cover-view 支持 transition) */
  transition: left 0.25s cubic-bezier(0.16, 1, 0.3, 1);
}

/* === idle: lime 圆 + logo (无动画) === */
.session-orb.idle {
  background: var(--primary);
  border: 2rpx solid var(--primary);
}

.session-orb.idle .orb-content {
  display: flex;
  align-items: center;
  justify-content: center;
}

.orb-logo-idle {
  width: 70rpx;
  height: 70rpx;
  /* cover-image 支持 filter, 反色以增加对比 */
  filter: invert(1);
}

/* === active: 深色圆 + logo + duration === */
.session-orb.active {
  background: var(--surface-high);
  /* 静态圆环代替原旋转光圈: 内层深色, 外层 lime border
     (cover-view 不支持 conic-gradient, 用 border + inset 阴影模拟) */
  border: 4rpx solid var(--primary);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.3);
}

.orb-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  pointer-events: none;
}

.orb-logo {
  width: 50rpx;
  height: 50rpx;
  margin-bottom: 2rpx;
}

.orb-time {
  font-size: 18rpx;
  font-weight: 800;
  color: var(--primary);
  letter-spacing: 0.02em;
  line-height: 1;
  font-variant-numeric: tabular-nums;
}

/* === tap 反馈 (按下时缩小) === */
.orb-tap {
  transform: scale(0.92) !important;
}

/* === day 主题微调 === */
.page.theme-day .session-orb.idle {
  border-color: var(--primary);
}
.page.theme-day .session-orb.active {
  background: #ffffff;
  border-color: var(--primary);
}
.page.theme-day .orb-logo-idle {
  /* day 主题: 不反色 */
  filter: none;
}
