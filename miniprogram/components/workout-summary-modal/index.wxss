/* components/workout-summary-modal/index.wxss */

/* Modal Mask */
.modal-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.75);
  backdrop-filter: blur(8rpx);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  padding: 40rpx;
}

/* Card */
.modal-card {
  position: relative;
  width: 100%;
  max-width: 680rpx;
  background: #111111;
  border-radius: 32rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

/* Background gradient */
.card-bg {
  position: absolute;
  inset: 0;
  background: linear-gradient(160deg, #1a1a2e 0%, #16213e 40%, #0f3460 70%, #1a1a2e 100%);
  pointer-events: none;
}

/* Decorative blobs */
.bg-blob {
  position: absolute;
  border-radius: 50%;
  pointer-events: none;
}
.blob-1 {
  top: -60rpx;
  right: -40rpx;
  width: 200rpx;
  height: 200rpx;
  background: radial-gradient(circle, rgba(204, 242, 0, 0.15) 0%, transparent 70%);
}
.blob-2 {
  bottom: 40rpx;
  left: -30rpx;
  width: 160rpx;
  height: 160rpx;
  background: radial-gradient(circle, rgba(139, 195, 74, 0.1) 0%, transparent 70%);
}

/* Header */
.card-header {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 32rpx 24rpx;
}

.brand {
  font-family: 'Lexend Deca', 'Lexend', sans-serif;
  font-size: 28rpx;
  font-weight: 900;
  color: #ccf200;
  letter-spacing: 0.2em;
  margin-bottom: 24rpx;
}

.check-circle {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #ccf200, #8bc34a);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
}

.check-icon {
  font-size: 48rpx;
  color: #000;
  font-weight: 900;
  line-height: 1;
}

.complete-label {
  font-family: 'Lexend Deca', 'Lexend', sans-serif;
  font-size: 24rpx;
  font-weight: 800;
  color: rgba(255, 255, 255, 0.7);
  letter-spacing: 0.15em;
  text-transform: uppercase;
}

/* Stats Row */
.stats-row {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 32rpx 24rpx;
  gap: 0;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  background: rgba(255, 255, 255, 0.08);
  backdrop-filter: blur(12rpx);
  border-radius: 16rpx;
  padding: 20rpx 16rpx;
}

.stat-sep {
  width: 1rpx;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.1);
  margin: 0 8rpx;
  flex-shrink: 0;
}

.stat-val {
  font-family: 'Lexend Deca', 'Lexend', sans-serif;
  font-size: 36rpx;
  font-weight: 900;
  color: #fff;
  line-height: 1;
}

.stat-lbl {
  font-size: 16rpx;
  font-weight: 800;
  color: rgba(255, 255, 255, 0.4);
  letter-spacing: 0.1em;
  text-transform: uppercase;
  margin-top: 4rpx;
}

/* Divider */
.divider {
  position: relative;
  z-index: 1;
  height: 1rpx;
  background: rgba(255, 255, 255, 0.1);
  margin: 0 32rpx;
}

/* Breakdown */
.breakdown-title {
  position: relative;
  z-index: 1;
  font-size: 18rpx;
  font-weight: 800;
  color: rgba(255, 255, 255, 0.3);
  letter-spacing: 0.15em;
  text-transform: uppercase;
  padding: 24rpx 32rpx 12rpx;
}

.breakdown-scroll {
  position: relative;
  z-index: 1;
  flex: 1;
  max-height: 400rpx;
}

.breakdown-list {
  padding: 0 32rpx 16rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.breakdown-item {
  background: rgba(255, 255, 255, 0.05);
  border-radius: 16rpx;
  overflow: hidden;
}

.item-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx;
}

.item-img {
  width: 64rpx;
  height: 64rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  object-fit: cover;
  background: rgba(255, 255, 255, 0.08);
}

.item-img-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.item-info {
  flex: 1;
  min-width: 0;
}

.item-name {
  font-family: 'Lexend Deca', 'Lexend', sans-serif;
  font-size: 26rpx;
  font-weight: 800;
  color: #fff;
  text-transform: uppercase;
  letter-spacing: 0.02em;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.item-sets {
  font-size: 18rpx;
  color: rgba(255, 255, 255, 0.4);
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  margin-top: 2rpx;
}

.item-vol {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
  flex-shrink: 0;
}

.vol-num {
  font-family: 'Lexend Deca', 'Lexend', sans-serif;
  font-size: 28rpx;
  font-weight: 900;
  color: #ccf200;
}

.vol-unit {
  font-size: 18rpx;
  font-weight: 700;
  color: rgba(204, 242, 0, 0.6);
}

/* Sets Grid - 2 columns using grid */
.sets-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8rpx;
  padding: 0 16rpx 16rpx;
}

.set-chip {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 8rpx;
  padding: 12rpx;
  min-width: 0;
}

.set-num {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  background: rgba(204, 242, 0, 0.2);
  color: #ccf200;
  font-size: 18rpx;
  font-weight: 900;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.set-val {
  font-size: 20rpx;
  font-weight: 700;
  color: #fff;
  flex: 1;
}

.set-sep {
  font-size: 18rpx;
  color: rgba(255, 255, 255, 0.3);
}

.set-reps {
  font-size: 18rpx;
  font-weight: 700;
  color: rgba(255, 255, 255, 0.5);
  flex-shrink: 0;
}

/* Date Footer */
.date-footer {
  position: relative;
  z-index: 1;
  text-align: center;
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.25);
  letter-spacing: 0.1em;
  padding: 16rpx 32rpx;
}

/* Footer Buttons */
.card-footer {
  position: relative;
  z-index: 1;
  display: flex;
  gap: 16rpx;
  padding: 0 32rpx 32rpx;
}

.btn-primary,
.btn-secondary {
  flex: 1;
  height: 96rpx;
  border-radius: 100rpx;
  font-family: 'Lexend Deca', 'Lexend', sans-serif;
  font-size: 26rpx;
  font-weight: 900;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-primary {
  background: linear-gradient(135deg, #ccf200, #8bc34a);
  color: #000;
}

.btn-secondary {
  background: rgba(255, 255, 255, 0.1);
  color: #fff;
}

.btn-primary::after,
.btn-secondary::after {
  border: none;
}
