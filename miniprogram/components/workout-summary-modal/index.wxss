/* components/workout-summary-modal/index.wxss */

/* Modal Mask */
.modal-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.75);
  backdrop-filter: blur(8rpx);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  padding: 40rpx;
}

/* Card */
.modal-card {
  position: relative;
  width: 100%;
  max-width: 680rpx;
  background: #111111;
  border-radius: 32rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.theme-day .modal-card {
  background: #ffffff;
}

/* Background gradient */
.card-bg {
  position: absolute;
  inset: 0;
  background: linear-gradient(160deg, #1a1a2e 0%, #16213e 40%, #0f3460 70%, #1a1a2e 100%);
  pointer-events: none;
}

.theme-day .card-bg {
  background: linear-gradient(160deg, #f5f5f5 0%, #ffffff 50%, #f0f0f0 100%);
}

/* Decorative blobs */
.bg-blob {
  position: absolute;
  border-radius: 50%;
  pointer-events: none;
}
.blob-1 {
  top: -60rpx;
  right: -40rpx;
  width: 200rpx;
  height: 200rpx;
  background: radial-gradient(circle, rgba(204, 242, 0, 0.15) 0%, transparent 70%);
}
.blob-2 {
  bottom: 40rpx;
  left: -30rpx;
  width: 160rpx;
  height: 160rpx;
  background: radial-gradient(circle, rgba(139, 195, 74, 0.1) 0%, transparent 70%);
}

/* Header */
.card-header {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 32rpx 24rpx;
}

.brand-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.brand-logo {
  width: 48rpx;
  height: 48rpx;
}

.brand {
  font-family: 'Lexend Deca', 'Lexend', sans-serif;
  font-size: 28rpx;
  font-weight: 900;
  color: var(--primary-text);
  letter-spacing: 0.2em;
}

.theme-day .brand {
  color: #006400;
}

.check-circle {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--primary), #8bc34a);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
}

.theme-day .check-circle {
  background: linear-gradient(135deg, #006400, #228b22);
}

.check-icon {
  font-size: 24rpx;
  color: #000;
  font-weight: 900;
  line-height: 1;
}

.complete-label {
  font-family: 'Lexend Deca', 'Lexend', sans-serif;
  font-size: 24rpx;
  font-weight: 800;
  color: var(--primary-text);
  letter-spacing: 0.15em;
  text-transform: uppercase;
}

.theme-day .complete-label {
  color: #006400;
}

/* Stats Row */
.stats-row {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 32rpx 24rpx;
  gap: 0;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  background: rgba(255, 255, 255, 0.08);
  backdrop-filter: blur(12rpx);
  border-radius: 16rpx;
  padding: 20rpx 16rpx;
}

.stat-sep {
  width: 1rpx;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.1);
  margin: 0 8rpx;
  flex-shrink: 0;
}

.stat-val {
  font-family: 'Lexend Deca', 'Lexend', sans-serif;
  font-size: 36rpx;
  font-weight: 900;
  color: #fff;
  line-height: 1;
  white-space: nowrap;
  max-width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* 中间时长在中文模式下可能装不下 (e.g. "12小时55分钟"), 缩小字号适配 */
.stat-duration .stat-val {
  font-size: 28rpx;
}

.stat-lbl {
  font-size: 16rpx;
  font-weight: 800;
  color: rgba(255, 255, 255, 0.4);
  letter-spacing: 0.1em;
  text-transform: uppercase;
  margin-top: 4rpx;
}

/* Divider */
.divider {
  position: relative;
  z-index: 1;
  height: 1rpx;
  background: rgba(255, 255, 255, 0.1);
  margin: 0 32rpx;
}

/* Breakdown */
.breakdown-title {
  position: relative;
  z-index: 1;
  font-size: 18rpx;
  font-weight: 800;
  color: rgba(255, 255, 255, 0.3);
  letter-spacing: 0.15em;
  text-transform: uppercase;
  padding: 24rpx 32rpx 12rpx;
}

.breakdown-scroll {
  position: relative;
  z-index: 1;
  flex: 1;
  max-height: 700rpx;
}

.breakdown-list {
  padding: 0 32rpx 16rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.breakdown-item {
  background: rgba(255, 255, 255, 0.05);
  border-radius: 16rpx;
  overflow: hidden;
}

.item-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx;
}

.item-img {
  width: 64rpx;
  height: 64rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  object-fit: cover;
  background: rgba(255, 255, 255, 0.08);
}

.item-img-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.item-info {
  flex: 1;
  min-width: 0;
}

.item-name {
  font-family: 'Lexend Deca', 'Lexend', sans-serif;
  font-size: 26rpx;
  font-weight: 800;
  color: #fff;
  text-transform: uppercase;
  letter-spacing: 0.02em;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.item-sets {
  font-size: 18rpx;
  color: rgba(255, 255, 255, 0.4);
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  margin-top: 2rpx;
}

.item-vol {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
  flex-shrink: 0;
}

.vol-num {
  font-family: 'Lexend Deca', 'Lexend', sans-serif;
  font-size: 28rpx;
  font-weight: 900;
  color: var(--primary-text);
}

.vol-unit {
  font-size: 18rpx;
  font-weight: 700;
  color: rgba(204, 242, 0, 0.6);
}

/* Sets Grid - 2 columns using grid */
.sets-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8rpx;
  padding: 0 16rpx 16rpx;
}

.set-chip {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 8rpx;
  padding: 12rpx;
  min-width: 0;
}

.set-num {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  background: rgba(204, 242, 0, 0.2);
  color: var(--primary-text);
  font-size: 18rpx;
  font-weight: 900;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.set-val {
  font-size: 20rpx;
  font-weight: 700;
  color: #fff;
  flex: 1;
}

.set-sep {
  font-size: 18rpx;
  color: rgba(255, 255, 255, 0.3);
}

.set-reps {
  font-size: 18rpx;
  font-weight: 700;
  color: rgba(255, 255, 255, 0.5);
  flex-shrink: 0;
}

/* Date Footer */
.date-footer {
  position: relative;
  z-index: 1;
  text-align: center;
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.25);
  letter-spacing: 0.1em;
  padding: 16rpx 32rpx;
}

/* Footer Buttons */
.card-footer {
  position: relative;
  z-index: 1;
  display: flex;
  gap: 16rpx;
  padding: 0 32rpx 32rpx;
}

.btn-primary,
.btn-secondary,
.btn-share {
  flex: 1;
  height: 80rpx;
  border-radius: 100rpx;
  font-family: 'Lexend Deca', 'Lexend', sans-serif;
  font-size: 22rpx;
  font-weight: 900;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-primary {
  background: linear-gradient(135deg, var(--primary), #8bc34a);
  color: #000;
}

.btn-secondary {
  background: rgba(255, 255, 255, 0.1);
  color: #fff;
}

.theme-day .btn-secondary {
  background: rgba(0, 0, 0, 0.08);
  color: #000;
}

.btn-share {
  background: linear-gradient(135deg, var(--primary), #8bc34a);
  color: #000;
}

.theme-day .btn-share {
  background: linear-gradient(135deg, #006400, #228b22);
  color: #fff;
}

.btn-primary::after,
.btn-secondary::after,
.btn-share::after {
  border: none;
}

/* Day theme: stat items */
.theme-day .stat-item {
  background: rgba(0, 0, 0, 0.05);
}

.theme-day .stat-val {
  color: #111111;
}

.theme-day .stat-lbl {
  color: rgba(0, 0, 0, 0.4);
}

/* Day theme: breakdown */
.theme-day .breakdown-title {
  color: rgba(0, 0, 0, 0.3);
}

.theme-day .divider {
  background: rgba(0, 0, 0, 0.1);
}

.theme-day .breakdown-item {
  background: rgba(0, 0, 0, 0.05);
}

.theme-day .item-name {
  color: #111111;
}

.theme-day .item-sets {
  color: rgba(0, 0, 0, 0.4);
}

.theme-day .item-vol {
  color: rgba(0, 0, 0, 0.4);
}

.theme-day .vol-num {
  color: #006400;
}

.theme-day .vol-unit {
  color: rgba(0, 100, 0, 0.6);
}

/* Day theme: set chip */
.theme-day .set-chip {
  background: rgba(0, 0, 0, 0.05);
}

.theme-day .set-num {
  background: rgba(0, 100, 0, 0.2);
  color: #006400;
}

.theme-day .set-val {
  color: #111111;
}

.theme-day .set-sep {
  color: rgba(0, 0, 0, 0.3);
}

.theme-day .set-reps {
  color: rgba(0, 0, 0, 0.5);
}

/* Day theme: date footer */
.theme-day .date-footer {
  color: rgba(0, 0, 0, 0.25);
}

/* Day theme: blob blobs */
.theme-day .blob-1 {
  background: radial-gradient(circle, rgba(0, 100, 0, 0.1) 0%, transparent 70%);
}

.theme-day .blob-2 {
  background: radial-gradient(circle, rgba(0, 100, 0, 0.08) 0%, transparent 70%);
}

/* Day theme: mask */
.theme-day .modal-mask {
  background: rgba(0, 0, 0, 0.5);
}

/* 兜底: WeChat 自定义组件样式隔离可能阻隔 page 上定义的 --primary-text 传过来,
   这里在组件自己的作用域内再定义一次, 保证颜色一定生效 */
.theme-day {
  --primary-text: #3a4a00;
  --primary-bg-soft: rgba(58, 74, 0, 0.15);
}

.theme-night {
  --primary-text: #ccf200;
  --primary-bg-soft: rgba(204, 242, 0, 0.15);
}
