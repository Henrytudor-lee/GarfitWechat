/* components/workout-summary-modal/index.wxss */

.modal-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.9);
  display: flex;
  flex-direction: column;
  z-index: 1000;
}

.modal-sheet {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  top: 0;
  background: #1A1A2E;
  border-radius: 32rpx 32rpx 0 0;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

/* Celebration Header */
.summary-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 32rpx 32rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.1);
  flex-shrink: 0;
}

.celebration-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.summary-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #E94560;
  letter-spacing: 4rpx;
  margin-bottom: 12rpx;
}

.summary-subtitle {
  font-size: 24rpx;
  color: #888;
  font-weight: 500;
}

/* Stats Grid */
.stats-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
  padding: 32rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.1);
  flex-shrink: 0;
}

.stat-card {
  background: rgba(255, 255, 255, 0.05);
  border-radius: 16rpx;
  padding: 32rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.stat-value {
  font-size: 48rpx;
  font-weight: 700;
  color: #fff;
}

.stat-label {
  font-size: 18rpx;
  font-weight: 700;
  color: #888;
  letter-spacing: 2rpx;
  text-transform: uppercase;
}

/* Breakdown Section */
.breakdown-section {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  padding: 0 32rpx;
}

.breakdown-title {
  font-size: 22rpx;
  font-weight: 700;
  color: #888;
  letter-spacing: 2rpx;
  text-transform: uppercase;
  padding: 24rpx 0;
  flex-shrink: 0;
}

.breakdown-list {
  flex: 1;
  overflow-y: auto;
}

.breakdown-item {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
}

.breakdown-item:last-child {
  border-bottom: none;
}

.item-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.item-img {
  width: 64rpx;
  height: 64rpx;
  border-radius: 10rpx;
  flex-shrink: 0;
}

.item-img-placeholder {
  background: #252540;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.item-text {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.item-name {
  font-size: 26rpx;
  font-weight: 700;
  color: #fff;
}

.item-sets-info {
  font-size: 20rpx;
  color: #888;
  font-weight: 500;
}

.item-summary {
  font-size: 22rpx;
  color: #aaa;
  padding-left: 80rpx;
  line-height: 1.5;
}

/* Modal Footer */
.modal-footer {
  display: flex;
  gap: 16rpx;
  padding: 32rpx;
  background: rgba(0, 0, 0, 0.9);
  border-top: 1rpx solid rgba(255, 255, 255, 0.1);
  flex-shrink: 0;
}

.btn-primary,
.btn-secondary {
  flex: 1;
  height: 96rpx;
  border-radius: 48rpx;
  font-size: 28rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  letter-spacing: 2rpx;
}

.btn-primary {
  background: #E94560;
  color: #fff;
}

.btn-secondary {
  background: rgba(255, 255, 255, 0.1);
  color: #aaa;
}

.btn-primary::after,
.btn-secondary::after {
  border: none;
}
