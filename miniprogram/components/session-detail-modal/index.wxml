<!--components/session-detail-modal/index.wxml-->
<view class="modal-mask" wx:if="{{isOpen && session}}" bindtap="onMaskTap">
  <view class="modal-sheet" catchtap="">

    <!-- Header -->
    <view class="modal-header">
      <view class="header-left">
        <view class="header-btn" bindtap="closeModal">✕</view>
      </view>
      <view class="header-title">{{locale === 'zh' ? '训练详情' : 'SESSION DETAIL'}}</view>
      <view class="header-right"></view>
    </view>

    <!-- Session Info -->
    <view class="session-info">
      <view class="session-date">{{session.dateStr || session.start_time}}</view>
      <view class="session-stats">
        <view class="stat-card">
          <view class="stat-val">{{_durationDisplay}}</view>
          <view class="stat-label">{{locale === 'zh' ? '时长' : 'DURATION'}}</view>
          <view class="stat-accent-bar"></view>
        </view>
        <view class="stat-card">
          <view class="stat-val">{{exerciseList.length}}</view>
          <view class="stat-label">{{locale === 'zh' ? '动作' : 'EXERCISES'}}</view>
          <view class="stat-accent-bar"></view>
        </view>
        <view class="stat-card">
          <view class="stat-val">{{getTotalSets(exerciseList)}}</view>
          <view class="stat-label">{{locale === 'zh' ? '组数' : 'SETS'}}</view>
          <view class="stat-accent-bar"></view>
        </view>
      </view>
    </view>

    <!-- Exercises List -->
    <scroll-view class="exercise-list" scroll-y>
      <view wx:if="{{loading}}" class="loading-state">{{locale === 'zh' ? '加载中...' : 'LOADING...'}}</view>
      <view wx:elif="{{exerciseList.length === 0}}" class="empty-state">{{locale === 'zh' ? '暂无动作记录' : 'NO EXERCISES RECORDED'}}</view>

      <view wx:else class="exercise-groups">
        <view class="ec-card" wx:for="{{exerciseList}}" wx:key="id">
          <!-- ec-header: image + name + sets + volume -->
          <view class="ec-header">
            <view class="ec-img-wrap">
              <image wx:if="{{item.image_name}}" class="ec-img" src="{{imgPrefix}}/{{item.image_name}}" mode="aspectFill" />
              <view wx:else class="ec-img-placeholder">🏋️</view>
            </view>
            <view class="ec-info">
              <view class="ec-name">{{item.name_zh || item.name}}</view>
              <view class="ec-sets-count">{{item.sets.length}} {{item.sets.length === 1 ? (locale === 'zh' ? '组' : 'set') : (locale === 'zh' ? '组' : 'sets')}}</view>
            </view>
            <view class="ec-volume">
              <view class="ec-vol-num">{{item.totalVolume || '—'}} {{item.sets[0] ? item.sets[0].weight_unit : 'kg'}}</view>
              <view class="ec-vol-label">{{locale === 'zh' ? '总重量' : 'VOLUME'}}</view>
            </view>
          </view>
          <!-- ec-sets-grid: 2 columns -->
          <view class="ec-sets-grid">
            <view class="ec-set-item" wx:for="{{item.sets}}" wx:for-item="s" wx:key="id">
              <view class="ec-set-num">{{index + 1}}</view>
              <view class="ec-set-val">{{s.weight}} <text class="ec-set-unit">{{s.weight_unit || 'kg'}}</text></view>
              <view class="ec-set-sep">×</view>
              <view class="ec-set-val reps">{{s.reps}} <text class="ec-set-unit">{{locale === 'zh' ? '次' : 'reps'}}</text></view>
            </view>
          </view>
        </view>
      </view>
    </scroll-view>

  </view>
</view>
