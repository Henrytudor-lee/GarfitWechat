<!--components/session-detail-modal/index.wxml-->
<view class="modal-mask" wx:if="{{isOpen && session}}" bindtap="onMaskTap">
  <view class="modal-sheet" catchtap="">

    <!-- Header -->
    <view class="modal-header">
      <view class="header-left">
        <view class="header-btn" bindtap="closeModal">✕</view>
      </view>
      <view class="header-title">{{locale === 'zh' ? '训练详情' : 'SESSION DETAIL'}}</view>
      <view class="header-right"></view>
    </view>

    <!-- Session Info -->
    <view class="session-info">
      <view class="session-date">{{session.dateStr || session.start_time}}</view>
      <view class="session-stats">
        <view class="stat-item">
          <view class="stat-val">{{_durationDisplay}}</view>
          <view class="stat-label">{{locale === 'zh' ? '时长' : 'DURATION'}}</view>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-item">
          <view class="stat-val">{{exerciseList.length}}</view>
          <view class="stat-label">{{locale === 'zh' ? '动作' : 'EXERCISES'}}</view>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-item">
          <view class="stat-val">{{getTotalSets(exerciseList)}}</view>
          <view class="stat-label">{{locale === 'zh' ? '组数' : 'SETS'}}</view>
        </view>
      </view>
    </view>

    <!-- Exercises List -->
    <scroll-view class="exercise-list" scroll-y>
      <view wx:if="{{loading}}" class="loading-state">{{locale === 'zh' ? '加载中...' : 'LOADING...'}}</view>
      <view wx:elif="{{exerciseList.length === 0}}" class="empty-state">{{locale === 'zh' ? '暂无动作记录' : 'NO EXERCISES RECORDED'}}</view>

      <view wx:else class="exercise-groups">
        <view class="group-card" wx:for="{{exerciseList}}" wx:key="id">
          <view class="group-header">
            <image
              wx:if="{{item.image_name}}"
              class="group-img"
              src="{{imgPrefix}}/{{item.image_name}}"
              mode="aspectFill"
            />
            <view wx:else class="group-img group-img-placeholder">🏋️</view>
            <view class="group-info">
              <view class="group-name">{{item.name_zh || item.name}}</view>
              <view class="group-sets-count">{{item.sets.length}} {{item.sets.length === 1 ? (locale === 'zh' ? '组' : 'SET') : (locale === 'zh' ? '组' : 'SETS')}}</view>
            </view>
          </view>

          <!-- Sets Grid (card chip style) -->
          <view class="sets-grid">
            <view
              wx:for="{{item.sets}}"
              wx:for-item="s"
              wx:key="id"
              class="set-chip"
            >
              <view class="set-chip-num">{{index + 1}}</view>
              <view class="set-chip-val">{{s.weight}}×{{s.reps}}</view>
              <view class="set-chip-unit">{{s.weight_unit || 'kg'}}/{{locale === 'zh' ? '次' : 'reps'}}</view>
            </view>
          </view>
        </view>
      </view>
    </scroll-view>

  </view>
</view>
