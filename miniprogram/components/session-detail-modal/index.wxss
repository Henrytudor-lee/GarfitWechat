/* components/session-detail-modal/index.wxss */

.modal-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.85);
  display: flex;
  flex-direction: column;
  z-index: 1000;
}

.modal-sheet {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  top: 0;
  background: #1A1A2E;
  border-radius: 32rpx 32rpx 0 0;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

/* Header */
.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 100rpx;
  padding: 0 32rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.1);
  flex-shrink: 0;
}

.header-left,
.header-right {
  width: 160rpx;
}

.header-right {
  display: flex;
  justify-content: flex-end;
}

.header-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
  text-align: center;
}

.header-btn {
  font-size: 26rpx;
  color: #E94560;
  font-weight: 600;
}

/* Session Info */
.session-info {
  padding: 32rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.1);
  flex-shrink: 0;
}

.session-date {
  font-size: 26rpx;
  color: #888;
  font-weight: 500;
  margin-bottom: 24rpx;
  text-align: center;
}

.session-stats {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 32rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.stat-val {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
}

.stat-label {
  font-size: 18rpx;
  font-weight: 700;
  color: #888;
  letter-spacing: 2rpx;
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.1);
}

/* Exercise List */
.exercise-list {
  flex: 1;
  overflow-y: auto;
  padding: 32rpx;
}

.loading-state,
.empty-state {
  text-align: center;
  color: #666;
  font-size: 26rpx;
  padding: 80rpx 0;
}

.exercise-groups {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.group-card {
  background: rgba(255, 255, 255, 0.05);
  border-radius: 16rpx;
  overflow: hidden;
}

.group-header {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
}

.group-img {
  width: 80rpx;
  height: 80rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.group-img-placeholder {
  background: #252540;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
}

.group-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.group-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #fff;
}

.group-sets-count {
  font-size: 20rpx;
  color: #888;
  font-weight: 500;
}

/* Sets Table */
.sets-table {
  padding: 0 24rpx 24rpx;
}

.sets-header-row {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
}

.sets-header-row .col-set,
.sets-header-row .col-weight,
.sets-header-row .col-reps {
  font-size: 18rpx;
  font-weight: 700;
  color: #666;
  letter-spacing: 2rpx;
  text-transform: uppercase;
}

.sets-data-row {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.03);
}

.sets-data-row:last-child {
  border-bottom: none;
}

.col-set {
  width: 60rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: #E94560;
  text-align: center;
}

.col-weight {
  flex: 1;
  font-size: 24rpx;
  font-weight: 600;
  color: #fff;
  text-align: center;
}

.col-reps {
  width: 120rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: #fff;
  text-align: center;
}
