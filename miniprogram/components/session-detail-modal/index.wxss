/* components/session-detail-modal/index.wxss */

/* Mask */
.modal-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.6);
  z-index: 9999;
}

/* Sheet — slides up from bottom */
.modal-sheet {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #1a1a1a;
  border-radius: 32rpx 32rpx 0 0;
  max-height: 85vh;
  display: flex;
  flex-direction: column;
  z-index: 10000;
}

/* Handle bar */
.modal-sheet::before {
  content: '';
  display: block;
  width: 80rpx;
  height: 8rpx;
  background: #444;
  border-radius: 4rpx;
  margin: 20rpx auto 0;
  flex-shrink: 0;
}

/* Header */
.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.08);
  flex-shrink: 0;
}

.header-left,
.header-right {
  width: 120rpx;
}

.header-right {
  display: flex;
  justify-content: flex-end;
}

.header-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #fff;
  text-align: center;
}

.header-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.08);
  color: #fff;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* Session Info */
.session-info {
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.08);
  flex-shrink: 0;
}

.session-date {
  font-size: 22rpx;
  color: #888;
  font-weight: 500;
  margin-bottom: 16rpx;
  text-align: center;
}

.session-stats {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.stat-val {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
}

.stat-label {
  font-size: 18rpx;
  font-weight: 700;
  color: #666;
  letter-spacing: 0.1em;
  text-transform: uppercase;
}

.stat-divider {
  width: 1rpx;
  height: 48rpx;
  background: rgba(255, 255, 255, 0.1);
}

/* Exercise List */
.exercise-list {
  flex: 1;
  min-height: 0;
  overflow-y: auto;
  padding: 24rpx 32rpx;
}

.loading-state,
.empty-state {
  text-align: center;
  color: #666;
  font-size: 24rpx;
  padding: 80rpx 0;
}

.exercise-groups {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.group-card {
  background: rgba(255, 255, 255, 0.05);
  border-radius: 20rpx;
  overflow: hidden;
}

.group-header {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
}

.group-img {
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
  object-fit: cover;
  background: rgba(255, 255, 255, 0.05);
}

.group-img-placeholder {
  background: rgba(255, 255, 255, 0.05);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
}

.group-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.group-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #fff;
}

.group-sets-count {
  font-size: 20rpx;
  color: #888;
  font-weight: 500;
}

/* Sets Grid (card chip style) — 2 columns */
.sets-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  padding: 16rpx 20rpx 20rpx;
}

.set-chip {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.06);
  border-radius: 12rpx;
  padding: 12rpx 16rpx;
  width: calc(50% - 8rpx);
  gap: 4rpx;
}

.set-chip-num {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: #ccf200;
  color: #1a1a1a;
  font-size: 20rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 4rpx;
}

.set-chip-val {
  font-size: 24rpx;
  font-weight: 700;
  color: #fff;
}

.set-chip-unit {
  font-size: 16rpx;
  color: #888;
  font-weight: 500;
}

/* ========================
   Day Theme Overrides
   ======================== */
.page.theme-day .modal-sheet {
  background: #f5f5f5;
}

.page.theme-day .modal-header {
  border-bottom-color: rgba(0, 0, 0, 0.08);
}

.page.theme-day .header-title {
  color: #1a1a1a;
}

.page.theme-day .header-btn {
  background: rgba(0, 0, 0, 0.06);
  color: #1a1a1a;
}

.page.theme-day .session-info {
  border-bottom-color: rgba(0, 0, 0, 0.08);
}

.page.theme-day .session-date {
  color: #71717a;
}

.page.theme-day .stat-val {
  color: #1a1a1a;
}

.page.theme-day .stat-label {
  color: #71717a;
}

.page.theme-day .stat-divider {
  background: rgba(0, 0, 0, 0.1);
}

.page.theme-day .loading-state,
.page.theme-day .empty-state {
  color: #a1a1aa;
}

.page.theme-day .group-card {
  background: rgba(0, 0, 0, 0.04);
}

.page.theme-day .group-header {
  border-bottom-color: rgba(0, 0, 0, 0.06);
}

.page.theme-day .group-img-placeholder {
  background: rgba(0, 0, 0, 0.04);
}

.page.theme-day .group-name {
  color: #1a1a1a;
}

.page.theme-day .group-sets-count {
  color: #71717a;
}

.page.theme-day .set-chip {
  background: rgba(0, 0, 0, 0.06);
}

.page.theme-day .set-chip-num {
  background: #ccf200;
  color: #1a1a1a;
}

.page.theme-day .set-chip-val {
  color: #1a1a1a;
}

.page.theme-day .set-chip-unit {
  color: #71717a;
}
