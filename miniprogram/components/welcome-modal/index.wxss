/* components/welcome-modal/index.wxss */

/* Mask */
.modal-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.7);
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* Sheet */
.modal-sheet {
  width: 90%;
  max-width: 600rpx;
  background: #1c1c1e;
  border-radius: 32rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  max-height: 90vh;
}

/* Header */
.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 32rpx 24rpx;
  flex-shrink: 0;
}

.header-left {
  width: 80rpx;
}

.header-center {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.header-right {
  width: 80rpx;
}

.lang-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
  padding: 10rpx;
  box-sizing: border-box;
}

.logo {
  width: 80rpx;
  height: 80rpx;
}

.welcome-text {
  font-size: 28rpx;
  font-weight: 700;
  color: #fff;
}

/* Form Content */
.form-content {
  padding: 0 32rpx;
  overflow-y: auto;
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.form-item {
  width: 100%;
}

/* Name Input */
.name-input {
  width: 100%;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 16rpx;
  padding: 0 24rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  color: #fff;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.name-input::placeholder {
  color: #666;
}

/* Avatar */
.avatar-item {
  display: flex;
  justify-content: center;
  padding: 8rpx 0;
}

.avatar-wrapper {
  position: relative;
  width: 160rpx;
  height: 160rpx;
}

.avatar-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.2);
}

.avatar-overlay {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
}

.upload-icon {
  font-size: 40rpx;
  color: #fff;
  font-weight: 300;
}

.upload-text {
  font-size: 20rpx;
  color: #fff;
}

/* Birthday Picker */
.picker-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 16rpx;
  padding: 0 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.picker-label {
  font-size: 26rpx;
  color: #888;
}

.picker-value {
  font-size: 28rpx;
  color: #fff;
}

.picker-value.placeholder {
  color: #666;
}

/* Gender Section */
.gender-section {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.section-label {
  font-size: 24rpx;
  color: #888;
  font-weight: 600;
  letter-spacing: 0.05em;
}

.gender-options {
  display: flex;
  gap: 16rpx;
}

.gender-option {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  height: 72rpx;
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #888;
}

.gender-option.selected {
  background: rgba(204, 242, 0, 0.15);
  border-color: #ccf200;
  color: #ccf200;
}

.gender-option radio {
  display: none;
}

/* Purpose Section */
.purpose-section {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.purpose-options {
  display: flex;
  gap: 12rpx;
}

.purpose-option {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 20rpx 8rpx;
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 20rpx;
  transition: all 0.2s;
}

.purpose-option.selected {
  background: rgba(204, 242, 0, 0.12);
  border-color: #ccf200;
}

.purpose-icon {
  font-size: 48rpx;
}

.purpose-text {
  font-size: 22rpx;
  font-weight: 600;
  color: #fff;
}

.purpose-option.selected .purpose-text {
  color: #ccf200;
}

/* Footer Buttons */
.modal-footer {
  display: flex;
  gap: 16rpx;
  padding: 24rpx 32rpx 32rpx;
  flex-shrink: 0;
}

.btn-cancel,
.btn-confirm {
  flex: 1;
  height: 88rpx;
  border-radius: 20rpx;
  font-size: 30rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  outline: none;
}

.btn-cancel {
  background: rgba(255, 255, 255, 0.08);
  color: #fff;
}

.btn-confirm {
  background: #ccf200;
  color: #000;
}

/* ========================
   Day Theme Overrides
   ======================== */
.page.theme-day .modal-sheet {
  background: #f5f5f5;
}

.page.theme-day .welcome-text {
  color: #1a1a1a;
}

.page.theme-day .name-input {
  background: rgba(0, 0, 0, 0.05);
  border-color: rgba(0, 0, 0, 0.1);
  color: #1a1a1a;
}

.page.theme-day .name-input::placeholder {
  color: #999;
}

.page.theme-day .picker-row {
  background: rgba(0, 0, 0, 0.05);
  border-color: rgba(0, 0, 0, 0.1);
}

.page.theme-day .picker-label,
.page.theme-day .picker-value.placeholder {
  color: #999;
}

.page.theme-day .picker-value {
  color: #1a1a1a;
}

.page.theme-day .section-label {
  color: #71717a;
}

.page.theme-day .gender-option {
  background: rgba(0, 0, 0, 0.04);
  border-color: rgba(0, 0, 0, 0.1);
  color: #71717a;
}

.page.theme-day .gender-option.selected {
  background: rgba(101, 191, 48, 0.12);
  border-color: #65bf30;
  color: #65bf30;
}

.page.theme-day .purpose-option {
  background: rgba(0, 0, 0, 0.04);
  border-color: rgba(0, 0, 0, 0.1);
}

.page.theme-day .purpose-option.selected {
  background: rgba(101, 191, 48, 0.1);
  border-color: #65bf30;
}

.page.theme-day .purpose-text {
  color: #1a1a1a;
}

.page.theme-day .purpose-option.selected .purpose-text {
  color: #65bf30;
}

.page.theme-day .btn-cancel {
  background: rgba(0, 0, 0, 0.06);
  color: #1a1a1a;
}

/* ========================
   Dark Neon Theme (G-FIT)
   ======================== */

/* Color Variables */
page {
  --neon-green: #C8FA3E;
  --neon-green-dim: rgba(200, 250, 62, 0.15);
  --neon-green-border: rgba(200, 250, 62, 0.4);
  --dark-bg: #0D0D0D;
  --dark-card: #1A1A1A;
  --dark-card-hover: #252525;
  --text-primary: #FFFFFF;
  --text-secondary: #888888;
  --text-muted: #555555;
}

/* Modal Mask - Darker overlay */
.modal-mask {
  background: rgba(0, 0, 0, 0.85);
}

/* Modal Sheet - Dark theme */
.modal-sheet {
  background: var(--dark-bg);
  border-radius: 40rpx;
  border: 1rpx solid rgba(200, 250, 62, 0.1);
  box-shadow: 0 0 60rpx rgba(200, 250, 62, 0.05);
}

/* Header - Dark Theme */
.modal-header {
  padding: 40rpx 32rpx 20rpx;
  background: linear-gradient(180deg, rgba(200, 250, 62, 0.03) 0%, transparent 100%);
}

.header-top {
  display: flex;
  justify-content: flex-end;
  margin-bottom: 24rpx;
}

.lang-btn {
  height: 48rpx;
  background: rgba(200, 250, 62, 0.1);
  border: 1rpx solid rgba(200, 250, 62, 0.2);
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  padding: 0 16rpx;
  flex-shrink: 0;
}

.lang-icon-img {
  width: 36rpx;
  height: 36rpx;
  flex-shrink: 0;
}



.header-brand {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.brand-title {
  font-size: 40rpx;
  font-weight: 800;
  color: var(--neon-green);
  letter-spacing: 2rpx;
  text-shadow: 0 0 20rpx rgba(200, 250, 62, 0.3);
}

.brand-subtitle {
  font-size: 26rpx;
  color: var(--text-secondary);
  font-weight: 400;
}

/* Form Content - Dark Theme */
.form-content {
  padding: 16rpx 32rpx 0;
  gap: 20rpx;
}

.form-item {
  width: 100%;
}

/* Field Label */
.field-label {
  display: block;
  font-size: 24rpx;
  font-weight: 600;
  color: var(--text-secondary);
  letter-spacing: 0.05em;
  text-transform: uppercase;
  margin-bottom: 16rpx;
}

/* Name Input - Dark Theme */
.name-input {
  width: 100%;
  height: 72rpx;
  background: var(--dark-card);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 16rpx;
  padding: 0 24rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  color: var(--text-primary);
}

.name-input::placeholder {
  color: var(--text-muted);
}

.name-input:focus {
  border-color: var(--neon-green-border);
  box-shadow: 0 0 0 4rpx rgba(200, 250, 62, 0.08);
}

/* Avatar Section - Dark Theme */
.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  padding: 8rpx 0;
}

.avatar-container {
  position: relative;
  width: 120rpx;
  height: 120rpx;
}

.avatar-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(200, 250, 62, 0.2);
}

.avatar-camera {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 44rpx;
  height: 44rpx;
  background: var(--neon-green);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(200, 250, 62, 0.3);
}

.camera-icon {
  font-size: 28rpx;
  color: #3f3636;
}

.avatar-hint {
  font-size: 24rpx;
  color: var(--text-muted);
}

/* Gender Selection - Dark Theme */
.gender-row {
  display: flex;
  gap: 16rpx;
}

.gender-btn {
  flex: 1;
  height: 64rpx;
  background: var(--dark-card);
  border: 1rpx solid rgba(255, 255, 255, 0.06);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

.gender-btn.active {
  background: var(--neon-green-dim);
  border-color: var(--neon-green);
}

.gender-text {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--text-secondary);
  transition: all 0.2s ease;
}

.gender-btn.active .gender-text {
  color: var(--neon-green);
}

/* Birthday Picker - Dark Theme */
.picker-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 72rpx;
  background: var(--dark-card);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 16rpx;
  padding: 0 24rpx;
}

.picker-label {
  font-size: 26rpx;
  color: var(--text-muted);
}

.picker-value {
  font-size: 28rpx;
  color: var(--text-primary);
}

.picker-value.placeholder {
  color: var(--text-muted);
}

/* Purpose Grid - Dark Theme */
.purpose-grid {
  display: flex;
  gap: 16rpx;
}

.purpose-card {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 24rpx 8rpx;
  background: var(--dark-card);
  border: 1rpx solid rgba(255, 255, 255, 0.06);
  border-radius: 20rpx;
  transition: all 0.25s ease;
}

.purpose-card:active {
  background: var(--dark-card-hover);
  transform: scale(0.98);
}

.purpose-card.selected {
  background: var(--neon-green-dim);
  border-color: var(--neon-green);
  box-shadow: 0 0 30rpx rgba(200, 250, 62, 0.1);
}

.purpose-icon {
  font-size: 52rpx;
}

.purpose-label {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--text-secondary);
  transition: all 0.2s ease;
}

.purpose-card.selected .purpose-label {
  color: var(--neon-green);
}

/* Footer Buttons - Dark Theme */
.modal-footer {
  padding: 32rpx;
  gap: 20rpx;
}

.btn-cancel {
  flex: 1;
  height: 80rpx;
  background: var(--dark-card);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 20rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-secondary);
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-confirm {
  flex: 1;
  height: 80rpx;
  background: var(--neon-green);
  border: none;
  border-radius: 20rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #0D0D0D;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(200, 250, 62, 0.25);
}

.btn-cancel::after,
.btn-confirm::after {
  border: none;
}

.btn-confirm:active {
  transform: scale(0.97);
  box-shadow: 0 4rpx 16rpx rgba(200, 250, 62, 0.2);
}

/* Language Button - Icon + Text */
.lang-icon-img {
  width: 48rpx;
  height: 48rpx;
}

.lang-current {
  font-weight: normal;
  white-space: nowrap;
  margin-left: 8rpx;
  font-size: 20rpx;
}

.lang-current.active {
  font-weight: 700;
  font-size: 26rpx;
  color: var(--neon-green);
}

.lang-btn {
  display: flex;
  align-items: center;
}