<!--components/add-exercise-modal/index.wxml-->
<view class="modal-mask {{theme === 'day' ? 'theme-day' : 'theme-night'}}" wx:if="{{isOpen}}" bindtap="onMaskTap">
  <view class="modal-sheet" catchtap="onSheetTap">

    <!-- Drag Handle -->
    <view class="drag-handle"></view>

    <!-- Header -->
    <view class="modal-header">
      <view class="header-left">
        <view wx:if="{{step === 'pick' && selectedMuscleOpen}}" class="header-btn" bindtap="closeMuscleMenu">
          <image class="header-btn-icon" src="{{imgPrefix}}/icons/close_icon_light.png" mode="aspectFit" />
        </view>
        <block wx:elif="{{step === 'pick'}}">
          <view class="header-btn" bindtap="toggleMuscleMenu">
            <image class="header-btn-icon" src="{{muscleIcon || (imgPrefix + '/icons/all.png')}}" mode="aspectFit" />
            <text class="header-btn-text">{{muscleLabel}}</text>
          </view>
        </block>
        <block wx:else>
          <view class="header-btn back-btn" bindtap="goBack">
            <image class="header-btn-icon" src="{{imgPrefix}}/icons/icon-back.png" mode="aspectFit" />
            <text>{{t.BACK}}</text>
          </view>
        </block>
      </view>

      <view class="header-title">{{step === 'pick' ? t.ADD_EXERCISE : t.SET_WEIGHT_REPS}}</view>

      <view class="header-right">
        <!-- step 2: favorite toggle -->
        <view wx:if="{{step === 'set' && selectedItem}}" class="header-btn header-btn-fav {{selectedItem.is_favorite ? 'is-fav' : ''}}" catchtap="onSelectedFavoriteTap">
          <text class="header-fav-icon">{{selectedItem.is_favorite ? '♥' : '♡'}}</text>
        </view>
        <view class="header-btn" bindtap="closeModal">
          <image class="header-btn-icon" src="{{imgPrefix}}/icons/close_icon_light.png" mode="aspectFit" />
        </view>
      </view>
    </view>

    <!-- Muscle Sidebar -->
    <view wx:if="{{selectedMuscleOpen && step === 'pick'}}" class="muscle-sidebar">
      <view class="muscle-item {{selectedMuscle === 0 ? 'active' : ''}}" bindtap="selectMuscle" data-id="0">{{t.ALL_MUSCLES}}</view>
      <view wx:for="{{muscleListWithName}}" wx:key="id" class="muscle-item {{selectedMuscle === item.id ? 'active' : ''}}" bindtap="selectMuscle" data-id="{{item.id}}">
        <image wx:if="{{item.icon}}" class="muscle-icon" src="{{imgPrefix}}/body-icons/{{item.icon}}" mode="aspectFit" />
        <text class="muscle-item-name">{{item._name}}</text>
      </view>
    </view>

    <!-- Content Area -->
    <view class="modal-content">

      <!-- STEP 1: Pick Exercise -->
      <view wx:if="{{step === 'pick'}}" style="flex:1;display:flex;flex-direction:column;min-height:0;">

        <!-- Search -->
        <view class="search-bar">
          <input class="search-input" placeholder="{{t.SEARCH_EXERCISES_MODAL}}" placeholder-class="search-placeholder" value="{{keyword}}" bindinput="onSearchInput" bindconfirm="onSearch" />
          <view class="filter-icons-wrap">
            <text class="filter-icon-btn {{filterFavor ? 'active' : ''}}" bindtap="onFavorFilterTap">♥</text>
            <text class="filter-icon-btn {{filterPracticed ? 'active' : ''}}" bindtap="onPracticedFilterTap">☑</text>
          </view>
        </view>

        <!-- Equipment Filters -->
        <view class="filter-section">
          <scroll-view class="filter-scroll" scroll-x>
            <view class="filter-row">
              <view class="filter-chip {{selectedEquipment === 0 ? 'active' : ''}}" bindtap="selectEquipment" data-id="0">{{t.ALL}} <text wx:if="{{selectedEquipment === 0}}" class="equip-name">{{t.EQUIPS}}</text></view>
              <view wx:for="{{equipmentListWithName}}" wx:key="id" class="filter-chip {{selectedEquipment === item.id ? 'active' : ''}}" bindtap="selectEquipment" data-id="{{item.id}}">
                <image wx:if="{{item.icon}}" class="equip-icon" src="{{imgPrefix}}/equipment_icons/{{item.icon}}" mode="aspectFit" />
                <text wx:if="{{selectedEquipment === item.id}}" class="equip-name">{{item._name}}</text>
              </view>
            </view>
          </scroll-view>
        </view>

        <!-- Exercise Grid - NOW SCROLLABLE -->
        <scroll-view class="exercise-grid" scroll-y bindscrolltolower="loadMore">
          <view wx:if="{{loading && list.length === 0}}" class="loading-state">{{t.LOADING}}</view>
          <view wx:elif="{{list.length === 0 && !loading}}" class="empty-state">{{t.NO_EXERCISES_FOUND}}</view>

          <view wx:else class="grid-inner">
            <view wx:for="{{list}}" wx:key="id" class="exercise-card" data-item="{{item}}" bindtap="onExerciseTap">
              <view class="card-img-wrap">
                <image wx:if="{{item.image_name}}" class="card-img" src="{{imgPrefix}}/{{item.image_name}}" mode="aspectFill" />
                <view wx:else class="card-img-placeholder">🏋️</view>
                <view class="card-gradient"></view>
                <!-- Top-left: DONE badge if practiced -->
                <view wx:if="{{item.is_practiced}}" class="done-badge">{{t.DONE}}</view>
                <!-- Bottom-left: heart/favorite icon (catchtap stops event bubbling) -->
                <view class="fav-icon-wrap" catchtap="onFavoriteTap" data-id="{{item.id}}">
                  <image wx:if="{{item.is_favorite}}" src="{{imgPrefix}}/icons/heart_filled.png" mode="aspectFit" />
                  <image wx:else src="{{imgPrefix}}/icons/heart.png" mode="aspectFit" />
                </view>
              </view>
              <view class="card-footer">
                <view class="card-name">{{locale === 'zh' ? item.name_zh : item.name}}</view>
                <view class="card-icons">
                  <block wx:for="{{item.muscle_icons}}" wx:key="index">
                    <image class="card-muscle-icon" src="{{imgPrefix}}/body-icons/{{item}}" mode="aspectFit" />
                  </block>
                  <image wx:if="{{item.equipment_icon}}" class="card-equip-icon" src="{{imgPrefix}}/equipment_icons/{{item.equipment_icon}}" mode="aspectFit" />
                </view>
              </view>
            </view>
          </view>

          <view wx:if="{{loadingMore}}" class="load-more">{{t.LOADING_MORE}}</view>
          <view wx:if="{{!hasMore && list.length > 0}}" class="no-more">— ALL —</view>
        </scroll-view>
      </view>

      <!-- STEP 2: Set Weight/Reps -->
      <view wx:if="{{step === 'set'}}" class="step2-wrap">

        <scroll-view scroll-y class="step2-scroll">

          <!-- Selected Exercise Card -->
          <view class="selected-exercise-card">
            <image wx:if="{{selectedItem.image_name}}" class="selected-img" src="{{imgPrefix}}/{{selectedItem.image_name}}" mode="aspectFill" />
            <view wx:else class="selected-img selected-img-placeholder">🏋️</view>
            <view class="selected-info">
              <view class="selected-name">{{locale === 'zh' ? selectedItem.name_zh : selectedItem.name}}</view>
              <view class="selected-tags">
                <text class="tag">{{locale === 'zh' ? (selectedItem.equipment_name || '其他') : (selectedItem.equipment_name || 'OTHER')}}</text>
                <text class="tag tag-neutral">{{locale === 'zh' ? (selectedItem.muscle_name_zh || '') : (selectedItem.muscle_name || '')}}</text>
              </view>
            </view>
            <view wx:if="{{historyMax}}" class="history-badge" bindtap="applyHistory">
              <text class="history-badge-label">{{t.LAST}}</text>
              <text class="history-badge-val">{{historyMax.weight}}{{historyMax.unit}} × {{historyMax.reps}}</text>
            </view>
          </view>

          <!-- Video -->
          <view wx:if="{{selectedItem.video_name}}" class="video-wrap">
            <video class="step2-video" src="{{vidPrefix}}/{{selectedItem.video_name}}" mode="aspectFill" show-center-play-btn show-play-btn enable-progress-gesture></video>
          </view>
          <view wx:else class="video-placeholder">
            <view class="video-placeholder-icon">🎬</view>
            <text class="video-placeholder-text">{{t.NO_DEMO_VIDEO_HINT}}</text>
            <text class="video-placeholder-sub">{{t.NO_DEMO_VIDEO_CONTACT}}</text>
          </view>

          <!-- Weight Input -->
          <view class="input-section">
            <view class="input-label-row">
              <view class="input-label">{{t.WEIGHT}} ({{weight_unit}})</view>
              <view class="quick-chips-row">
                <view wx:for="{{weightChips}}" wx:key="index" class="chip {{weight == item ? 'active' : ''}}" bindtap="setWeight" data-val="{{item}}">{{item}}</view>
              </view>
            </view>
            <view class="input-row">
              <view class="input-btn" bindtap="decWeight">−</view>
              <input class="input-field" type="digit" value="{{weight}}" bindinput="onWeightInput" placeholder="0" />
              <view class="input-btn" bindtap="incWeight">+</view>
            </view>
          </view>

          <!-- Unit Toggle -->
          <view class="unit-toggle">
            <view class="unit-btn {{weight_unit === 'kg' ? 'active' : ''}}" bindtap="setUnit" data-weight-unit="kg">KG</view>
            <view class="unit-btn {{weight_unit === 'lb' ? 'active' : ''}}" bindtap="setUnit" data-weight-unit="lb">LB</view>
          </view>

          <!-- Reps Input -->
          <view class="input-section">
            <view class="input-label-row">
              <view class="input-label">{{t.REPS}}</view>
              <view class="quick-chips-row">
                <view wx:for="{{repsChips}}" wx:key="index" class="chip {{reps == item ? 'active' : ''}}" bindtap="setReps" data-val="{{item}}">{{item}}</view>
              </view>
            </view>
            <view class="input-row">
              <view class="input-btn" bindtap="decReps">−</view>
              <input class="input-field" type="number" value="{{reps}}" bindinput="onRepsInput" placeholder="0" />
              <view class="input-btn" bindtap="incReps">+</view>
            </view>
          </view>

        </scroll-view>

      </view>
    </view>

    <!-- Bottom Confirm Button (Step 2 only) -->
    <view wx:if="{{step === 'set'}}" class="modal-footer">
      <button class="confirm-btn {{(weight < 0 || reps <= 0 || submitting) ? 'disabled' : ''}}" bindtap="confirmAdd" disabled="{{weight < 0 || reps <= 0 || submitting}}">{{submitting ? t.ADDING : t.ADD_TO_WORKOUT}}</button>
    </view>

  </view>
</view>