<!--components/add-exercise-modal/index.wxml-->
<view class="modal-mask" wx:if="{{isOpen}}" bindtap="onMaskTap">
  <view class="modal-sheet" catchtap="">

    <!-- Drag Handle -->
    <view class="drag-handle"></view>

    <!-- Header -->
    <view class="modal-header">
      <view class="header-left">
        <view wx:if="{{step === 'pick' && selectedMuscleOpen}}" class="header-btn" bindtap="closeMuscleMenu">
          <image class="header-btn-icon" src="{{imgPrefix}}/icons/close_icon_light.png" mode="aspectFit" />
        </view>
        <block wx:elif="{{step === 'pick'}}">
          <view class="header-btn" bindtap="toggleMuscleMenu">
            <image
              class="header-btn-icon"
              src="{{muscleIcon || (imgPrefix + '/icons/all.png')}}"
              mode="aspectFit"
            />
            <text class="header-btn-text">{{muscleLabel}}</text>
          </view>
        </block>
        <block wx:else>
          <view class="header-btn back-btn" bindtap="goBack">
            <image class="header-btn-icon" src="{{imgPrefix}}/icons/icon-back.svg" mode="aspectFit" />
            Back
          </view>
        </block>
      </view>

      <view class="header-title">{{step === 'pick' ? 'ADD EXERCISE' : 'SET WEIGHT'}}</view>

      <view class="header-right">
        <view class="header-btn" bindtap="closeModal">
          <image class="header-btn-icon" src="{{imgPrefix}}/icons/close_icon_light.png" mode="aspectFit" />
        </view>
      </view>
    </view>

    <!-- Muscle Sidebar -->
    <view wx:if="{{selectedMuscleOpen && step === 'pick'}}" class="muscle-sidebar">
      <view
        class="muscle-item {{selectedMuscle === 0 ? 'active' : ''}}"
        bindtap="selectMuscle"
        data-id="0"
      >All Muscles</view>
      <view
        wx:for="{{muscleList}}"
        wx:key="id"
        class="muscle-item {{selectedMuscle === item.id ? 'active' : ''}}"
        bindtap="selectMuscle"
        data-id="{{item.id}}"
      >
        <image wx:if="{{item.icon}}" class="muscle-icon" src="{{imgPrefix}}/body-icons/{{item.icon}}" mode="aspectFit" />
        <text class="muscle-item-name">{{item.name}}</text>
      </view>
    </view>

    <!-- Content Area -->
    <view class="modal-content">

      <!-- STEP 1: Pick Exercise -->
      <view wx:if="{{step === 'pick'}}" style="flex:1;display:flex;flex-direction:column;min-height:0;">

        <!-- Search -->
        <view class="search-bar">
          <view class="search-icon-wrap">
            <image src="{{imgPrefix}}/icons/icon-search.svg" mode="aspectFit" style="width:28rpx;height:28rpx;opacity:0.5;" />
          </view>
          <input
            class="search-input"
            placeholder="SEARCH EXERCISES..."
            placeholder-class="search-placeholder"
            value="{{keyword}}"
            bindinput="onSearchInput"
            bindconfirm="onSearch"
          />
        </view>

        <!-- Equipment Filters -->
        <view class="filter-section">
          <scroll-view class="filter-scroll" scroll-x>
            <view class="filter-row">
              <view
                class="filter-chip {{selectedEquipment === 0 ? 'active' : ''}}"
                bindtap="selectEquipment"
                data-id="0"
              >ALL</view>
              <view
                wx:for="{{equipmentList}}"
                wx:key="id"
                class="filter-chip {{selectedEquipment === item.id ? 'active' : ''}}"
                bindtap="selectEquipment"
                data-id="{{item.id}}"
              >
                <image wx:if="{{item.icon}}" class="equip-icon" src="{{imgPrefix}}/equipment_icons/{{item.icon}}" mode="aspectFit" />
                <text class="equip-name">{{item.name.toUpperCase()}}</text>
              </view>
            </view>
          </scroll-view>
        </view>

        <!-- Exercise Grid - NOW SCROLLABLE -->
        <scroll-view class="exercise-grid" scroll-y bindscrolltolower="loadMore">
          <view wx:if="{{loading && list.length === 0}}" class="loading-state">LOADING...</view>
          <view wx:elif="{{list.length === 0 && !loading}}" class="empty-state">NO EXERCISES FOUND</view>

          <view wx:else class="grid-inner">
            <view
              wx:for="{{list}}"
              wx:key="_id"
              class="exercise-card"
              data-item="{{item}}"
              bindtap="onExerciseTap"
            >
              <view class="card-img-wrap">
                <image
                  wx:if="{{item.image_name}}"
                  class="card-img"
                  src="{{imgPrefix}}/{{item.image_name}}"
                  mode="aspectFill"
                />
                <view wx:else class="card-img-placeholder">🏋️</view>
                <view class="card-gradient"></view>
                <view wx:if="{{item.is_favorite}}" class="fav-badge">WORKED</view>
              </view>
              <view class="card-footer">
                <view class="card-name">{{item.name}}</view>
                <view class="card-icons">
                  <block wx:for="{{item.muscle_icons}}" wx:key="index">
                    <image class="card-muscle-icon" src="{{imgPrefix}}/body-icons/{{item}}" mode="aspectFit" />
                  </block>
                  <image wx:if="{{item.equipment_icon}}" class="card-equip-icon" src="{{imgPrefix}}/equipment_icons/{{item.equipment_icon}}" mode="aspectFit" />
                </view>
              </view>
            </view>
          </view>

          <view wx:if="{{loadingMore}}" class="load-more">LOADING MORE...</view>
          <view wx:if="{{!hasMore && list.length > 0}}" class="no-more">— ALL —</view>
        </scroll-view>
      </view>

      <!-- STEP 2: Set Weight/Reps -->
      <view wx:if="{{step === 'set'}}" class="step2-wrap">

        <scroll-view scroll-y class="step2-scroll">

        <!-- Selected Exercise Card -->
        <view class="selected-exercise-card">
          <image
            wx:if="{{selectedItem.image_name}}"
            class="selected-img"
            src="{{imgPrefix}}/{{selectedItem.image_name}}"
            mode="aspectFill"
          />
          <view wx:else class="selected-img selected-img-placeholder">🏋️</view>
          <view class="selected-info">
            <view class="selected-name">{{selectedItem.name_zh || selectedItem.name}}</view>
            <view class="selected-tags">
              <text class="tag">{{selectedItem.equipment_name || 'OTHER'}}</text>
              <text class="tag tag-neutral">{{selectedItem.muscle_name || ''}}</text>
            </view>
          </view>
        </view>

        <!-- Last Time -->
        <view wx:if="{{historyMax}}" class="history-bar">
          <text class="history-label">Last time:</text>
          <view class="history-val" bindtap="applyHistory">{{historyMax.weight}}{{historyMax.unit}} × {{historyMax.reps}}</view>
        </view>

        <!-- Video -->
        <view wx:if="{{selectedItem.video_name}}" class="video-wrap">
          <video
            class="step2-video"
            src="{{vidPrefix}}/{{selectedItem.video_name}}"
            mode="aspectFill"
            show-center-play-btn
            show-play-btn
            enable-progress-gesture
          ></video>
        </view>

        <!-- Quick Weight Chips -->
        <view class="quick-chips">
          <view class="quick-chips-label">QUICK</view>
          <view class="chips-row">
            <view wx:for="{{weightChips}}" wx:key="index" class="chip {{weight == item ? 'active' : ''}}" bindtap="setWeight" data-val="{{item}}">{{item}}</view>
          </view>
        </view>

        <!-- Weight Input -->
        <view class="input-section">
          <view class="input-label">WEIGHT ({{weight_unit}})</view>
          <view class="input-row">
            <view class="input-btn" bindtap="decWeight">−</view>
            <input
              class="input-field"
              type="digit"
              value="{{weight}}"
              bindinput="onWeightInput"
              placeholder="0"
            />
            <view class="input-btn" bindtap="incWeight">+</view>
          </view>
        </view>

        <!-- Unit Toggle -->
        <view class="unit-toggle">
          <view
            class="unit-btn {{weight_unit === 'kg' ? 'active' : ''}}"
            bindtap="setUnit"
            data-weight-unit="kg"
          >KG</view>
          <view
            class="unit-btn {{weight_unit === 'lb' ? 'active' : ''}}"
            bindtap="setUnit"
            data-weight-unit="lb"
          >LB</view>
        </view>

        <!-- Quick Reps Chips -->
        <view class="quick-chips">
          <view class="quick-chips-label">QUICK</view>
          <view class="chips-row">
            <view wx:for="{{repsChips}}" wx:key="index" class="chip {{reps == item ? 'active' : ''}}" bindtap="setReps" data-val="{{item}}">{{item}}</view>
          </view>
        </view>

        <!-- Reps Input -->
        <view class="input-section">
          <view class="input-label">REPS</view>
          <view class="input-row">
            <view class="input-btn" bindtap="decReps">−</view>
            <input
              class="input-field"
              type="number"
              value="{{reps}}"
              bindinput="onRepsInput"
              placeholder="0"
            />
            <view class="input-btn" bindtap="incReps">+</view>
          </view>
        </view>

        </scroll-view>

      </view>
    </view>

    <!-- Bottom Confirm Button (Step 2 only) -->
    <view wx:if="{{step === 'set'}}" class="modal-footer">
      <button
        class="confirm-btn {{(weight < 0 || reps <= 0 || submitting) ? 'disabled' : ''}}"
        bindtap="confirmAdd"
        disabled="{{weight < 0 || reps <= 0 || submitting}}"
      >{{submitting ? 'ADDING...' : 'ADD TO WORKOUT'}}</button>
    </view>

  </view>
</view>
