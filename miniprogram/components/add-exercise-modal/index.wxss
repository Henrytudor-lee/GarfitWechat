/* components/add-exercise-modal/index.wxss */

.modal-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.85);
  display: flex;
  flex-direction: column;
  z-index: 1000;
}

.modal-sheet {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  top: 0;
  background: #1A1A2E;
  border-radius: 32rpx 32rpx 0 0;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

/* Drag Handle */
.drag-handle {
  width: 80rpx;
  height: 8rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 4rpx;
  margin: 24rpx auto 0;
}

/* Header */
.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 100rpx;
  padding: 0 32rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.1);
}

.header-left,
.header-right {
  width: 160rpx;
}

.header-right {
  display: flex;
  justify-content: flex-end;
}

.header-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
  text-align: center;
}

.header-btn {
  font-size: 26rpx;
  color: #E94560;
  font-weight: 600;
}

.back-btn {
  color: #E94560;
}

/* Muscle Sidebar */
.muscle-sidebar {
  position: absolute;
  left: 0;
  top: 100rpx;
  bottom: 0;
  width: 320rpx;
  background: rgba(0, 0, 0, 0.95);
  border-right: 1rpx solid rgba(255, 255, 255, 0.1);
  z-index: 20;
  overflow-y: auto;
}

.muscle-item {
  padding: 28rpx 32rpx;
  font-size: 26rpx;
  font-weight: 500;
  color: #aaa;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
}

.muscle-item.active {
  background: rgba(233, 69, 96, 0.2);
  color: #E94560;
}

/* Content Area */
.modal-content {
  flex: 1;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

/* Search Bar */
.search-bar {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  background: #1A1A2E;
}

.search-icon {
  font-size: 28rpx;
  margin-right: 16rpx;
}

.search-input {
  flex: 1;
  height: 72rpx;
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 26rpx;
  color: #fff;
}

.search-placeholder {
  color: #666;
}

/* Filter Section */
.filter-section {
  padding: 0 32rpx 20rpx;
}

.filter-scroll {
  white-space: nowrap;
}

.filter-row {
  display: inline-flex;
  gap: 12rpx;
  padding: 4rpx 0;
}

.filter-chip {
  display: inline-block;
  padding: 12rpx 24rpx;
  border-radius: 30rpx;
  font-size: 22rpx;
  font-weight: 700;
  background: rgba(255, 255, 255, 0.05);
  color: #888;
  flex-shrink: 0;
}

.filter-chip.active {
  background: #E94560;
  color: #fff;
}

/* Exercise Grid */
.exercise-grid {
  flex: 1;
  overflow-y: auto;
  padding: 0 32rpx 200rpx;
}

.loading-state,
.empty-state {
  text-align: center;
  color: #666;
  font-size: 26rpx;
  padding: 80rpx 0;
}

.load-more {
  text-align: center;
  color: #E94560;
  font-size: 24rpx;
  padding: 24rpx 0;
}

.no-more {
  text-align: center;
  color: #444;
  font-size: 22rpx;
  padding: 24rpx 0;
}

.grid-inner {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.exercise-card {
  width: calc((100% - 32rpx) / 3);
  position: relative;
  border-radius: 16rpx;
  overflow: hidden;
  background: #252540;
}

.card-img-wrap {
  width: 100%;
  aspect-ratio: 1;
  position: relative;
}

.card-img {
  width: 100%;
  height: 100%;
}

.card-img-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #252540;
  font-size: 60rpx;
}

.card-gradient {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 60%;
  background: linear-gradient(to top, rgba(0,0,0,0.7), transparent);
}

.fav-badge {
  position: absolute;
  top: 8rpx;
  left: 8rpx;
  background: #4CAF50;
  color: #fff;
  font-size: 18rpx;
  font-weight: 700;
  padding: 4rpx 10rpx;
  border-radius: 10rpx;
}

.card-footer {
  padding: 12rpx;
}

.card-name {
  font-size: 22rpx;
  font-weight: 600;
  color: #fff;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* STEP 2: Set Weight/Reps */
.selected-exercise-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 32rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 16rpx;
  margin: 24rpx 32rpx;
}

.selected-img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
}

.selected-img-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #252540;
  font-size: 48rpx;
}

.selected-info {
  flex: 1;
}

.selected-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 8rpx;
}

.selected-tags {
  display: flex;
  gap: 8rpx;
}

.tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  background: #E94560;
  color: #fff;
  border-radius: 10rpx;
}

.tag-neutral {
  background: rgba(255, 255, 255, 0.1);
  color: #aaa;
}

/* History Bar */
.history-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 0 32rpx 24rpx;
}

.history-label {
  font-size: 22rpx;
  color: #888;
  font-weight: 500;
}

.history-val {
  font-size: 22rpx;
  font-weight: 700;
  color: #E94560;
  background: rgba(233, 69, 96, 0.2);
  padding: 8rpx 20rpx;
  border-radius: 12rpx;
}

/* Input Section */
.input-section {
  padding: 0 32rpx 24rpx;
}

.input-label {
  font-size: 22rpx;
  font-weight: 700;
  color: #888;
  text-transform: uppercase;
  letter-spacing: 2rpx;
  margin-bottom: 16rpx;
}

.input-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.input-btn {
  width: 80rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #aaa;
}

.input-field {
  flex: 1;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
  text-align: center;
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
}

/* Unit Toggle */
.unit-toggle {
  display: flex;
  gap: 16rpx;
  padding: 0 32rpx 24rpx;
}

.unit-btn {
  flex: 1;
  height: 64rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
  color: #888;
}

.unit-btn.active {
  background: #E94560;
  color: #fff;
}

/* Modal Footer */
.modal-footer {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 32rpx;
  background: rgba(0, 0, 0, 0.9);
  border-top: 1rpx solid rgba(255, 255, 255, 0.1);
}

.confirm-btn {
  width: 100%;
  height: 96rpx;
  background: #E94560;
  color: #fff;
  border-radius: 48rpx;
  font-size: 30rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  letter-spacing: 2rpx;
}

.confirm-btn.disabled {
  opacity: 0.3;
}

.confirm-btn::after {
  border: none;
}
