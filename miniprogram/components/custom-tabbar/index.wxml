<!--components/custom-tabbar/index.wxml — cover-view tabbar for canvas layering-->
<cover-view class="tabbar-wrap {{theme === 'day' ? 'theme-day' : 'theme-night'}}">
  <!-- Bottom Nav -->
  <cover-view class="tabbar">
    <cover-view
      wx:for="{{tabs}}"
      wx:key="id"
      class="tab-item {{active === item.id ? 'active' : ''}}"
      data-id="{{item.id}}"
      data-url="{{item.url}}"
      bindtap="switchTab"
    >
      <cover-image
        src="{{active === item.id ? item.iconActive : item.icon}}"
        class="tab-icon-img"
      />
      <cover-view class="tab-label">{{item.label}}</cover-view>
    </cover-view>
  </cover-view>
</cover-view>
