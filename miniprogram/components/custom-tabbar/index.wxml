<!--components/custom-tabbar/index.wxml — garcia-fitness-new bottom nav-->
<view class="tabbar-wrap {{theme === 'day' ? 'theme-day' : 'theme-night'}}">
  <!-- Bottom Nav -->
  <view class="tabbar">
    <view
      wx:for="{{tabs}}"
      wx:key="id"
      class="tab-item {{active === item.id ? 'active' : ''}}"
      bindtap="switchTab"
      data-id="{{item.id}}"
      data-url="{{item.url}}"
    >
      <image
        src="{{active === item.id ? item.iconActive : item.icon}}"
        class="tab-icon-img"
      />
      <text class="tab-label">{{item.label}}</text>
    </view>
  </view>
</view>
