/* components/custom-tabbar/index.wxss — cover-view tabbar */

/* Wrap */
.tabbar-wrap {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 999;
  padding-bottom: env(safe-area-inset-bottom);
}

/* Night theme */
.tabbar-wrap.theme-night {
  background: #131313;
  border-top: 1px solid rgba(255, 255, 255, 0.08);
}

.tabbar-wrap.theme-night .tab-label {
  color: #71717a;
}

.tabbar-wrap.theme-night .tab-item.active .tab-label {
  color: #ccf200;
}

/* Day theme */
.tabbar-wrap.theme-day {
  background: #ffffff;
  border-top: 1px solid rgba(0, 0, 0, 0.10);
}

.tabbar-wrap.theme-day .tab-label {
  color: #a1a1aa;
}

.tabbar-wrap.theme-day .tab-item.active .tab-label {
  color: #85a000;
}

/* Tabbar */
.tabbar {
  width: 100%;
  height: 120rpx;
  display: flex;
  justify-content: space-around;
  align-items: flex-start;
  padding-top: 16rpx;
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.tab-icon-img {
  width: 44rpx;
  height: 44rpx;
  margin-bottom: 6rpx;
}

.tab-label {
  font-size: 18rpx;
  font-weight: 700;
  line-height: 1;
}
