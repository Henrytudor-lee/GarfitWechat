/* components/edit-exercise-modal/index.wxss */

.modal-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.85);
  display: flex;
  flex-direction: column;
  z-index: 1000;
}

.modal-sheet {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  top: 0;
  background: #1A1A2E;
  border-radius: 32rpx 32rpx 0 0;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

/* Header */
.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.1);
}

.exercise-info {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.exercise-img {
  width: 96rpx;
  height: 96rpx;
  border-radius: 16rpx;
}

.exercise-img-placeholder {
  background: #252540;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
}

.exercise-text {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.exercise-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
}

.exercise-sets {
  font-size: 22rpx;
  color: #888;
}

.header-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.action-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #E94560;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 700;
}

.action-btn-close {
  background: rgba(255, 255, 255, 0.1);
  color: #888;
  font-size: 26rpx;
}

/* Sets List */
.sets-list {
  flex: 1;
  overflow-y: auto;
  padding: 32rpx;
}

.set-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 16rpx;
  margin-bottom: 16rpx;
}

.set-item.deleted {
  opacity: 0.3;
}

.set-num {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #E94560;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.set-field {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.set-field-unit {
  flex-shrink: 0;
}

.field-label {
  font-size: 18rpx;
  font-weight: 700;
  color: #888;
  text-transform: uppercase;
  letter-spacing: 2rpx;
}

.field-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.field-btn {
  width: 48rpx;
  height: 48rpx;
  border-radius: 12rpx;
  background: #252540;
  color: #aaa;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.field-input {
  width: 112rpx;
  height: 48rpx;
  background: transparent;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 12rpx;
  text-align: center;
  font-size: 26rpx;
  font-weight: 700;
  color: #fff;
}

/* Unit Toggle */
.unit-toggle {
  display: flex;
  border-radius: 12rpx;
  overflow: hidden;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.unit-btn {
  padding: 12rpx 16rpx;
  font-size: 18rpx;
  font-weight: 700;
  color: #888;
  background: transparent;
}

.unit-btn.active {
  background: #E94560;
  color: #fff;
}

/* Delete Button */
.delete-btn {
  margin-left: auto;
  padding: 16rpx;
  font-size: 28rpx;
  color: #666;
}

/* Footer */
.modal-footer {
  padding: 32rpx;
  background: rgba(0, 0, 0, 0.9);
  border-top: 1rpx solid rgba(255, 255, 255, 0.1);
}

.save-btn {
  width: 100%;
  height: 96rpx;
  background: #E94560;
  color: #fff;
  border-radius: 48rpx;
  font-size: 28rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  letter-spacing: 2rpx;
}

.save-btn.disabled {
  opacity: 0.3;
}

.save-btn::after {
  border: none;
}